{
  "name": "scanlation-cms-edge",
  "type": "module",
  "version": "1.0.0",
  "description": "Professional Edge-First Scanlation CMS built with Astro and Cloudflare.",
  "overrides": {
    "esbuild": "0.25.12",
    "fast-xml-parser": "^5.3.4",
    "lodash": "^4.17.23",
    "undici": "^7.19.2",
    "wrangler": "^4.61.1"
  },
  "scripts": {
    "dev": "astro dev",
    "lint": "biome check . && eslint .",
    "lint:fix": "biome check . --write && eslint . --fix",
    "format": "biome format . --write",
    "check": "astro check && svelte-check",
    "test": "vitest run",
    "test:watch": "vitest",
    "analyze": "vite-bundle-visualizer",
    "build": "astro build",
    "preview": "astro build && wrangler pages dev ./dist",
    "astro": "astro",
    "deploy": "astro build && wrangler pages deploy",
    "cf-typegen": "wrangler types",
    "dev:cf": "concurrently \"wrangler pages dev --proxy 8789 --ip 0.0.0.0 --port 8788\" \"astro dev --port 8789 --host 0.0.0.0\"",
    "dev:remote": "concurrently \"wrangler pages dev --proxy 8789 --ip 0.0.0.0 --port 8788 --remote\" \"astro dev --port 8789 --host 0.0.0.0\"",
    "start": "astro start",
    "db:pull": "node scripts/db-export-custom.js",
    "db:reset:local": "if exist .wrangler\\state\\v3\\d1 rd /s /q .wrangler\\state\\v3\\d1",
    "db:local": "wrangler d1 execute babylon-scanlation-prod --local --file=./db_snapshots/dump.sql",
    "db:migrate": "wrangler d1 migrations apply babylon-scanlation-prod --local",
    "db:offline": "npm run db:reset:local && npm run db:migrate && npm run dev:cf",
    "db:online": "node scripts/db-sync.js",
    "db:purge": "node scripts/db-purge.js",
    "db:generate": "dotenv -e .env.local -- drizzle-kit generate",
    "db:migrate:local": "drizzle-kit migrate:sqlite",
    "db:push": "drizzle-kit push:sqlite"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.6",
    "@astrojs/cloudflare": "^12.6.12",
    "@astrojs/db": "^0.19.0",
    "@astrojs/sitemap": "^3.7.0",
    "@astrojs/svelte": "^7.2.5",
    "@fingerprintjs/fingerprintjs": "^5.0.1",
    "@google/gemini-cli": "^0.30.1",
    "@opentelemetry/api": "^1.9.0",
    "@zip.js/zip.js": "^2.7.64",
    "astro": "^5.18.0",
    "chart.js": "^4.5.1",
    "cropperjs": "^1.5.13",
    "dotenv": "^17.2.1",
    "drizzle-orm": "^0.45.1",
    "firebase": "^12.0.0",
    "firebase-admin": "^12.7.0",
    "jose": "^6.0.12",
    "p-limit": "^7.2.0",
    "svelte": "^5.46.0",
    "swiper": "^12.1.2",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250801.0",
    "@types/cropperjs": "^1.3.3",
    "@types/node": "^24.0.14",
    "@typescript-eslint/eslint-plugin": "^8.48.0",
    "@typescript-eslint/parser": "^8.48.0",
    "astro-eslint-parser": "^1.2.2",
    "concurrently": "^9.2.0",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.8",
    "esbuild": "0.25.12",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^1.5.0",
    "eslint-plugin-svelte": "^3.14.0",
    "prettier": "^3.7.1",
    "prettier-plugin-astro": "^0.14.1",
    "svelte-check": "^4.3.5",
    "svelte-eslint-parser": "^1.4.1",
    "typescript-eslint": "^8.46.2",
    "wrangler": "^4.61.1"
  }
}
