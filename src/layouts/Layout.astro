---
import '../styles/global.css';
import AdblockWall from '../components/AdblockWall.astro';
import BottomNav from '../components/BottomNav.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { getNewsCount } from '../lib/data/news';
import { getDB } from '../lib/db';
import { siteConfig } from '../site.config';

// Orion: Obtención de contador en el servidor para evitar peticiones del cliente (Ahorro masivo)
const db = getDB(Astro.locals.runtime.env);
const serverNewsCount = Astro.url.pathname.startsWith('/admin') ? 0 : await getNewsCount(db);

const {
  title: pageTitle,
  description = siteConfig.description,
  ogImage = siteConfig.assets.ogImage,
  canonicalURL = Astro.url.href,
  isNsfwContent, // Orion: Prop para forzar la temática según el contenido actual
} = Astro.props;

const { user } = Astro.locals;

// Orion: Detección de dispositivo para evitar carga de componentes móviles en Desktop
const ua = Astro.request.headers.get('user-agent') || '';
const isMobile = /mobile|iphone|ipad|android|blackberry|opera mini|iemobile|wpdesktop/i.test(ua);

const title = pageTitle ? `${pageTitle} | ${siteConfig.shortName}` : siteConfig.name;

const isAdminPage = Astro.url.pathname.startsWith('/admin');
const isVerifyPage = Astro.url.pathname === '/verify';
const isHome = Astro.url.pathname === '/';

const isVerified = Astro.cookies.get('site_verified')?.value === 'true';
const isBot = (Astro.locals as any).isBot;
const shouldBlockContent = !isVerified && !isVerifyPage && !isAdminPage && !isBot;

// Astra: Detección de modo NSFW.
// Prioridad: 1. Prop de la página (para forzar color en series específicas) -> 2. Cookie Global
const isNsfw =
  isNsfwContent !== undefined ? isNsfwContent : Astro.cookies.get('babylon_nsfw')?.value === 'true';

// Orion: URL Base para metadatos absolutos
const siteUrl = siteConfig.url;
const fullOgImage = ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`;
---

<!doctype html>
<html lang="es" class:list={[ { 'age-gate-active': shouldBlockContent, 'nsfw-mode': isNsfw } ]}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    {import.meta.env.PROD && (
      <>
        <link rel="icon" type="image/png" href={siteConfig.assets.favicon} />
        <link rel="manifest" href="/manifest.json?v=2" />
      </>
    )}
    <meta name="theme-color" content={siteConfig.theme.accent} />
    <meta name="google-site-verification" content="p13-r-hLZ82o8n9SUSdk_-bOPDu6aqYAvk8jf8ihFvw" />
    
    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />

    <!-- Googlebot Priority -->
    <meta name="googlebot" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
    <meta name="bingbot" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />

    <!-- Breadcrumbs JSON-LD -->
    <script type="application/ld+json" is:inline set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Inicio",
          "item": siteUrl
        },
        ...Astro.url.pathname.split('/').filter(Boolean).map((part, i, arr) => ({
          "@type": "ListItem",
          "position": i + 2,
          "name": part.charAt(0).toUpperCase() + part.slice(1).replace(/-/g, ' '),
          "item": `${siteUrl}/${arr.slice(0, i + 1).join('/')}`
        }))
      ]
    })} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={fullOgImage} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={Astro.url.href} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={fullOgImage} />

    <!-- Orion: Preconexiones Críticas (Optimización Extrema) -->
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
    <link rel="preconnect" href="https://crowdsubsequentadmire.com" crossorigin />
    <link rel="dns-prefetch" href="https://crowdsubsequentadmire.com" />
    <link rel="preconnect" href="https://pagead2.googlesyndication.com" crossorigin />
    <link rel="preconnect" href="https://challenges.cloudflare.com" crossorigin />

    <!-- Astra: Swiper (Carga Dinámica Orion) -->
    <link rel="icon" type="image/png" href={siteConfig.assets.favicon} />
    {import.meta.env.PROD && <link rel="manifest" href="/manifest.json?v=2" />}
    <slot name="head" />

    <style is:inline define:vars={{ 
      accent: siteConfig.theme.accent, 
      accentGlow: siteConfig.theme.accentGlow,
      bg: siteConfig.theme.background,
      bgAlt: siteConfig.theme.backgroundAlt
    }}>
      /* --- CRITICAL CSS (Prevent FOUC) --- */
      :root {
        --accent-color: var(--accent);
        --accent-glow: var(--accentGlow);
        --bg-color: var(--bg);
        --bg-alt: var(--bgAlt);
      }

      /* Bloqueo inmediato del fondo y color base */
      html { background-color: #020205 !important; color: #fff; }
      body { 
        margin: 0; 
        padding: 0; 
        background-color: #020205; 
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        overflow-x: hidden;
      }

      /* Reserva de espacio para Header y Hero para evitar saltos */
      .site-header { 
        height: 90px; 
        background: #020205; 
        position: fixed; 
        top: 0; 
        width: 100%; 
        z-index: 5000; 
      }
      
      .hero-carousel-section { 
        min-height: 520px; 
        background: #000; 
        width: 100%;
      }

      /* Esqueleto de Grillas (Featured y Updates) */
      .featured-grid-3x2 {
        display: grid !important;
        grid-template-columns: repeat(3, 1fr) !important;
        gap: 1.5rem !important;
        min-height: 600px;
      }

      .recent-updates-swiper:not(.swiper-initialized) .swiper-wrapper {
        display: flex !important;
        gap: 20px !important;
        overflow: hidden !important;
        min-height: 350px;
      }

      .custom-slide {
        flex-shrink: 0 !important;
        width: 240px !important;
      }

      /* Esqueleto de Cards (Evita el colapso interno) */
      .premium-update-card-wrapper, .featured-card-wrapper {
        aspect-ratio: 2 / 3 !important;
        background: rgba(255, 255, 255, 0.03) !important;
        border-radius: 24px !important;
        overflow: hidden !important;
      }

      .featured-card-wrapper {
        height: 320px !important;
        aspect-ratio: auto !important; /* Featured usa altura fija */
      }

      @media (max-width: 1100px) {
        .featured-grid-3x2 { grid-template-columns: repeat(2, 1fr) !important; }
      }

      @media (max-width: 768px) {
        .site-header { height: 80px; position: relative; }
        .featured-grid-3x2 { grid-template-columns: repeat(2, 1fr) !important; gap: 1rem !important; }
        .recent-updates-swiper:not(.swiper-initialized) .swiper-wrapper { gap: 15px !important; }
        .custom-slide { width: 160px !important; }
      }

      /* Ocultar contenido hasta que el navegador procese el CSS principal si es necesario */
      .site-main-content { visibility: visible; opacity: 1; }

      html.nsfw-mode {
        --accent-color: #900000 !important;
        --accent-glow: rgba(144, 0, 0, 0.6) !important;
      }

      /* Orion: Optimización de Renderizado (Aceleración por Hardware) */
      .stars-layer {
        will-change: transform;
        transform: translate3d(0, 0, 0);
        backface-visibility: hidden;
      }
      /* Astra: Limpieza de Slides para el Hero (Evita superposición translúcida) */
      .hero-swiper .swiper-slide {
        opacity: 0 !important;
        transition: opacity 0.6s ease-in-out !important;
        pointer-events: none;
      }
      .hero-swiper .swiper-slide-active {
        opacity: 1 !important;
        pointer-events: auto;
      }

      /* Astra: Capa Fantasma (Shield) */
      .image-wrapper {
        position: relative;
        user-select: none;
        -webkit-user-drag: none;
      }

      /* Este es el "cristal" que intercepta todos los clicks y el inspector */
      .image-wrapper::after {
        content: "";
        position: absolute;
        inset: 0;
        z-index: 10;
        background: transparent;
        cursor: default;
      }

      img {
        pointer-events: none !important;
        -webkit-touch-callout: none !important;
      }

      /* Astra: Estilos para Contenedores de Anuncios */
      .ad-container-root {
        display: flex;
        justify-content: center;
        align-items: center;
        width: 100%;
        margin: 0;
        min-height: 0;
        background: transparent;
        border-radius: 16px;
        overflow: hidden !important;
        position: relative;
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
      }

      .ad-container-root.square {
        height: auto;
        margin: 0 auto;
      }

      .ad-inner-wrapper {
        position: relative;
        z-index: 1;
        width: 100%;
        display: flex;
        justify-content: center;
        align-items: center;
      }

      /* --- CRITICAL SKELETON (Prevent FOUC) --- */
      body { background-color: #020205; margin: 0; color: #fff; font-family: system-ui, sans-serif; }
      .site-header { height: 90px; width: 100%; background: #020205; position: absolute; top: 0; z-index: 5000; }
      .hero-carousel-section { min-height: 520px; background: #000; width: 100vw; overflow: hidden; }
      .site-main-content { min-height: 100vh; display: flex; flex-direction: column; }
      @media (max-width: 1023px) { .site-header { height: 80px; position: relative; } }

      /* Orion: Padding condicional para páginas que no son la Home */
      @media (min-width: 1024px) {
        .padded-content {
          padding-top: 90px;
        }
      }
    </style>
  </head>
  <body 
    class="cosmos-theme" 
    style="opacity: 0; transition: opacity 0.2s ease;"
    data-user-id={user?.uid || 'guest'}
    data-user-state={user ? JSON.stringify({ uid: user.uid, email: user.email, isAdmin: user.isAdmin }) : 'null'}
    data-cosmos-physics={siteConfig.theme.cosmos.physicsEnabled ? 'true' : 'false'}
    data-news-count={serverNewsCount}
    data-is-dev={import.meta.env.DEV ? 'true' : 'false'}
  >
    <script is:inline>
      // Astra: Blindaje Anti-FOUC Nuclear
      (function() {
        const show = () => document.body.style.opacity = '1';
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', show);
        } else {
          show();
        }
        // Fallback de seguridad por si algo falla
        setTimeout(show, 150);
      })();
    </script>
    {siteConfig.theme.cosmos.enabled && (
      <div class="cosmos-bg">
        <div class="stars-layer base" style="transform: translate3d(calc(var(--cosmos-tx) * -0.02), calc(var(--cosmos-sy) * -0.02 + var(--cosmos-ty) * -0.02), 0)"></div>
        <div class="stars-layer mid" style="transform: translate3d(calc(var(--cosmos-tx) * -0.06), calc(var(--cosmos-sy) * -0.06 + var(--cosmos-ty) * -0.06), 0)"></div>
        <div class="stars-layer dust" style="transform: translate3d(calc(var(--cosmos-tx) * -0.12), calc(var(--cosmos-sy) * -0.12 + var(--cosmos-ty) * -0.12), 0)"></div>
        <div class="nebula-glow"></div>
        <div class="shooting-stars">
          <span></span><span></span><span></span>
        </div>
      </div>
    )}

    {shouldBlockContent ? (<div class="content-blocked-placeholder"></div>) : (
      <>
        {!isVerifyPage && (
          <Header />
        )}
        <main class="site-main-content">
          <slot />
        </main>
        {!isVerifyPage && isMobile && (
          <BottomNav />
        )}
        {!isVerifyPage && <Footer />}
      </>
    )}

    <div id="global-utilities-root"></div>
    {!isAdminPage && <AdblockWall />}
    
    <script is:inline>
      (function() {
        // 1. Blindaje Crítico (Astra Orion: Seguridad Activa)
        window.addEventListener('contextmenu', e => e.preventDefault(), { capture: true, passive: false });
        window.addEventListener('dragstart', e => e.preventDefault(), { capture: true, passive: false });

        // 2. Cargador de Imágenes (Astra: Fade-in Nativo Global)
        document.addEventListener('load', (e) => {
          if (e.target.tagName === 'IMG' && e.target.classList.contains('protected-img')) {
            e.target.classList.add('loaded');
          }
        }, true);
      })();
    </script>

