---
import '../styles/global.css';
import AdblockWall from '../components/AdblockWall.astro';
import BottomNav from '../components/BottomNav.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { getNewsCount } from '../lib/data/news';
import { getDB } from '../lib/db';
import { siteConfig } from '../site.config';

// Orion: Obtención de contador en el servidor para evitar peticiones del cliente (Ahorro masivo)
const db = getDB(Astro.locals.runtime.env);
const serverNewsCount = Astro.url.pathname.startsWith('/admin') ? 0 : await getNewsCount(db);

const {
  title: pageTitle,
  description = siteConfig.description,
  ogImage = siteConfig.assets.ogImage,
  canonicalURL = Astro.url.href,
  isNsfwContent, // Orion: Prop para forzar la temática según el contenido actual
} = Astro.props;

const { user } = Astro.locals;

// Orion: Detección de dispositivo para evitar carga de componentes móviles en Desktop
const ua = Astro.request.headers.get('user-agent') || '';
const isMobile = /mobile|iphone|ipad|android|blackberry|opera mini|iemobile|wpdesktop/i.test(ua);

const title = pageTitle ? `${pageTitle} | ${siteConfig.shortName}` : siteConfig.name;

const isAdminPage = Astro.url.pathname.startsWith('/admin');
const isVerifyPage = Astro.url.pathname === '/verify';

const isVerified = Astro.cookies.get('site_verified')?.value === 'true';
const isBot = (Astro.locals as any).isBot;
const shouldBlockContent = !isVerified && !isVerifyPage && !isAdminPage && !isBot;

// Astra: Detección de modo NSFW.
// Prioridad: 1. Prop de la página (para forzar color en series específicas) -> 2. Cookie Global
const isNsfw =
  isNsfwContent !== undefined ? isNsfwContent : Astro.cookies.get('babylon_nsfw')?.value === 'true';

// Orion: URL Base para metadatos absolutos
const siteUrl = siteConfig.url;
const fullOgImage = ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`;
---

<!doctype html>
<html lang="es" class:list={[ { 'age-gate-active': shouldBlockContent, 'nsfw-mode': isNsfw } ]}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <link rel="icon" type="image/png" href={siteConfig.assets.favicon} />
    <link rel="manifest" href="/manifest.json?v=2" />
    <meta name="theme-color" content={siteConfig.theme.accent} />
    <meta name="google-site-verification" content="p13-r-hLZ82o8n9SUSdk_-bOPDu6aqYAvk8jf8ihFvw" />
    
    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />

    <!-- Googlebot Priority -->
    <meta name="googlebot" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
    <meta name="bingbot" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />

    <!-- Breadcrumbs JSON-LD -->
    <script type="application/ld+json" is:inline set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Inicio",
          "item": siteUrl
        },
        ...Astro.url.pathname.split('/').filter(Boolean).map((part, i, arr) => ({
          "@type": "ListItem",
          "position": i + 2,
          "name": part.charAt(0).toUpperCase() + part.slice(1).replace(/-/g, ' '),
          "item": `${siteUrl}/${arr.slice(0, i + 1).join('/')}`
        }))
      ]
    })} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={fullOgImage} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={Astro.url.href} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={fullOgImage} />

    <!-- Orion: Preconexiones Críticas (Optimización Extrema) -->
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
    <link rel="preconnect" href="https://crowdsubsequentadmire.com" crossorigin />
    <link rel="dns-prefetch" href="https://crowdsubsequentadmire.com" />
    <link rel="preconnect" href="https://pagead2.googlesyndication.com" crossorigin />
    <link rel="preconnect" href="https://challenges.cloudflare.com" crossorigin />

    <!-- Astra: Swiper (Carga Única desde CDN para evitar fragmentación de Vite) -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
    <script is:inline src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>

    <slot name="head" />

    <style is:global define:vars={{ 
      accent: siteConfig.theme.accent, 
      accentGlow: siteConfig.theme.accentGlow,
      bg: siteConfig.theme.background,
      bgAlt: siteConfig.theme.backgroundAlt
    }}>
      :root {
        --accent-color: var(--accent);
        --accent-glow: var(--accentGlow);
        --bg-color: var(--bg);
        --bg-alt: var(--bgAlt);
      }
      
      html.nsfw-mode {
        --accent-color: #900000 !important;
        --accent-glow: rgba(144, 0, 0, 0.6) !important;
      }
    </style>
    <style is:global>
      /* Astra: Capa Fantasma (Shield) */
      .image-wrapper {
        position: relative;
        user-select: none;
        -webkit-user-drag: none;
      }
      
      /* Este es el "cristal" que intercepta todos los clicks y el inspector */
      .image-wrapper::after {
        content: "";
        position: absolute;
        inset: 0;
        z-index: 10;
        background: transparent;
        cursor: default;
      }

      img {
        pointer-events: none !important;
        -webkit-touch-callout: none !important;
      }
      
      /* Astra: Estilos para Contenedores de Anuncios Camuflados */
      .content-dynamic-wrap {
        display: flex;
        justify-content: center;
        align-items: flex-start;
        width: 100%;
        margin: 2.5rem 0;
        min-height: 50px;
        background: rgba(255, 255, 255, 0.01);
        border-radius: 16px;
        overflow: visible !important;
        position: relative;
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
      }

      .content-dynamic-wrap.square {
        min-height: 250px;
        margin: 2.5rem auto;
      }

      .dynamic-inner-box {
        position: relative;
        z-index: 1;
        width: 100%;
        display: flex;
        justify-content: center;
      }
    </style>
  </head>
  <body 
    class="cosmos-theme" 
    data-user-id={user?.uid || 'guest'}
    data-user-state={user ? JSON.stringify({ uid: user.uid, email: user.email, isAdmin: user.isAdmin }) : 'null'}
    data-cosmos-physics={siteConfig.theme.cosmos.physicsEnabled ? 'true' : 'false'}
    data-news-count={serverNewsCount}
  >
    {siteConfig.theme.cosmos.enabled && (
      <div class="cosmos-bg">
        <div class="stars-layer base"></div>
        <div class="stars-layer mid"></div>
        <div class="stars-layer dust"></div>
        <div class="nebula-glow"></div>
        <div class="shooting-stars">
          <span></span><span></span><span></span>
        </div>
      </div>
    )}

    {shouldBlockContent ? (<div class="content-blocked-placeholder"></div>) : (
      <>
        {!isVerifyPage && (
          <Header />
        )}
        <main class="site-main-content">
          <slot />
        </main>
        {!isVerifyPage && isMobile && (
          <BottomNav />
        )}
        {!isVerifyPage && <Footer />}
      </>
    )}

    <div id="global-utilities-root"></div>
    {!isAdminPage && <AdblockWall />}
    
    <script is:inline>
