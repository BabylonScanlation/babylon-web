---
import '../styles/global.css';
import '../styles/components.css';
import { siteConfig } from '../site.config';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BottomNav from '../components/BottomNav.astro';
import AuthModal from '../components/AuthModal.svelte';
import AgeGate from '../components/AgeGate.svelte';
import ToastContainer from '../components/ToastContainer.svelte';
import AppBanner from '../components/AppBanner.svelte';
import AdblockWall from '../components/AdblockWall.astro';

const {
  title: pageTitle,
  description = siteConfig.description,
  ogImage = siteConfig.assets.ogImage,
  canonicalURL = Astro.url.href,
  isNsfwContent, // Orion: Prop para forzar la temática según el contenido actual
} = Astro.props;

const { user } = Astro.locals;

// Orion: Detección de dispositivo para evitar carga de componentes móviles en Desktop
const ua = Astro.request.headers.get('user-agent') || '';
const isMobile = /mobile|iphone|ipad|android|blackberry|opera mini|iemobile|wpdesktop/i.test(ua);

const title = pageTitle ? `${pageTitle} | ${siteConfig.shortName}` : siteConfig.name;

const isAdminPage = Astro.url.pathname.startsWith('/admin');
const isVerifyPage = Astro.url.pathname === '/verify';

const isVerified = Astro.cookies.get('site_verified')?.value === 'true';
const isBot = (Astro.locals as any).isBot;
const shouldBlockContent = !isVerified && !isVerifyPage && !isAdminPage && !isBot;

// Astra: Detección de modo NSFW.
// Prioridad: 1. Prop de la página (para forzar color en series específicas) -> 2. Cookie Global
const isNsfw =
  isNsfwContent !== undefined ? isNsfwContent : Astro.cookies.get('babylon_nsfw')?.value === 'true';

// Orion: URL Base para metadatos absolutos
const siteUrl = siteConfig.url;
const fullOgImage = ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`;
---

<!doctype html>
<html lang="es" class:list={[ { 'age-gate-active': shouldBlockContent, 'nsfw-mode': isNsfw } ]}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <link rel="icon" type="image/svg+xml" href={siteConfig.assets.favicon} />
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content={siteConfig.theme.accent} />
    <meta name="google-site-verification" content="p13-r-hLZ82o8n9SUSdk_-bOPDu6aqYAvk8jf8ihFvw" />
    
    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />

    <!-- Googlebot Priority -->
    <meta name="googlebot" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
    <meta name="bingbot" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />

    <!-- Breadcrumbs JSON-LD -->
    <script type="application/ld+json" is:inline set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Inicio",
          "item": siteUrl
        },
        ...Astro.url.pathname.split('/').filter(Boolean).map((part, i, arr) => ({
          "@type": "ListItem",
          "position": i + 2,
          "name": part.charAt(0).toUpperCase() + part.slice(1).replace(/-/g, ' '),
          "item": `${siteUrl}/${arr.slice(0, i + 1).join('/')}`
        }))
      ]
    })} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={fullOgImage} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={Astro.url.href} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={fullOgImage} />

    <slot name="head" />

    <script is:inline>
      // Astra: Silenciador de errores de Privacy Sandbox/Permissions-Policy
      (function() {
        const originalError = console.error;
        console.error = function(...args) {
          if (args[0] && typeof args[0] === 'string' && (
              args[0].includes('browsing-topics') || 
              args[0].includes('run-ad-auction') || 
              args[0].includes('join-ad-interest-group')
          )) return;
          originalError.apply(console, args);
        };
      })();
    </script>
    
    <style is:global set:html={`
      :root {
        --accent-color: ${siteConfig.theme.accent};
        --accent-glow: ${siteConfig.theme.accentGlow};
        --bg-color: ${siteConfig.theme.background};
        --bg-alt: ${siteConfig.theme.backgroundAlt};
      }
      
      html.nsfw-mode {
        --accent-color: #900000 !important;
        --accent-glow: rgba(144, 0, 0, 0.6) !important;
      }
    `}>
    </style>
  </head>
  <body 
    class="cosmos-theme" 
    data-user-id={user?.uid || 'guest'}
    data-cosmos-physics={siteConfig.theme.cosmos.physicsEnabled ? 'true' : 'false'}
  >
    {siteConfig.theme.cosmos.enabled && (
      <div class="cosmos-bg">
        <div class="stars-layer base"></div>
        <div class="stars-layer mid"></div>
        <div class="stars-layer dust"></div>
        <div class="nebula-glow"></div>
        <div class="shooting-stars">
          <span></span><span></span><span></span>
        </div>
      </div>
    )}

    {shouldBlockContent ? (
      <AgeGate client:load isVerificationPage={false} />
    ) : (
      <>
        {!isVerifyPage && (
          <Header />
        )}
        <main class="site-main-content">
          <slot />
        </main>
        {!isVerifyPage && isMobile && (
          <BottomNav />
        )}
        {!isVerifyPage && <Footer />}
        <AuthModal client:load />
        <ToastContainer client:idle />
        {!isVerifyPage && <AppBanner client:idle />}
        {!isAdminPage && <AdblockWall />}
      </>
    )}
    
    <script>
      import { NewsService } from '../lib/news-service';
      // Orion: Inicializar el servicio (él mismo leerá el data-latest-news del body)
      NewsService.getInstance();
    </script>
    
    <script>
      // Astra: Motor de Física Estelar (Paralaje 2.0)
      const initCosmos = () => {
        const bg = document.querySelector('.cosmos-bg');
        if (!bg) return;

        const layers = {
          base: document.querySelector('.stars-layer.base') as HTMLElement,
          mid: document.querySelector('.stars-layer.mid') as HTMLElement,
          dust: document.querySelector('.stars-layer.dust') as HTMLElement,
          nebula: document.querySelector('.nebula-glow') as HTMLElement
        };

        if (!layers.base) return;

        let mouseX = 0;
        let mouseY = 0;
        let scrollY = window.scrollY;
        let targetX = 0;
        let targetY = 0;
        let animationFrameId: number;
        
        let winW = window.innerWidth;
        let winH = window.innerHeight;

        // Factores de profundidad (Paralaje)
        const D_BASE = 0.02;   // Fondo lejano (casi quieto)
        const D_MID = 0.06;    // Plano medio
        const D_DUST = 0.12;   // Primer plano (más rápido = más cerca)
        const D_NEBULA = 0.01; // Ambiente

        const onMouseMove = (e: MouseEvent) => {
          mouseX = (e.clientX - winW / 2);
          mouseY = (e.clientY - winH / 2);
        };

        const onScroll = () => {
          scrollY = window.pageYOffset || document.documentElement.scrollTop;
        };

        const onResize = () => {
          winW = window.innerWidth;
          winH = window.innerHeight;
        };

        document.addEventListener('mousemove', onMouseMove, { passive: true });
        window.addEventListener('scroll', onScroll, { passive: true });
        window.addEventListener('resize', onResize, { passive: true });

        const animate = () => {
          targetX += (mouseX - targetX) * 0.04;
          targetY += (mouseY - targetY) * 0.04;

          if (layers.base) {
            layers.base.style.transform = `translate3d(${-targetX * D_BASE}px, ${-scrollY * D_BASE - targetY * D_BASE}px, 0)`;
          }
          if (layers.mid) {
            layers.mid.style.transform = `translate3d(${-targetX * D_MID}px, ${-scrollY * D_MID - targetY * D_MID}px, 0)`;
          }
          if (layers.dust) {
            layers.dust.style.transform = `translate3d(${-targetX * D_DUST}px, ${-scrollY * D_DUST - targetY * D_DUST}px, 0)`;
          }
          if (layers.nebula) {
             layers.nebula.style.transform = `translate3d(${-targetX * D_NEBULA}px, ${-targetY * D_NEBULA}px, 0) scale(1.2)`;
          }

          animationFrameId = requestAnimationFrame(animate);
        };

        animate();

        return () => {
            if (animationFrameId) cancelAnimationFrame(animationFrameId);
            document.removeEventListener('mousemove', onMouseMove);
            window.removeEventListener('scroll', onScroll);
            window.removeEventListener('resize', onResize);
        };
      };

      let cleanup: (() => void) | undefined;

      document.addEventListener('astro:page-load', () => {
        if (cleanup) cleanup();

        const physicsEnabled = document.body.getAttribute('data-cosmos-physics') === 'true';
        if (!physicsEnabled) return;

        cleanup = initCosmos();
      });
    </script>
  </body>
</html>
