---
import '../styles/global.css';
import AdblockWall from '../components/AdblockWall.astro';
import BottomNav from '../components/BottomNav.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { siteConfig } from '../site.config';
import { getDB } from '../lib/db';
import { sql } from 'drizzle-orm';
import * as schema from '../db/schema';

// Orion: Obtención de contador en el servidor para evitar peticiones del cliente (Ahorro masivo)
const getInitialNewsCount = async () => {
  try {
    const db = getDB(Astro.locals.runtime.env);
    // Solo consultamos si no es una página de administración para ahorrar lecturas
    if (Astro.url.pathname.startsWith('/admin')) return 0;
    const result = await db.select({ count: sql<number>`count(*)` }).from(schema.news).all();
    return result[0]?.count || 0;
  } catch { return 0; }
};

const serverNewsCount = await getInitialNewsCount();

const {
  title: pageTitle,
  description = siteConfig.description,
  ogImage = siteConfig.assets.ogImage,
  canonicalURL = Astro.url.href,
  isNsfwContent, // Orion: Prop para forzar la temática según el contenido actual
} = Astro.props;

const { user } = Astro.locals;

// Orion: Detección de dispositivo para evitar carga de componentes móviles en Desktop
const ua = Astro.request.headers.get('user-agent') || '';
const isMobile = /mobile|iphone|ipad|android|blackberry|opera mini|iemobile|wpdesktop/i.test(ua);

const title = pageTitle ? `${pageTitle} | ${siteConfig.shortName}` : siteConfig.name;

const isAdminPage = Astro.url.pathname.startsWith('/admin');
const isVerifyPage = Astro.url.pathname === '/verify';

const isVerified = Astro.cookies.get('site_verified')?.value === 'true';
const isBot = (Astro.locals as any).isBot;
const shouldBlockContent = !isVerified && !isVerifyPage && !isAdminPage && !isBot;

// Astra: Detección de modo NSFW.
// Prioridad: 1. Prop de la página (para forzar color en series específicas) -> 2. Cookie Global
const isNsfw =
  isNsfwContent !== undefined ? isNsfwContent : Astro.cookies.get('babylon_nsfw')?.value === 'true';

// Orion: URL Base para metadatos absolutos
const siteUrl = siteConfig.url;
const fullOgImage = ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`;
---

<!doctype html>
<html lang="es" class:list={[ { 'age-gate-active': shouldBlockContent, 'nsfw-mode': isNsfw } ]}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <link rel="icon" type="image/png" href={siteConfig.assets.favicon} />
    <link rel="manifest" href="/manifest.json?v=2" />
    <meta name="theme-color" content={siteConfig.theme.accent} />
    <meta name="google-site-verification" content="p13-r-hLZ82o8n9SUSdk_-bOPDu6aqYAvk8jf8ihFvw" />
    
    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />

    <!-- Googlebot Priority -->
    <meta name="googlebot" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
    <meta name="bingbot" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />

    <!-- Breadcrumbs JSON-LD -->
    <script type="application/ld+json" is:inline set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Inicio",
          "item": siteUrl
        },
        ...Astro.url.pathname.split('/').filter(Boolean).map((part, i, arr) => ({
          "@type": "ListItem",
          "position": i + 2,
          "name": part.charAt(0).toUpperCase() + part.slice(1).replace(/-/g, ' '),
          "item": `${siteUrl}/${arr.slice(0, i + 1).join('/')}`
        }))
      ]
    })} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={fullOgImage} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={Astro.url.href} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={fullOgImage} />

    <!-- Orion: Preconexiones Críticas (Optimización Extrema) -->
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
    <link rel="preconnect" href="https://pagead2.googlesyndication.com" crossorigin />
    <link rel="preconnect" href="https://challenges.cloudflare.com" crossorigin />
    <link rel="dns-prefetch" href="https://crowdsubsequentadmire.com" />

    <!-- Astra: Swiper (Carga Única desde CDN para evitar fragmentación de Vite) -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
    <script is:inline src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>

    <slot name="head" />

    <script is:inline>
      // Astra: Silenciador de errores de Privacy Sandbox/Permissions-Policy
      (function() {
        const originalError = console.error;
        console.error = function(...args) {
          if (args[0] && typeof args[0] === 'string' && (
              args[0].includes('browsing-topics') || 
              args[0].includes('run-ad-auction') || 
              args[0].includes('join-ad-interest-group')
          )) return;
          originalError.apply(console, args);
        };
      })();
    </script>
    
    <style is:global define:vars={{ 
      accent: siteConfig.theme.accent, 
      accentGlow: siteConfig.theme.accentGlow,
      bg: siteConfig.theme.background,
      bgAlt: siteConfig.theme.backgroundAlt
    }}>
      :root {
        --accent-color: var(--accent);
        --accent-glow: var(--accentGlow);
        --bg-color: var(--bg);
        --bg-alt: var(--bgAlt);
      }
      
      html.nsfw-mode {
        --accent-color: #900000 !important;
        --accent-glow: rgba(144, 0, 0, 0.6) !important;
      }
    </style>
    <style is:global>
      /* Astra: Estilos críticos para imágenes de noticias (Carga prioritaria para evitar parpadeos) */
      .news-gallery, 
      .post-images, 
      .news-gallery-container {
        display: grid;
        grid-template-columns: 1fr;
        gap: 2rem;
        margin-top: 1.5rem;
        width: 100%;
      }
      
      /* Selectores de alta especificidad para garantizar el tamaño sin usar !important */
      article.news-article .prose img,
      .premium-news-post .news-gallery img,
      .news-post .post-images img {
        width: 100%;
        height: auto;
        max-height: 1200px;
        object-fit: contain;
        display: block;
        margin: 2.5rem auto;
      }

      .news-gallery .image-wrapper, 
      .post-images .image-wrapper {
        position: relative;
        border-radius: 20px;
        overflow: hidden;
        border: 1px solid rgba(255, 255, 255, 0.08);
        background: rgba(0, 0, 0, 0.3);
        width: 100%;
        display: block;
      }
    </style>
  </head>
  <body 
    class="cosmos-theme" 
    data-user-id={user?.uid || 'guest'}
    data-user-state={user ? JSON.stringify({ uid: user.uid, email: user.email, isAdmin: user.isAdmin }) : 'null'}
    data-cosmos-physics={siteConfig.theme.cosmos.physicsEnabled ? 'true' : 'false'}
  >
    {siteConfig.theme.cosmos.enabled && (
      <div class="cosmos-bg">
        <div class="stars-layer base"></div>
        <div class="stars-layer mid"></div>
        <div class="stars-layer dust"></div>
        <div class="nebula-glow"></div>
        <div class="shooting-stars">
          <span></span><span></span><span></span>
        </div>
      </div>
    )}

    {shouldBlockContent ? (<div class="content-blocked-placeholder"></div>) : (
      <>
        {!isVerifyPage && (
          <Header />
        )}
        <main class="site-main-content">
          <slot />
        </main>
        {!isVerifyPage && isMobile && (
          <BottomNav />
        )}
        {!isVerifyPage && <Footer />}
      </>
    )}

    <div id="global-utilities-root"></div>
    {!isAdminPage && <AdblockWall />}
    
    <script is:inline define:vars={{ serverNewsCount }}>
      const initAll = async () => {
        // Orion: Singleton para evitar doble ejecución (Astro lifecycle fix)
        if (window._babylonInitialized) return;
        window._babylonInitialized = true;

        // 0. Instant NSFW
        const htmlHasMode = document.documentElement.classList.contains('nsfw-mode');
        const isNsfwCookie = document.cookie.split(';').some(c => c.trim().startsWith('babylon_nsfw=true'));
        if (isNsfwCookie || htmlHasMode) {
          const header = document.getElementById('main-header');
          if (header) header.classList.add('nsfw-active');
          
          // Astra: Actualización de logo instantánea
          const logoImg = document.getElementById('header-logo-img');
          if (logoImg) {
            const logoNsfw = '/iconpage/babylon-logo-4.webp'; // De siteConfig
            const r2Url = '/api/assets/proxy';
            logoImg.src = logoNsfw.startsWith('/') ? `${r2Url}${logoNsfw}` : logoNsfw;
          }
        }

        // 1. Cosmos Physics
        const physicsEnabled = document.body.getAttribute('data-cosmos-physics') === 'true';
        if (physicsEnabled) {
          const layers = { 
            base: document.querySelector('.stars-layer.base'), 
            mid: document.querySelector('.stars-layer.mid'), 
            dust: document.querySelector('.stars-layer.dust'), 
            nebula: document.querySelector('.nebula-glow') 
          };
          if (layers.base) {
            let mouseX = 0, mouseY = 0, scrollY = window.scrollY, targetX = 0, targetY = 0, winW = window.innerWidth;
            document.addEventListener('mousemove', (e) => { mouseX = (e.clientX - winW / 2); mouseY = (e.clientY - window.innerHeight / 2); }, { passive: true });
            window.addEventListener('scroll', () => { scrollY = window.pageYOffset; }, { passive: true });
            const animate = () => { targetX += (mouseX - targetX) * 0.04; targetY += (mouseY - targetY) * 0.04; layers.base.style.transform = `translate3d(${-targetX * 0.02}px, ${-scrollY * 0.02 - targetY * 0.02}px, 0)`; if (layers.mid) layers.mid.style.transform = `translate3d(${-targetX * 0.06}px, ${-scrollY * 0.06 - targetY * 0.06}px, 0)`; if (layers.dust) layers.dust.style.transform = `translate3d(${-targetX * 0.12}px, ${-scrollY * 0.12 - targetY * 0.12}px, 0)`; if (layers.nebula) layers.nebula.style.transform = `translate3d(${-targetX * 0.01}px, ${-targetY * 0.01}px, 0) scale(1.2)`; requestAnimationFrame(animate); };
            animate();
          }
        }

        // Astra: Marcado de 'Visto' Permanente (Anti-molestias)
        const lastSeenId = localStorage.getItem('babylon_last_seen_news_id');
        const updateBadges = (count) => {
          document.querySelectorAll('[data-news-badge]').forEach(b => {
            if (count > 0 && !window.location.pathname.startsWith('/news')) {
              b.textContent = count > 9 ? '+9' : count.toString();
              b.style.display = 'flex';
            } else {
              b.style.display = 'none';
            }
          });
        };

        // Orion: Lógica de Ventanas ART (Argentina UTC-3)
        // Solo mostramos el contador como 'Nuevo' si estamos cerca de una ventana de actualización
        // o si el valor del servidor es significativamente diferente al local.
        updateBadges(serverNewsCount);

        window.addEventListener('news-count-updated', (e) => updateBadges(e.detail.count));
        window.addEventListener('new-news-created', () => refreshNewsCount(true));

        // Astra: Toggle NSFW unificado (JS Nativo)
        const setupNsfwToggle = (id) => {
          const btn = document.getElementById(id);
          if (btn) {
            btn.onclick = async (e) => {
              e.preventDefault();
              btn.classList.add('loading');
              try {
                const res = await fetch('/api/ui/toggle-nsfw', { method: 'POST' });
                const data = await res.json();
                if (data?.success) window.location.reload();
              } catch (err) {
                console.error('Error:', err);
              } finally {
                btn.classList.remove('loading');
              }
            };
          }
        };
        setupNsfwToggle('nsfw-toggle-btn');
        setupNsfwToggle('nsfw-toggle-mobile');

        // 3.5 Ghost Loader (Astra Orion - Ultra Reactive)
        const initGhostLoader = () => {
          const obs = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
              if (entry.isIntersecting) {
                const img = entry.target;
                const ds = img.getAttribute('data-src');
                if (ds) {
                  img.src = ds;
                  img.removeAttribute('data-src');
                  requestAnimationFrame(() => img.classList.remove('lazy-ghost'));
                }
                obs.unobserve(img);
              }
            });
          }, { rootMargin: '0px' });

          const observeExisting = (root = document.body) => {
            if (!root) return;
            root.querySelectorAll('.lazy-ghost').forEach(el => obs.observe(el));
          };

          const mut = new MutationObserver((mutations) => {
            for (const m of mutations) {
              m.addedNodes.forEach(node => {
                if (node instanceof HTMLElement) {
                  if (node.classList.contains('lazy-ghost')) obs.observe(node);
                  node.querySelectorAll('.lazy-ghost').forEach(el => obs.observe(el));
                }
              });
            }
          });
          
          mut.observe(document.body, { childList: true, subtree: true });
          observeExisting();
        };
        initGhostLoader();

        // 4. Swiper Initialization
        const initSwipers = () => {
          const S = window.Swiper;
          if (!S) return;
          
          const hero = document.querySelector('.hero-swiper');
          if (hero && !hero.swiper) {
            const slideCount = hero.querySelectorAll('.swiper-slide').length;
            new S(hero, { 
              slidesPerView: 1, 
              loop: slideCount > 1, 
              effect: 'fade', 
              fadeEffect: { crossFade: true },
              speed: 1000, 
              autoplay: slideCount > 1 ? { delay: 6000, disableOnInteraction: false } : false, 
              pagination: { el: '.premium-pagination', clickable: true }, 
              navigation: { prevEl: '.premium-nav.prev', nextEl: '.premium-nav.next' } 
            });
          }

          const updates = document.querySelector('.recent-updates-swiper');
          if (updates && !updates.swiper) {
            const obs = new IntersectionObserver((es) => { 
              es.forEach(e => { 
                if (e.isIntersecting) { 
                  new S(updates, { slidesPerView: 'auto', spaceBetween: 20, freeMode: true, scrollbar: { el: '.premium-scrollbar', draggable: true }, breakpoints: { 768: { spaceBetween: 30 }, 1024: { spaceBetween: 40 } } }); 
                  obs.disconnect(); 
                } 
              }); 
            }, { rootMargin: '0px' });
            obs.observe(updates);
          }
        };
        
        if ('requestIdleCallback' in window) {
          window.requestIdleCallback(initSwipers);
        } else {
          setTimeout(initSwipers, 100);
        }

        // 5. Adsterra Runner
        const initAds = () => {
          const ads = Array.from(document.querySelectorAll('.ad-container-root'));
          const observer = new IntersectionObserver((entries) => {
            entries.forEach(async (entry) => {
              if (entry.isIntersecting) {
                const el = entry.target;
                if (el.getAttribute('data-loaded')) return;
                el.setAttribute('data-loaded', 'true');
                observer.unobserve(el);

                const type = el.getAttribute('data-ad-type');
                const keys = JSON.parse(el.getAttribute('data-ad-keys') || '{}');
                const dims = JSON.parse(el.getAttribute('data-ad-dims') || '{}');
                const currentWinW = window.innerWidth;
                let currentType = type, currentDim = dims[currentType] || { w: 728, h: 90 };
                if (currentWinW < currentDim.w) { currentType = currentWinW >= 468 && type !== 'square' ? 'bannerSmall' : 'square'; currentDim = dims[currentType] || { w: 300, h: 250 }; }
                const finalKey = keys[currentType] || keys.banner;
                if (finalKey) {
                  const iframe = document.createElement('iframe');
                  iframe.style.width = currentDim.w + 'px'; iframe.style.height = currentDim.h + 'px'; iframe.style.border = 'none'; iframe.style.overflow = 'hidden'; iframe.loading = 'lazy';
                  const slot = document.getElementById(`slot-${el.id}`);
                  if (slot) {
                    slot.innerHTML = ''; slot.appendChild(iframe);
                    iframe.srcdoc = `<body style="margin:0;padding:0;display:flex;justify-content:center;align-items:center;min-height:${currentDim.h}px;background:transparent;"><div id="container-${finalKey}"></div><script type="text/javascript">atOptions = { 'key' : '${finalKey}', 'format' : 'iframe', 'height' : ${currentDim.h}, 'width' : ${currentDim.w}, 'params' : {} };<\/script><script type="text/javascript" src="https://crowdsubsequentadmire.com/${finalKey}/invoke.js"><\/script></body>`;
                  }
                }
              }
            });
          }, { rootMargin: '50px' });
          ads.forEach(ad => observer.observe(ad));
        };

        const runAdblockCheck = () => {
          if (document.body.getAttribute('data-user-state')?.includes('"isAdmin":true')) return;

          // Orion: Chequeo instantáneo por DOM (Cero peticiones de red)
          const bait = document.getElementById('tester-wrap');
          const isBlocked = !bait || bait.offsetParent === null || bait.offsetHeight === 0;
          
          if (isBlocked) {
            if (window.location.pathname.includes('/series/') && window.location.pathname.split('/').length >= 4) {
              const wall = document.getElementById('adblock-wall'); if (wall) { wall.style.display = 'flex'; document.body.style.overflow = 'hidden'; }
            } else {
              const toast = document.getElementById('adblock-toast'); if (toast) toast.style.display = 'flex';
            }
          }
        };

        // Orion: Inicialización inmediata para máxima velocidad
        initAds();
        setTimeout(runAdblockCheck, 1000); // Solo 1s para dar tiempo a que los bloqueadores oculten el bait
      };

      // Astra: Inyección bajo demanda (Event Delegation)
      const handleTrigger = async (e) => {
        if (window._babylonUtilsInjected) return;
        window._babylonUtilsInjected = true;
        window._babylonPendingEvent = { type: e.type, detail: e.detail };
        const [svelte, { default: GlobalUtilities }] = await Promise.all([import('svelte'), import('../components/GlobalUtilities.svelte')]);
        const container = document.getElementById('global-utilities-root');
        if (container && svelte.mount) {
          svelte.mount(GlobalUtilities, { target: container, props: { isVerifyPage: window.location.pathname === '/verify', shouldShowAgeGate: document.documentElement.classList.contains('age-gate-active') } });
        }
      };

      window.addEventListener('open-auth-modal', handleTrigger);
      window.addEventListener('show-toast', handleTrigger);

      if (document.readyState !== 'loading') initAll();
      else document.addEventListener('DOMContentLoaded', initAll);
    </script>
  </body>
</html>
