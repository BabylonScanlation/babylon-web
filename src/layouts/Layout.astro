---
import '../styles/global.css';
import '../styles/components.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AuthModal from '../components/AuthModal.svelte';
import ToastContainer from '../components/ToastContainer.svelte';
import AppBanner from '../components/AppBanner.svelte';
import AdblockWall from '../components/AdblockWall.astro';
import AgeGate from '../components/AgeGate.svelte';
import BottomNav from '../components/BottomNav.astro';
import { siteConfig } from '../site.config';

const { 
  title: pageTitle, 
  description = siteConfig.description,
  ogImage = siteConfig.assets.ogImage,
  canonicalURL = Astro.url.href
} = Astro.props;

const title = pageTitle ? `${pageTitle} | ${siteConfig.shortName}` : siteConfig.name;

const isAdminPage = Astro.url.pathname.startsWith('/admin');
const isVerifyPage = Astro.url.pathname === '/verify';

const isVerified = Astro.cookies.get('site_verified')?.value === 'true';
const isBot = Astro.locals.isBot;
const shouldBlockContent = !isVerified && !isVerifyPage && !isAdminPage && !isBot;

// Orion: URL Base para metadatos absolutos
const siteUrl = siteConfig.url;
const fullOgImage = ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`;
---

<!doctype html>
<html lang="es" class={shouldBlockContent ? 'age-gate-active' : ''}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <link rel="icon" type="image/svg+xml" href={siteConfig.assets.favicon} />
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content={siteConfig.theme.accent} />
    <meta name="google-site-verification" content="p13-r-hLZ82o8n9SUSdk_-bOPDu6aqYAvk8jf8ihFvw" />
    
    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />

    <!-- Googlebot Priority -->
    <meta name="googlebot" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
    <meta name="bingbot" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />

    <!-- Breadcrumbs JSON-LD -->
    <script type="application/ld+json" is:inline set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Inicio",
          "item": siteUrl
        },
        ...Astro.url.pathname.split('/').filter(Boolean).map((part, i, arr) => ({
          "@type": "ListItem",
          "position": i + 2,
          "name": part.charAt(0).toUpperCase() + part.slice(1).replace(/-/g, ' '),
          "item": `${siteUrl}/${arr.slice(0, i + 1).join('/')}`
        }))
      ]
    })} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={fullOgImage} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={Astro.url.href} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={fullOgImage} />

    <slot name="head" />

    <script is:inline>
      // Orion: Silenciador de errores de Privacy Sandbox/Permissions-Policy
      (function() {
        const originalError = console.error;
        console.error = function(...args) {
          if (args[0] && typeof args[0] === 'string' && (
              args[0].includes('browsing-topics') || 
              args[0].includes('run-ad-auction') || 
              args[0].includes('join-ad-interest-group')
          )) return;
          originalError.apply(console, args);
        };
      })();
    </script>
    
    <style is:global set:html={`
      :root {
        --accent-color: ${siteConfig.theme.accent};
        --accent-glow: ${siteConfig.theme.accentGlow};
        --bg-color: ${siteConfig.theme.background};
        --bg-alt: ${siteConfig.theme.backgroundAlt};
      }
    `}>
    </style>
    
    <style is:inline>
      .site-main-content {
        width: 100%;
        display: flex;
        flex-direction: column;
        flex: 1; /* Astra: Ocupa el espacio disponible para empujar el footer */
      }

      body.cosmos-theme {
        display: flex;
        flex-direction: column;
        min-height: 100vh;
        background-color: var(--bg-color);
      }

      .age-gate-active body { visibility: hidden !important; background: #000 !important; overflow: hidden !important; }
      .age-gate-active .age-gate-overlay { visibility: visible !important; }

      /* Astra: Modo Lectura en Móvil - Limpieza de Cosmos */
      @media (max-width: 1023px) {
        .site-main-content {
          padding-bottom: 5rem; /* Astra: Espacio de seguridad para el footer y BottomNav */
        }
        body[data-reader-active="true"] .site-main-content {
          padding-top: 0 !important;
          margin-top: 0 !important;
        }
        body[data-reader-active="true"] .cosmos-bg {
          display: none !important;
        }
        body[data-reader-active="true"] {
          background-color: #000 !important;
        }
      }
    </style>
  </head>
  <body class="cosmos-theme">
    {siteConfig.theme.cosmos.enabled && (
      <div class="cosmos-bg">
        <div class="stars-layer base"></div>
        <div class="stars-layer mid"></div>
        <div class="stars-layer dust"></div>
        <div class="nebula-glow"></div>
        <div class="shooting-stars">
          <span></span><span></span><span></span>
        </div>
      </div>
    )}

    {shouldBlockContent ? (
      <AgeGate client:load isVerificationPage={false} />
    ) : (
      <>
        {!isVerifyPage && <Header />}
        <main class="site-main-content">
          <slot />
        </main>
        <BottomNav />
        {!isVerifyPage && <Footer />}
        <AuthModal client:idle />
        <ToastContainer client:idle />
        <AppBanner client:idle />
        {!isAdminPage && <AdblockWall />}
      </>
    )}
    
    <script is:inline define:vars={{ storagePrefix: siteConfig.storage.prefix }}>
      // Orion: Sistema de Notificaciones de Noticias (Estado Persistente)
      window.checkNewNews = async function(force = false) {
        const pcBadge = document.getElementById('news-badge-pc');
        const mobileBadge = document.getElementById('news-badge-mobile');
        const currentPath = window.location.pathname;
        const isNewsPage = currentPath === '/news' || currentPath === '/news/';

        const updateUI = (count) => {
          [pcBadge, mobileBadge].forEach(el => {
            if (!el) return;
            if (count > 0 && !isNewsPage) {
              el.textContent = count > 9 ? '+9' : count.toString();
              el.classList.remove('hidden');
            } else {
              el.classList.add('hidden');
            }
          });
        };

        // 1. Mostrar estado previo inmediatamente (Evita desaparición al refrescar)
        const cachedCount = parseInt(localStorage.getItem(`${storagePrefix}unread_news_count`) || '0');
        updateUI(cachedCount);

        // 2. Si estamos en noticias, marcar como leído y salir
        if (isNewsPage) {
          localStorage.setItem(`${storagePrefix}unread_news_count`, '0');
          updateUI(0);
          
          try {
            const res = await fetch('/api/news/check');
            const latest = await res.json();
            if (latest && latest.length > 0) {
              localStorage.setItem(`${storagePrefix}last_seen_news_date`, latest[0].createdAt.toString());
            }
          } catch {}
          return;
        }

        // 3. Throttling de 30s para la API
        const lastCheck = localStorage.getItem(`${storagePrefix}last_news_check_ts`);
        const now = Date.now();
        if (!force && lastCheck && (now - parseInt(lastCheck)) < 30000) return;

        // 4. Consultar nuevas noticias
        try {
          const res = await fetch('/api/news/check?t=' + now);
          if (!res.ok) return;
          const latest = await res.json();
          localStorage.setItem(`${storagePrefix}last_news_check_ts`, now.toString());

          if (!latest || latest.length === 0) return;

          const lastSeenDate = parseInt(localStorage.getItem(`${storagePrefix}last_seen_news_date`) || '0');
          const unreadNews = latest.filter(n => parseInt(n.createdAt) > lastSeenDate);
          const count = unreadNews.length;

          localStorage.setItem(`${storagePrefix}unread_news_count`, count.toString());
          updateUI(count);
        } catch (e) {}
      }

      if (!window.hasNewsListener) {
        window.addEventListener('new-news-created', () => {
          setTimeout(() => window.checkNewNews(true), 1000);
        });
        window.hasNewsListener = true;
      }

      document.addEventListener('astro:page-load', () => window.checkNewNews());
      document.addEventListener('astro:after-swap', () => window.checkNewNews());
    </script>
    
    <script>
      // Astra: Motor de Física Estelar (Paralaje 2.0)
      let cleanupCosmos: (() => void) | null = null;

      const initCosmos = () => {
        if (cleanupCosmos) cleanupCosmos();

        const bg = document.querySelector('.cosmos-bg');
        if (!bg) return;

        const layers = {
          base: document.querySelector('.stars-layer.base') as HTMLElement,
          mid: document.querySelector('.stars-layer.mid') as HTMLElement,
          dust: document.querySelector('.stars-layer.dust') as HTMLElement,
          nebula: document.querySelector('.nebula-glow') as HTMLElement
        };

        if (!layers.base) return;

        let mouseX = 0;
        let mouseY = 0;
        let scrollY = window.scrollY;
        let targetX = 0;
        let targetY = 0;
        let animationFrameId: number;
        
        let winW = window.innerWidth;
        let winH = window.innerHeight;

        // Factores de profundidad (Paralaje)
        const D_BASE = 0.02;   // Fondo lejano (casi quieto)
        const D_MID = 0.06;    // Plano medio
        const D_DUST = 0.12;   // Primer plano (más rápido = más cerca)
        const D_NEBULA = 0.01; // Ambiente

        const onMouseMove = (e: MouseEvent) => {
          // Normalizamos el centro de la pantalla usando valores cacheados
          mouseX = (e.clientX - winW / 2);
          mouseY = (e.clientY - winH / 2);
        };

        const onScroll = () => {
          // Orion: Lectura optimizada
          scrollY = window.pageYOffset || document.documentElement.scrollTop;
        };

        const onResize = () => {
          winW = window.innerWidth;
          winH = window.innerHeight;
        };

        document.addEventListener('mousemove', onMouseMove, { passive: true });
        window.addEventListener('scroll', onScroll, { passive: true });
        window.addEventListener('resize', onResize, { passive: true });

        const animate = () => {
          // Suavizado cinemático (Lerp)
          targetX += (mouseX - targetX) * 0.04;
          targetY += (mouseY - targetY) * 0.04;

          // 1. Capa Base (Lejana, borrosa)
          if (layers.base) {
            layers.base.style.transform = `translate3d(${-targetX * D_BASE}px, ${-scrollY * D_BASE - targetY * D_BASE}px, 0)`;
          }

          // 2. Capa Media (Nítida, estrellas principales)
          if (layers.mid) {
            layers.mid.style.transform = `translate3d(${-targetX * D_MID}px, ${-scrollY * D_MID - targetY * D_MID}px, 0)`;
          }

          // 3. Polvo Cósmico (Cerca de la cámara, movimiento notable)
          if (layers.dust) {
            layers.dust.style.transform = `translate3d(${-targetX * D_DUST}px, ${-scrollY * D_DUST - targetY * D_DUST}px, 0)`;
          }

          // 4. Nebulosa (Rotación ambiental)
          // La nebulosa ya rota por CSS, aquí solo añadimos un leve desplazamiento para que no parezca un sticker
          if (layers.nebula) {
             layers.nebula.style.transform = `translate3d(${-targetX * D_NEBULA}px, ${-targetY * D_NEBULA}px, 0) scale(1.2)`;
          }

          animationFrameId = requestAnimationFrame(animate);
        };

        animate();

        cleanupCosmos = () => {
            if (animationFrameId) cancelAnimationFrame(animationFrameId);
            document.removeEventListener('mousemove', onMouseMove);
            window.removeEventListener('scroll', onScroll);
            window.removeEventListener('resize', onResize);
        };
      };

      document.addEventListener('astro:page-load', () => {
        // Astra: Solo inicializar si la física está habilitada en la config
        const physicsEnabled = siteConfig.theme.cosmos.physicsEnabled;
        if (!physicsEnabled) return;

        if ('requestIdleCallback' in window) {
          (window as any).requestIdleCallback(() => initCosmos(), { timeout: 1000 });
        } else {
          setTimeout(initCosmos, 200);
        }
      });
    </script>
  </body>
</html>