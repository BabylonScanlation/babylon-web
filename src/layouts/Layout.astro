---
import '../styles/global.css';
import '../styles/components.css';
import { siteConfig } from '../site.config';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BottomNav from '../components/BottomNav.astro';
import AdblockWall from '../components/AdblockWall.astro';
import GlobalUtilities from '../components/GlobalUtilities.svelte';

const {
  title: pageTitle,
  description = siteConfig.description,
  ogImage = siteConfig.assets.ogImage,
  canonicalURL = Astro.url.href,
  isNsfwContent,
} = Astro.props;

const { user, runtime } = Astro.locals;
const ua = Astro.request.headers.get('user-agent') || '';
const isMobile = /mobile|iphone|ipad|android|blackberry|opera mini|iemobile|wpdesktop/i.test(ua);
const title = pageTitle ? `${pageTitle} | ${siteConfig.shortName}` : siteConfig.name;
const isAdminPage = Astro.url.pathname.startsWith('/admin');
const isVerifyPage = Astro.url.pathname === '/verify';
const isVerified = Astro.cookies.get('site_verified')?.value === 'true';
const isBot = (Astro.locals as any).isBot;
const shouldBlockContent = !isVerified && !isVerifyPage && !isAdminPage && !isBot;
const isNsfw = isNsfwContent !== undefined ? isNsfwContent : Astro.cookies.get('babylon_nsfw')?.value === 'true';
const siteUrl = siteConfig.url;
const fullOgImage = ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`;
const r2PublicUrlAssets = runtime?.env?.R2_PUBLIC_URL_ASSETS || '/api/assets/proxy';
const currentYear = new Date().getFullYear();
---

<!doctype html>
<html lang="es" class:list={[ { 'age-gate-active': shouldBlockContent, 'nsfw-mode': isNsfw } ]}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <link rel="icon" type="image/svg+xml" href={siteConfig.assets.favicon} />
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content={siteConfig.theme.accent} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={fullOgImage} />
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
    <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js" defer></script>
    <style is:global set:html={`:root{--accent-color:${siteConfig.theme.accent};--accent-glow:${siteConfig.theme.accentGlow};--bg-color:${siteConfig.theme.background};--bg-alt:${siteConfig.theme.backgroundAlt};}html.nsfw-mode{--accent-color:#900000!important;--accent-glow:rgba(144,0,0,0.6)!important;}`}></style>
  </head>
  <body class="cosmos-theme" data-user-id={user?.uid || 'guest'} data-cosmos-physics={siteConfig.theme.cosmos.physicsEnabled ? 'true' : 'false'}>
    {siteConfig.theme.cosmos.enabled && (<div class="cosmos-bg"><div class="stars-layer base"></div><div class="stars-layer mid"></div><div class="stars-layer dust"></div><div class="nebula-glow"></div></div>)}

    {shouldBlockContent ? (<div class="content-blocked-placeholder"></div>) : (
      <>
        {!isVerifyPage && (
          <Header />
        )}
        <main class="site-main-content"><slot /></main>
        {!isVerifyPage && isMobile && (
          <BottomNav />
        )}
        {!isVerifyPage && (
          <Footer />
        )}
      </>
    )}

    <GlobalUtilities client:visible isVerifyPage={isVerifyPage} shouldShowAgeGate={shouldBlockContent} />        
    {!isAdminPage && (
      <AdblockWall />
    )}
    
    <script>
      const initAll = async () => {
        const htmlHasMode = document.documentElement.classList.contains('nsfw-mode');
        const isNsfwCookie = document.cookie.split(';').some(c => c.trim().startsWith('babylon_nsfw=true'));
        if (isNsfwCookie || htmlHasMode) {
          const header = document.getElementById('main-header');
          if (header) header.classList.add('nsfw-active');
        }
        const physicsEnabled = document.body.getAttribute('data-cosmos-physics') === 'true';
        if (physicsEnabled) {
          const layers = { base: document.querySelector('.stars-layer.base') as HTMLElement, mid: document.querySelector('.stars-layer.mid') as HTMLElement, dust: document.querySelector('.stars-layer.dust') as HTMLElement, nebula: document.querySelector('.nebula-glow') as HTMLElement };
          if (layers.base) {
            let mouseX = 0, mouseY = 0, scrollY = window.scrollY, targetX = 0, targetY = 0, winW = window.innerWidth;
            document.addEventListener('mousemove', (e) => { mouseX = (e.clientX - winW / 2); mouseY = (e.clientY - window.innerHeight / 2); }, { passive: true });
            window.addEventListener('scroll', () => { scrollY = window.pageYOffset; }, { passive: true });
            const animate = () => { targetX += (mouseX - targetX) * 0.04; targetY += (mouseY - targetY) * 0.04; layers.base.style.transform = `translate3d(${-targetX * 0.02}px, ${-scrollY * 0.02 - targetY * 0.02}px, 0)`; if (layers.mid) layers.mid.style.transform = `translate3d(${-targetX * 0.06}px, ${-scrollY * 0.06 - targetY * 0.06}px, 0)`; if (layers.dust) layers.dust.style.transform = `translate3d(${-targetX * 0.12}px, ${-scrollY * 0.12 - targetY * 0.12}px, 0)`; if (layers.nebula) layers.nebula.style.transform = `translate3d(${-targetX * 0.01}px, ${-targetY * 0.01}px, 0) scale(1.2)`; requestAnimationFrame(animate); };
            animate();
          }
        }
        const logo = document.getElementById('header-logo-toggle');
        if (logo) logo.onclick = async (e) => { e.preventDefault(); const { actions } = await import('astro:actions'); const { data } = await actions.ui.toggleNsfw(); if (data?.success) window.location.assign('/'); };
        const updateBadges = (count: number) => { document.querySelectorAll('[data-news-badge]').forEach(b => { if (count > 0) { b.textContent = count > 9 ? '+9' : count.toString(); b.classList.remove('hidden'); (b as HTMLElement).style.display = 'flex'; } else { b.classList.add('hidden'); (b as HTMLElement).style.display = 'none'; } }); };
        updateBadges(parseInt(localStorage.getItem('babylon_news_count') || '0', 10));
        window.addEventListener('news-count-updated', (e: any) => updateBadges(e.detail.count));
        const initSwipers = () => { // @ts-ignore
          const S = window.Swiper; if (!S) return;
          const hero = document.querySelector('.hero-swiper'); if (hero && !(hero as any).swiper) new S(hero, { slidesPerView: 1, loop: true, effect: 'fade', speed: 800, autoplay: { delay: 6000 }, pagination: { el: '.premium-pagination', clickable: true }, navigation: { prevEl: '.premium-nav.prev', nextEl: '.premium-nav.next' } });
          const updates = document.querySelector('.recent-updates-swiper'); if (updates && !(updates as any).swiper) { const obs = new IntersectionObserver((es) => { es.forEach(e => { if (e.isIntersecting) { new S(updates, { slidesPerView: 'auto', spaceBetween: 15, freeMode: true, scrollbar: { el: '.premium-scrollbar', draggable: true } }); obs.disconnect(); } }); }, { rootMargin: '100px' }); obs.observe(updates); }
        };
        initSwipers();
        const initAds = () => {
          const ads = Array.from(document.querySelectorAll('.ad-container-root')); if (ads.length === 0) return;
          const obs = new IntersectionObserver((entries) => { entries.forEach(entry => { if (entry.isIntersecting) { const el = entry.target as HTMLElement; if (el.getAttribute('data-loaded')) return; el.setAttribute('data-loaded', 'true'); const keys = JSON.parse(el.getAttribute('data-ad-keys') || '{}'); const dims = JSON.parse(el.getAttribute('data-ad-dims') || '{}'); const type = el.getAttribute('data-ad-type'); let currentType = type, currentDim = dims[currentType!] || { w: 728, h: 90 }; if (window.innerWidth < currentDim.w) { currentType = window.innerWidth >= 468 && type !== 'square' ? 'bannerSmall' : 'square'; currentDim = dims[currentType!] || { w: 300, h: 250 }; } const finalKey = keys[currentType!] || keys.banner; if (finalKey) { // @ts-ignore
            window.atOptions = { 'key': finalKey, 'format': 'iframe', 'height': currentDim.h, 'width': currentDim.w, 'params': {} }; const s = document.createElement('script'); s.type = 'text/javascript'; s.src = `https://crowdsubsequentadmire.com/${finalKey}/invoke.js`; document.getElementById(`slot-${el.id}`)!.appendChild(s); } obs.unobserve(el); } }); }, { rootMargin: '100px' }); ads.forEach(ad => obs.observe(ad));
        };
        setTimeout(initAds, 1000);
        setTimeout(async () => { const check = async () => { const network = await fetch('https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js', { method: 'HEAD', mode: 'no-cors' }).catch(() => null); if (network === null) return true; const bait = document.getElementById('tester-wrap'); if (bait && (bait.offsetParent === null || bait.offsetHeight === 0)) return true; return false; }; if (await check()) { if (window.location.pathname.includes('/series/')) { const wall = document.getElementById('adblock-wall'); if (wall) { wall.style.display = 'flex'; document.body.style.overflow = 'hidden'; } } else { const toast = document.getElementById('adblock-toast'); if (toast) toast.style.display = 'flex'; } } }, 2000);
      };
      document.addEventListener('astro:page-load', initAll);
      if (document.readyState !== 'loading') initAll();
    </script>
  </body>
</html>
