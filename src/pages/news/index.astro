---
import { eq } from 'drizzle-orm';
import { users } from '../../db/schema';
import Layout from '../../layouts/Layout.astro';
import { getAllNews, type NewsWithDetails } from '../../lib/data/news';
import { getDB } from '../../lib/db';
import { siteConfig } from '../../site.config';

const drizzleDb = getDB(Astro.locals.runtime.env);
const { user, runtime } = Astro.locals;

const newsItems = (await getAllNews(drizzleDb, 'published', undefined, runtime.env)) || [];

// Orion: Limpiador de Markdown para extractos
function stripMarkdown(text: string) {
  return text
    .replace(/[#*`~_]/g, '') // Quitar símbolos básicos
    .replace(/\[(.*?)\]\(.*?\)/g, '$1') // Quitar links dejando el texto
    .replace(/!\[.*?\]\(.*?\)/g, '') // Eliminar imágenes por completo del extracto
    .replace(/>/g, '') // Quitar citas
    .trim();
}

// Orion: Marcar como leído (Standard Unificado + DB Sync)
if (newsItems.length > 0 && newsItems[0]) {
  const latestId = newsItems[0].id.toString();

  // 1. Sincronizar Cookie (para invitados y respuesta inmediata)
  Astro.cookies.set('last_news_id', latestId, {
    path: '/',
    expires: new Date(Date.now() + 365 * 24 * 60 * 60 * 1000),
    sameSite: 'lax',
    httpOnly: false,
    secure: Astro.url.protocol === 'https:',
  });

  // 2. Sincronizar Base de Datos (para usuarios registrados)
  if (user?.uid) {
    try {
      const dbUser = await drizzleDb.select().from(users).where(eq(users.id, user.uid)).get();
      const currentPrefs =
        typeof dbUser?.preferences === 'string'
          ? JSON.parse(dbUser.preferences)
          : dbUser?.preferences || {};

      // Solo actualizar si el lastSeenNewsId cambió realmente
      if (currentPrefs?.lastSeenNewsId !== latestId) {
        const newPrefs = JSON.stringify({ ...currentPrefs, lastSeenNewsId: latestId });

        await drizzleDb
          .update(users)
          .set({ preferences: newPrefs })
          .where(eq(users.id, user.uid))
          .execute();
      }
    } catch (e) {
      console.error('[NewsDBUpdate] Error:', e);
    }
  }
}
---

<Layout title={`Noticias - ${siteConfig.shortName}`}>
  <script is:inline>
    // LIMPIEZA ATÓMICA DE NOTICIAS
    function clearNewsStatus() {
      // 1. Unificar Cookie de "Último Visto"
      const latestNewsId = document.querySelector('.news-card-wrapper a')?.getAttribute('href')?.split('/').pop();
      if (latestNewsId) {
        document.cookie = "last_news_id=" + latestNewsId + "; path=/; max-age=" + (365*24*60*60) + "; SameSite=Lax";
      }

      // 2. Limpiar rastros antiguos
      const badKeys = [
        'babylon_unread_news_count', 'babylon_news_count', 
        'babylon_last_seen_news_id', 'last_news_id_v2'
      ];
      badKeys.forEach(k => {
        localStorage.removeItem(k);
        document.cookie = k + "=; expires=Thu, 01 Jan 1970 00:00:00 UTC; path=/;";
      });

      // 3. Forzar contador a 0 localmente
      localStorage.setItem('babylon_news_count', '0');
      
      // 4. Notificar a la UI
      window.dispatchEvent(new CustomEvent('news-count-updated', { detail: { count: 0 } }));
      
      // 5. Bloquear actualizaciones del Store por un breve momento para evitar race conditions
      window.news_lock = Date.now() + 3000; 
    }

    clearNewsStatus();
    // Ejecutar también en cargas de Astro (View Transitions)
    document.addEventListener('astro:page-load', clearNewsStatus);
  </script>
  <main class="news-index-container">
    <div class="news-header-section">
      <h1 class="news-page-title">Últimas Noticias</h1>
      <p class="news-page-subtitle">Entérate de las últimas novedades de tus series favoritas.</p>
    </div>

    <div class="news-grid">
      {
        newsItems.length === 0 ? (
          <div class="empty-news">
            <div class="illustration-empty">📰</div>
            <h3>Sin noticias</h3>
            <p>No hay noticias publicadas aún en este momento.</p>
          </div>
        ) : (
          newsItems.map((news: NewsWithDetails) => (
            <div class="news-card-wrapper">
              <a
                href={`/news/${news.id}`}
                class="news-card-inner"
              >
                {(news.imageUrls && news.imageUrls.length > 0 || news.seriesCover) && (
                  <div class="news-card-image">
                    {news.imageUrls && news.imageUrls.length > 0 ? (
                      <img
                        src={news.imageUrls[0]}
                        alt={news.title}
                        loading="lazy"
                      />
                    ) : (
                      <img
                        src={news.seriesCover}
                        alt={news.title}
                        loading="lazy"
                      />
                    )}
                  </div>
                )}
                <div class="news-card-content">
                  {news.seriesTitle && (
                    <span class="series-label">{news.seriesTitle}</span>
                  )}
                  <h2 class="news-card-title">{news.title}</h2>
                  <p class="news-card-excerpt">{stripMarkdown(news.content)}</p>
                  <div class="news-card-footer">
                    <div class="date-block">
                      <span class="date-day">
                        {new Date(news.createdAt).toLocaleDateString('es-ES', { day: 'numeric', month: 'long', year: 'numeric' })}
                      </span>
                    </div>
                    <span class="news-read-more">Leer más</span>
                  </div>
                </div>
              </a>
            </div>
          ))
        )
      }
    </div>
  </main>
</Layout>

<style>
  .news-index-container {
    width: 100%;
    margin: 0;
    padding: 0;
    overflow-x: hidden;
  }

  .news-header-section {
    text-align: center;
    padding: 2rem 0; /* Estándar ASTRA */
    margin: 0;
    width: 100%;
  }

  .news-page-title {
    font-size: 3.5rem; /* Estándar ASTRA */
    font-weight: 800;
    margin: 0;
    padding: 0;
    background: linear-gradient(90deg, #fff, var(--accent-color, #00bfff));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .news-page-subtitle {
    color: #aaa;
    font-size: 1.2rem;
    margin-bottom: 2rem;
  }

  .news-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 2.5rem;
    padding: 0 1.5rem 4rem;
    width: 100%;
    max-width: 1400px;
    margin: 0 auto;
    justify-content: center; /* Astra: Centrado del grid */
  }

  /* NUEVO: Wrapper Estático */
  .news-card-wrapper {
    position: relative;
    z-index: 1;
    height: 100%;
    width: 100%;
    max-width: 420px;
    margin: 0 auto; /* Astra: Forzar centrado individual */
  }

  @media (max-width: 768px) {
    .news-grid {
      grid-template-columns: 1fr; /* Una sola columna limpia */
      padding: 0 1rem 3rem;
      gap: 2rem;
      justify-items: center; /* Astra: Centrado de columna única */
    }
    .news-card-wrapper {
      max-width: 100%; /* Ocupar el ancho disponible centrado */
    }
  }

  /* Modificado: Elemento Interno Visual */
  .news-card-inner {
    background-color: rgba(20, 20, 25, 0.6);
    border-radius: 20px; /* Bordes suaves */
    overflow: hidden;
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    border: 1px solid rgba(255, 255, 255, 0.05);
    display: flex;
    flex-direction: row; /* Astra: Diseño horizontal */
    height: 100%;
    text-decoration: none !important;
    color: inherit;
    position: relative;
    will-change: transform;
  }

  /* Trigger en Wrapper -> Efecto en Inner */
  .news-card-wrapper:hover .news-card-inner {
    transform: translateY(-8px);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
    border-color: rgba(255, 255, 255, 0.1);
    background-color: rgba(25, 25, 30, 0.8);
    z-index: 2;
  }

  .news-card-image {
    width: 140px; /* Astra: Aumentado para mayor impacto visual */
    height: auto;
    min-height: 140px;
    flex-shrink: 0;
    overflow: hidden;
    position: relative;
    background: #111;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Overlay gradiente en imagen para profundidad */
  .news-card-image::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(to right, transparent 0%, rgba(0,0,0,0.4) 100%);
    pointer-events: none;
    z-index: 2;
  }

  .series-label {
    display: inline-block;
    color: var(--accent-color, #00bfff);
    font-size: 0.65rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.25rem;
    opacity: 0.8;
  }

  .news-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover; /* Astra: Llenado total sin espacios vacíos */
    transition: transform 0.6s cubic-bezier(0.165, 0.84, 0.44, 1);
    z-index: 1;
  }

  .news-card-content {
    padding: 1rem 1.25rem;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
    min-width: 0; /* Evitar desbordamiento de texto */
  }

  .news-card-title {
    font-size: 1.2rem;
    font-weight: 800;
    color: #fff;
    margin-bottom: 0.5rem;
    line-height: 1.3;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    transition: color 0.3s;
  }
  
  .news-card-wrapper:hover .news-card-title {
    color: var(--accent-color, #00bfff);
  }

  .news-card-excerpt {
    color: #888;
    font-size: 0.9rem;
    line-height: 1.5;
    margin-bottom: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2; /* Astra: Más compacto */
    -webkit-box-orient: vertical;
    overflow: hidden;
    flex-grow: 1;
  }

  .news-card-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-top: 1px solid rgba(255,255,255,0.05);
    padding-top: 0.8rem;
    margin-top: 0.8rem;
    gap: 1rem;
  }

  .date-block {
    display: flex;
    flex-direction: row !important; /* Astra: En fila para ahorrar espacio */
    gap: 0.5rem;
    align-items: center;
  }

  .date-day {
    color: #666;
    font-weight: 600;
    font-size: 0.75rem;
  }

  .news-read-more {
    color: var(--accent-color, #00bfff);
    font-weight: 800;
    text-transform: uppercase;
    font-size: 0.65rem;
    letter-spacing: 0.05em;
    transition: all 0.3s;
  }
  
  .news-card-wrapper:hover .news-read-more {
    color: #fff;
  }

  @media (max-width: 480px) {
    .news-card-inner {
      flex-direction: column;
    }
    .news-card-image {
      width: 100%;
      height: 160px;
    }
    .news-card-image img {
      max-width: 140px;
      max-height: 140px;
    }
  }

  .empty-news {
    grid-column: 1 / -1;
    text-align: center;
    padding: 5rem 2rem;
    background: rgba(255, 255, 255, 0.02);
    border-radius: 32px;
    border: 1px dashed rgba(255, 255, 255, 0.08);
  }

  .illustration-empty { 
    font-size: 4rem; 
    margin-bottom: 1.5rem; 
    filter: grayscale(1) opacity(0.3); 
  }

  .empty-news h3 {
    font-size: 1.5rem;
    font-weight: 800;
    color: #fff;
    margin-bottom: 0.5rem;
  }

  .empty-news p {
    color: #666;
    font-size: 1rem;
    font-weight: 600;
  }

  @media (max-width: 640px) {
    .news-page-title {
      font-size: 2.2rem;
    }
    .news-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
