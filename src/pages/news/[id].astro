---
import snarkdown from 'snarkdown';
import UnifiedComments from '../../components/UnifiedComments.astro';
import Layout from '../../layouts/Layout.astro';
import { getCommentsForTarget } from '../../lib/data/comments';
import { getNewsDetail } from '../../lib/data/news';
import { getDB } from '../../lib/db';
import { siteConfig } from '../../site.config';
import type { Comment } from '../../types';

const { id } = Astro.params;
if (!id) return Astro.redirect('/404');

const user = Astro.locals.user;
const drizzleDb = getDB(Astro.locals.runtime.env);

const newsItem = await getNewsDetail(drizzleDb, id);

if (!newsItem) {
  return Astro.redirect('/news');
}

// Orion: Procesar Markdown
const renderedContent = snarkdown(newsItem.content);

// Cargar comentarios iniciales
const initialComments = (await getCommentsForTarget(drizzleDb, 'news', id, user?.uid)) as Comment[];
---

<Layout title={`${newsItem.title} - Noticias - ${siteConfig.shortName}`}>
  <main class="news-detail-container">
    <!-- Navegación Superior -->
    <nav class="news-top-nav">
      <a href="/news" class="back-link-minimal">
        <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2.5" fill="none"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
        <span>Noticias</span>
      </a>
    </nav>

    <!-- Artículo Principal -->
    <article class="news-article">
      <div class="news-header">
        <h1 class="news-title">{newsItem.title}</h1>
        <div class="news-meta">
          <span class="news-author">Por <span class="highlight">{newsItem.authorName || `Redacción ${siteConfig.shortName}`}</span></span>
          <span class="separator">•</span>
          <span class="news-date">{new Date(newsItem.createdAt).toLocaleDateString('es-ES', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' })}</span>
        </div>
      </div>

      {newsItem.imageUrls && newsItem.imageUrls.length > 0 && (
        <div class="news-image-container">
          <img 
            src={newsItem.imageUrls[0]} 
            alt={newsItem.title} 
            class="news-featured-image"
          />
        </div>
      )}

      <div class="news-content-wrapper">
        <div class="news-content prose" set:html={renderedContent}></div>
      </div>

      {newsItem.seriesSlug && (
        <div class="news-footer-nav">
          <a href={`/series/${newsItem.seriesSlug}`} class="nav-btn-modern accent">
            Ir a la Serie
            <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2.5" fill="none"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
      )}
    </article>

    <!-- Zona de Comentarios Separada -->
    <section class="discussion-zone">
      <div class="comments-container-glass">
        <UnifiedComments 
          targetType="news" 
          targetId={id!} 
          comments={initialComments} 
          user={user ?? null} 
        />
      </div>
    </section>
  </main>
</Layout>

<style>
  /* --- NAVEGACIÓN --- */
  .news-top-nav {
    margin-bottom: 2.5rem;
    display: flex;
    justify-content: flex-start;
    padding-left: 8rem; /* Astra: Desplazamiento profundo a la derecha */
  }

  @media (max-width: 1400px) {
    .news-top-nav { padding-left: 4rem; }
  }

  @media (max-width: 1200px) {
    .news-top-nav { padding-left: 2rem; }
  }

  @media (max-width: 768px) {
    .news-top-nav { padding-left: 1.5rem; }
  }

  .back-link-minimal {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    color: #aaa;
    text-decoration: none;
    font-size: 0.85rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
    padding: 0.7rem 1.2rem;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 100px;
    backdrop-filter: blur(10px);
  }

  .back-link-minimal svg {
    transition: transform 0.3s ease;
    color: var(--accent-color);
  }

  .back-link-minimal:hover {
    color: #fff;
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(255, 255, 255, 0.2);
    transform: translateX(5px);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
  }

  .back-link-minimal:hover svg {
    transform: translateX(-3px);
  }

  .news-footer-nav {
    display: flex;
    justify-content: center;
    padding-top: 3rem;
    border-top: 1px solid rgba(255,255,255,0.05);
    margin-top: 4rem;
  }

  /* --- ARTÍCULO --- */
  .news-article {
    /* Eliminamos el fondo "card" para que se sienta más editorial, o lo hacemos muy sutil */
    background: transparent; 
  }

  .news-header {
    margin-bottom: 2.5rem;
    text-align: center; /* Título centrado estilo revista */
  }

  .news-title {
    font-size: 3rem;
    font-weight: 900;
    color: #fff;
    margin-bottom: 1rem;
    line-height: 1.1;
    letter-spacing: -0.02em;
    background: linear-gradient(180deg, #fff 0%, #ccc 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .news-meta {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 1rem;
    color: #888;
    font-size: 1rem;
    font-weight: 500;
  }
  .news-meta .highlight { color: var(--accent-color); font-weight: 700; }
  .news-meta .separator { color: #444; }

  .news-image-container {
    margin-bottom: 3rem;
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 20px 40px rgba(0,0,0,0.3);
    border: 1px solid rgba(255,255,255,0.05);
  }

  .news-featured-image {
    width: auto;
    max-width: 100%;
    height: auto;
    max-height: 500px; /* Astra: Tamaño aumentado */
    object-fit: contain; /* Astra: Imagen completa sin recortes */
    display: block;
    margin: 0 auto;
  }

  .news-content {
    font-size: 1.25rem; /* Texto más grande para lectura cómoda */
    line-height: 1.8;
    color: #d0d0d0;
    margin-bottom: 4rem;
    max-width: 75ch; /* Ancho óptimo de lectura */
    margin-left: auto;
    margin-right: auto;
  }

  /* Astra: Estilos para Markdown (Prose) */
  :global(.prose img) {
    max-width: 100%;
    height: auto;
    max-height: 700px; /* Astra: Tamaño duplicado para impacto visual */
    border-radius: 16px;
    display: block;
    margin: 2.5rem auto;
    box-shadow: 0 15px 40px rgba(0,0,0,0.5);
    border: 1px solid rgba(255,255,255,0.08);
    object-fit: contain;
  }

  :global(.prose strong) { color: #fff; font-weight: 800; }
  :global(.prose ul, .prose ol) { margin: 1.5rem 0; padding-left: 1.5rem; color: #bbb; }
  :global(.prose li) { margin-bottom: 0.5rem; }
  :global(.prose h2, .prose h3) { color: #fff; margin-top: 2.5rem; margin-bottom: 1rem; }

  :global(.prose a) {
    color: var(--accent-color);
    text-decoration: none;
    font-weight: 700;
    transition: all 0.2s ease;
    border-bottom: 1px solid rgba(0, 191, 255, 0.2);
  }

  :global(.prose a:hover) {
    color: #fff;
    border-bottom-color: #fff;
    text-shadow: 0 0 10px rgba(0, 191, 255, 0.5);
  }

  .news-content p { margin-bottom: 1.8rem; }

  .news-navigation {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 2rem;
    border-top: 1px solid rgba(255,255,255,0.1);
    flex-wrap: wrap;
    gap: 1.5rem;
  }

  /* --- ZONA DE COMENTARIOS --- */
  .discussion-zone {
    max-width: 800px; /* Ligeramente más estrecho que el contenedor principal */
    width: 100%;
    margin: 0 auto;
  }

  .comments-container-glass {
    background: rgba(255, 255, 255, 0.02);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 32px;
    padding: 2.5rem;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.3);
  }

  /* Botones (reutilizados pero ajustados) */
  .nav-btn-modern {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.8rem 1.5rem;
    background: transparent;
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 100px; /* Pill shape */
    color: #eee;
    text-decoration: none;
    font-weight: 600;
    transition: all 0.3s ease;
  }

  .nav-btn-modern:hover {
    border-color: #fff;
    background: rgba(255, 255, 255, 0.05);
    transform: translateX(-4px);
  }

  .nav-btn-modern.accent {
    border-color: var(--accent-color);
    color: var(--accent-color);
  }

  .nav-btn-modern.accent:hover {
    background: rgba(0, 191, 255, 0.1);
    box-shadow: 0 0 20px rgba(0, 191, 255, 0.2);
    transform: translateX(4px);
  }

  @media (max-width: 768px) {
    .news-title { font-size: 2.2rem; }
    .news-detail-container { padding: 1.5rem 1rem; gap: 3rem; }
    .news-content { font-size: 1.1rem; }
    .comments-container-glass {
      padding: 1.5rem 1rem;
      border-radius: 24px;
    }
  }
</style>
