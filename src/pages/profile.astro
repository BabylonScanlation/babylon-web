---
import { eq } from 'drizzle-orm';
import { userRoles, users } from '../db/schema';
import { getDB } from '../lib/db';
import { getSession } from '../lib/session';
import Layout from '../layouts/Layout.astro';
import ProfileMediaHandler from '../components/ProfileMediaHandler.svelte';
import AdminAccess from '../components/AdminAccess.svelte';
import { siteConfig } from '../site.config';

// 1. Auth Check
const sessionCookie = getSession(Astro);
if (!sessionCookie) {
  return Astro.redirect('/');
}

// 2. Data Fetching
const db = getDB(Astro.locals.runtime.env);
const { user } = Astro.locals;

if (!user) return Astro.redirect('/');

// Fetch full user profile
const userProfile = await db.select().from(users).where(eq(users.id, user.uid)).get();
const userRoleData = await db.select().from(userRoles).where(eq(userRoles.userId, user.uid)).get();

// Fallbacks
const avatar =
  userProfile?.avatarUrl || `https://ui-avatars.com/api/?name=${user.email}&background=random`;
const bannerUrl = userProfile?.bannerUrl || null;
const username = userProfile?.username || user.email?.split('@')[0] || 'Usuario';
const bio = userProfile?.bio || 'Sin biografía aún.';
const roleDisplay = userRoleData?.role === 'admin' ? 'Administrador' : 'Explorador';
const isPrivate = userProfile?.isPrivate || false;

// Format Date
const joinedDate = userProfile?.createdAt
  ? new Date(userProfile.createdAt).toLocaleDateString('es-ES', {
      month: 'long',
      year: 'numeric',
    })
  : 'Recientemente';
---

<Layout title={`Perfil de ${username} - ${siteConfig.shortName}`}>
  <div class="profile-page-wrapper">
    <ProfileMediaHandler client:idle />

    <!-- HEADER & HERO -->
    <header class="profile-hero">
      <div
        class:list={['hero-banner', { 'premium-gradient': !bannerUrl }]}
        id="banner-preview"
        style={bannerUrl ? `background-image: url('${bannerUrl}')` : ''}
      >
        {!bannerUrl && <div class="banner-pattern" />}
        <div class="hero-overlay"></div>
        
        <!-- Astra: Botón de cambio de portada -->
        <button class="change-banner-btn" onclick="window.openProfileMediaModal('banner')">
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
          <span>Cambiar Portada</span>
        </button>
      </div>

      <div class="hero-content">
        <div class="profile-header-grid">
          <div class="avatar-section">
            <div class="avatar-container">
              <div class="avatar-glow"></div>
              <img
                src={avatar}
                alt={username}
                class="main-avatar"
                id="avatar-preview"
              />
              <!-- Astra: Overlay para cambiar avatar -->
              <button class="avatar-edit-overlay" onclick="window.openProfileMediaModal('avatar')">
                <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
              </button>
            </div>
          </div>

          <div class="identity-section">
            <div class="identity-top">
              <h1 class="username">{username}</h1>
              <span
                class:list={[
                  'role-badge',
                  userRoleData?.role === 'admin'
                    ? 'role-admin'
                    : 'role-explorer',
                ]}>{roleDisplay}</span
              >
            </div>
            <div class="identity-meta">
              <span class="meta-item">
                <svg
                  viewBox="0 0 24 24"
                  width="16"
                  height="16"
                  stroke="currentColor"
                  fill="none"
                  ><rect x="3" y="4" width="18" height="18" rx="2" ry="2"
                  ></rect><line x1="16" y1="2" x2="16" y2="6"></line><line
                    x1="8"
                    y1="2"
                    x2="8"
                    y2="6"></line><line x1="3" y1="10" x2="21" y2="10"
                  ></line></svg
                >
                Miembro desde {joinedDate}
              </span>
              <span class="meta-dot">•</span>
              <span class="meta-item email-display">{user.email}</span>
            </div>
          </div>
        </div>
      </div>
    </header>

    <!-- MAIN GRID -->
    <div class="profile-layout">
      <!-- SIDEBAR NAV -->
      <aside class="profile-sidebar">
        {
          userRoleData?.role === 'admin' && (
            <div class="admin-wrapper">
              <AdminAccess client:load />
            </div>
          )
        }

        <nav class="glass-nav">
          <div class="nav-header mobile-hidden">
            <h3>Ajustes</h3>
          </div>
          <button class="nav-item active" data-target="general">
            <div class="icon-box">
              <svg
                viewBox="0 0 24 24"
                width="20"
                height="20"
                stroke="currentColor"
                stroke-width="2"
                fill="none"
                ><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"
                ></path><circle cx="12" cy="7" r="4"></circle></svg
              >
            </div>
            <div class="nav-label">
              <span>Mi Perfil</span>
              <small>Datos personales</small>
            </div>
          </button>

          <button class="nav-item" data-target="security">
            <div class="icon-box">
              <svg
                viewBox="0 0 24 24"
                width="20"
                height="20"
                stroke="currentColor"
                stroke-width="2"
                fill="none"
                ><rect x="3" y="11" width="18" height="11" rx="2" ry="2"
                ></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg
              >
            </div>
            <div class="nav-label">
              <span>Seguridad</span>
              <small>Contraseña y privacidad</small>
            </div>
          </button>

          <button class="nav-item" data-target="comments">
            <div class="icon-box">
              <svg
                viewBox="0 0 24 24"
                width="20"
                height="20"
                stroke="currentColor"
                stroke-width="2"
                fill="none"
                ><path
                  d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"
                ></path></svg
              >
            </div>
            <div class="nav-label">
              <span>Comentarios</span>
              <small>Historial de actividad</small>
            </div>
          </button>

          <div class="nav-divider"></div>

          <button id="logout-trigger" class="nav-item logout-btn">
            <div class="icon-box danger">
              <svg
                viewBox="0 0 24 24"
                width="20"
                height="20"
                stroke="currentColor"
                stroke-width="2"
                fill="none"
                ><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"
                ></path><polyline points="16 17 21 12 16 7"></polyline><line
                  x1="21"
                  y1="12"
                  x2="9"
                  y2="12"></line></svg
              >
            </div>
            <div class="nav-label">
              <span>Cerrar Sesión</span>
            </div>
          </button>
        </nav>
      </aside>

      <!-- CONTENT PANELS -->
      <main class="profile-content">
        <!-- GENERAL TAB -->
        <section id="general" class="content-panel active">
          <div class="panel-header">
            <h2>Editar Perfil</h2>
            <p>Personaliza tu identidad en la comunidad {siteConfig.shortName}.</p>
          </div>

          <div class="glass-card">
            <form id="profile-form">
              <div class="form-grid">
                <div class="input-group">
                  <label for="username">Nombre de Usuario</label>
                  <input
                    type="text"
                    id="username"
                    name="username"
                    value={username}
                    class="modern-input"
                    placeholder="Ej: NeoAnderson"
                  />
                </div>
                <div class="input-group">
                  <label for="website">Sitio Web</label>
                  <input
                    type="url"
                    id="website"
                    name="website"
                    value={userProfile?.website || ''}
                    class="modern-input"
                    placeholder="https://..."
                  />
                </div>
              </div>

              <div class="input-group">
                <label for="bio">Biografía</label>
                <textarea
                  id="bio"
                  name="bio"
                  rows="4"
                  maxlength="160"
                  class="modern-input"
                  placeholder="Cuéntanos algo sobre ti...">{bio}</textarea
                >
                <div class="char-count">Máx. 160 caracteres</div>
              </div>

              <div class="form-actions">
                <button type="submit" class="btn-primary-save">
                  <span class="btn-text">Guardar Cambios</span>
                  <div class="btn-glow"></div>
                </button>
              </div>
            </form>
          </div>
        </section>

        <!-- SECURITY TAB -->
        <section id="security" class="content-panel">
          <div class="panel-header">
            <h2>Centro de Seguridad</h2>
            <p>Protege tu cuenta y gestiona tu privacidad.</p>
          </div>

          <div class="security-grid">
            <!-- Credenciales -->
            <div class="glass-card compact">
              <div class="card-header">
                <div class="header-icon">
                  <svg
                    viewBox="0 0 24 24"
                    width="24"
                    height="24"
                    stroke="currentColor"
                    stroke-width="2"
                    fill="none"
                    ><path
                      d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
                    ></path><polyline points="22,6 12,13 2,6"></polyline></svg
                  >
                </div>
                <h3>Credenciales</h3>
              </div>

              <div class="card-body">
                <div class="read-only-field">
                  <label>Email Vinculado</label>
                  <div class="field-value">
                    <span>{user.email}</span>
                    <svg
                      viewBox="0 0 24 24"
                      width="14"
                      height="14"
                      stroke="currentColor"
                      fill="none"
                      ><rect x="3" y="11" width="18" height="11" rx="2" ry="2"
                      ></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg
                    >
                  </div>
                </div>

                <div id="password-reset-container">
                  <button class="btn-outlined" id="reset-password-btn">
                    Enviar Link de Recuperación
                  </button>
                </div>

                <div
                  id="google-managed-info"
                  class="managed-badge"
                  style="display: none;"
                >
                  <svg
                    viewBox="0 0 24 24"
                    width="18"
                    height="18"
                    fill="currentColor"
                    ><path
                      d="M12.48 10.92v3.28h4.74c-.2 1.06-.9 1.95-1.93 2.53v2.13h3.12c1.82-1.68 2.87-4.15 2.87-7.07 0-.52-.04-1.03-.13-1.51H12.48z"
                    ></path><path
                      d="M12.48 21c2.43 0 4.47-.81 5.96-2.2l-3.12-2.13c-.87.58-1.98.92-2.84.92-2.19 0-4.04-1.48-4.71-3.48H4.55v2.2C6.03 19.26 8.99 21 12.48 21z"
                    ></path><path
                      d="M7.77 14.11c-.17-.51-.27-1.06-.27-1.61s.1-1.1.27-1.61v-2.2H4.55C3.99 10.01 3.68 11.23 3.68 12.5s.31 2.49.87 3.61l3.22-2z"
                    ></path><path
                      d="M12.48 7.51c1.33 0 2.52.46 3.46 1.36l2.59-2.59C16.94 4.75 14.91 4 12.48 4 8.99 4 6.03 5.74 4.55 8.79l3.22 2.2c.67-2 2.52-3.48 4.71-3.48z"
                    ></path></svg
                  >
                  <span>Cuenta vinculada con Google</span>
                </div>
              </div>
            </div>

            <!-- Privacidad -->
            <div class="glass-card compact">
              <div class="card-header">
                <div class="header-icon warning">
                  <svg
                    viewBox="0 0 24 24"
                    width="24"
                    height="24"
                    stroke="currentColor"
                    stroke-width="2"
                    fill="none"
                    ><path
                      d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"
                    ></path><line x1="1" y1="1" x2="23" y2="23"></line></svg
                  >
                </div>
                <h3>Privacidad</h3>
              </div>

              <div class="card-body">
                <div class="toggle-row">
                  <div class="toggle-info">
                    <h4>Perfil Privado</h4>
                    <p>Solo tú y los admins pueden ver tu actividad.</p>
                  </div>
                  <label class="switch">
                    <input
                      type="checkbox"
                      id="privacy-toggle"
                      checked={isPrivate}
                    />
                    <span class="slider round"></span>
                  </label>
                </div>
              </div>
            </div>
          </div>
        </section>

        <!-- COMMENTS TAB -->
        <section id="comments" class="content-panel">
          <div class="panel-header">
            <h2>Historial de Comentarios</h2>
            <p>Tus últimas interacciones.</p>
          </div>

          <div class="glass-card empty-state">
            <div class="empty-icon">
              <svg
                viewBox="0 0 24 24"
                width="48"
                height="48"
                stroke="currentColor"
                stroke-width="1"
                fill="none"
                ><path
                  d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"
                ></path><line x1="9" y1="10" x2="15" y2="10"></line><line
                  x1="9"
                  y1="14"
                  x2="15"
                  y2="14"></line></svg
              >
            </div>
            <h3>Está muy tranquilo por aquí...</h3>
            <p>Aún no has comentado en ninguna serie o capítulo.</p>
            <a href="/" class="btn-text-link">Explorar Series &rarr;</a>
          </div>
        </section>
      </main>
    </div>
  </div>
</Layout>

<style>
  /* --- VARS & BASE --- */
  :root {
    --card-bg: rgba(20, 20, 25, 0.6);
    --card-border: rgba(255, 255, 255, 0.08);
    --input-bg: rgba(0, 0, 0, 0.3);
    --primary-glow: 0 0 20px rgba(0, 191, 255, 0.15);
  }

  .profile-page-wrapper {
    min-height: 100vh;
    padding-bottom: 4rem;
  }

  /* --- MEDIA EDIT BUTTONS --- */
  .change-banner-btn {
    position: absolute;
    top: 50px;
    right: 1.5rem;
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: #fff;
    padding: 0.6rem 1.2rem;
    border-radius: 12px;
    font-size: 0.8rem;
    font-weight: 700;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 0.6rem;
    transition: all 0.2s ease;
    z-index: 50;
  }

  .change-banner-btn:hover {
    background: #fff;
    color: #000;
    transform: translateY(-2px);
  }

  .avatar-edit-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.4);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    opacity: 0;
    transition: all 0.3s ease;
    border: none;
    cursor: pointer;
    z-index: 2;
  }

  .avatar-container:hover .avatar-edit-overlay {
    opacity: 1;
    backdrop-filter: blur(2px);
  }

  @media (max-width: 900px) {
    .change-banner-btn {
      top: 45px;
      right: 1rem;
      padding: 0.5rem 1rem;
      font-size: 0.75rem;
    }
  }

  /* --- HERO SECTION --- */
  .profile-hero {
    position: relative;
    width: 100%;
    margin-bottom: -60px;
    z-index: 10;
  }

  .hero-banner {
    height: 320px;
    width: 100%;
    background-size: cover;
    background-position: center;
    position: relative;
    mask-image: linear-gradient(
      to bottom,
      transparent 0%,
      black 5%,
      black 90%,
      transparent 100%
    );
    -webkit-mask-image: linear-gradient(
      to bottom,
      transparent 0%,
      black 5%,
      black 90%,
      transparent 100%
    );
    transition: all 0.5s ease;
  }
  .premium-gradient {
    background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
  }
  .banner-pattern {
    position: absolute;
    inset: 0;
    opacity: 0.1;
    background-image: radial-gradient(#fff 1px, transparent 1px);
    background-size: 30px 30px;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      #020205 0%,
      rgba(2, 2, 5, 0.6) 4%,
      transparent 10%
    );
    z-index: 1;
    pointer-events: none; /* Astra: Evita que el gradiente bloquee clics */
  }

  .hero-content {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
    position: relative;
  }

  .profile-header-grid {
    display: flex;
    align-items: flex-end;
    gap: 2.5rem;
    transform: translateY(-80px);
  }

  .avatar-container {
    width: 180px;
    height: 180px;
    position: relative;
    flex-shrink: 0;
  }
  .main-avatar {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 50%;
    border: 6px solid #020205; /* Match body bg */
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
    background: #000;
  }

  .identity-section {
    padding-bottom: 20px;
    flex: 1;
  }
  .identity-top {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 0.5rem;
  }
  .username {
    font-size: 2.8rem;
    font-weight: 800;
    line-height: 1;
    color: #fff;
    letter-spacing: -0.02em;
  }
  .role-badge {
    padding: 0.3rem 0.8rem;
    border-radius: 100px;
    font-size: 0.75rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .role-admin {
    background: rgba(255, 68, 68, 0.1);
    color: #ff4444;
    border: 1px solid rgba(255, 68, 68, 0.2);
  }
  .role-explorer {
    background: rgba(0, 191, 255, 0.1);
    color: var(--accent-color);
    border: 1px solid rgba(0, 191, 255, 0.2);
  }

  .identity-meta {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    color: #888;
    font-size: 0.95rem;
  }
  .meta-item {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }
  .meta-dot {
    color: #444;
  }

  /* --- MAIN LAYOUT --- */
  .profile-layout {
    max-width: 1200px;
    margin: 4rem auto 0;
    padding: 0 2rem;
    display: grid;
    grid-template-columns: 320px 1fr;
    gap: 3rem;
  }

  /* SIDEBAR */
  .profile-sidebar {
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .admin-wrapper {
    margin-bottom: 0;
  }

  .glass-nav {
    background: linear-gradient(
      135deg,
      rgba(255, 255, 255, 0.05) 0%,
      rgba(255, 255, 255, 0.01) 100%
    );
    backdrop-filter: blur(24px) saturate(180%);
    -webkit-backdrop-filter: blur(24px) saturate(180%);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 28px;
    padding: 0.8rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    position: sticky;
    top: 100px;
    box-shadow: 
      0 4px 24px -1px rgba(0, 0, 0, 0.2),
      inset 0 0 20px rgba(255, 255, 255, 0.02);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .nav-header {
    padding: 0.8rem 1.2rem;
    margin-bottom: 0.8rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }
  .nav-header h3 {
    font-size: 0.75rem;
    text-transform: uppercase;
    color: var(--accent-color);
    filter: brightness(0.7);
    font-weight: 800;
    letter-spacing: 0.15em;
    margin: 0;
  }

  .nav-item {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 1rem;
    padding: 0.85rem 1rem;
    border-radius: 18px;
    background: transparent;
    border: 1px solid transparent;
    color: #999;
    cursor: pointer;
    transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    text-align: left;
    width: 100%;
    position: relative;
    overflow: hidden;
  }

  .nav-item::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, var(--accent-color), transparent);
    opacity: 0;
    transition: opacity 0.3s ease;
    z-index: 0;
  }

  .nav-item:hover {
    background: rgba(255, 255, 255, 0.04);
    color: #eee;
    transform: translateX(4px);
    border-color: rgba(255, 255, 255, 0.05);
  }

  .nav-item.active {
    background: rgba(0, 191, 255, 0.08);
    color: #fff;
    border-color: rgba(0, 191, 255, 0.2);
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
  }

  .icon-box {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 12px;
    background: rgba(0, 0, 0, 0.3);
    color: inherit;
    transition: all 0.3s ease;
    z-index: 1;
    border: 1px solid rgba(255, 255, 255, 0.05);
    flex-shrink: 0;
  }

  .nav-item:hover .icon-box {
    background: rgba(0, 0, 0, 0.5);
    border-color: rgba(255, 255, 255, 0.1);
    transform: scale(1.05);
  }

  .nav-item.active .icon-box {
    background: var(--accent-color);
    color: #000;
    box-shadow: 0 0 20px rgba(0, 191, 255, 0.3);
    border-color: transparent;
  }
  .icon-box.danger {
    color: #ff4444;
  }
  .logout-btn:hover .icon-box.danger {
    background: #ff4444;
    color: #fff;
  }

  .nav-label {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    flex: 1;
    overflow: hidden;
  }
  .nav-label span {
    font-weight: 700;
    font-size: 0.95rem;
    color: #fff;
    line-height: 1.2;
  }
  .nav-label small {
    font-size: 0.75rem;
    opacity: 0.5;
    font-weight: 500;
    white-space: nowrap;
