</style>

<script>
  import { actions } from 'astro:actions';
  import { toast } from '../lib/stores.svelte';
  import { getClientAuth } from '../lib/firebase/client';
  import { sendPasswordResetEmail, onAuthStateChanged } from 'firebase/auth';

  let auth: any;

  // Orion: Inicialización asíncrona para perfil
  (async () => {
    auth = await getClientAuth();

    // Auth Provider Detection
    onAuthStateChanged(auth, (user: any) => {
      if (user) {
        const isPasswordUser = user.providerData.some(
          (p: any) => p.providerId === 'password'
        );
        const resetContainer = document.getElementById(
          'password-reset-container'
        );
        const googleInfo = document.getElementById('google-managed-info');

        if (!isPasswordUser) {
          if (resetContainer) resetContainer.style.display = 'none';
          if (googleInfo) googleInfo.style.display = 'flex';
        }
      }
    });
  })();

  // Tabs Logic
  const navBtns = document.querySelectorAll('.nav-item[data-target]');
  const panes = document.querySelectorAll('.content-panel');

  navBtns.forEach((btn) => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      // Remove active class from all
      navBtns.forEach((b) => b.classList.remove('active'));
      panes.forEach((p) => p.classList.remove('active'));

      // Add active to clicked
      btn.classList.add('active');
      const targetId = btn.getAttribute('data-target');
      document.getElementById(targetId!)?.classList.add('active');

      // Optional: Smooth scroll on mobile if tab is below header
      if (window.innerWidth < 900) {
        window.scrollBy({ top: 100, behavior: 'smooth' });
      }
    });
  });

  // Profile Update Logic
  const form = document.getElementById('profile-form') as HTMLFormElement;
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = form.querySelector(
      'button[type="submit"]'
    ) as HTMLButtonElement;
    const originalText = btn.innerHTML;

    try {
      btn.disabled = true;
      btn.innerHTML = '<span class="loading-spinner"></span> Guardando...';

      const formData = new FormData(form);
      const payload = Object.fromEntries(formData);

      const { error } = await actions.user.updateProfile(payload);

      if (error) throw new Error(error.message || 'Error al guardar');
      toast.success('¡Perfil actualizado correctamente!');
    } catch (error: any) {
      toast.error(error.message);
    } finally {
      btn.disabled = false;
      btn.innerHTML = originalText;
    }
  });

  // Password Reset
  const resetBtn = document.getElementById('reset-password-btn');
  resetBtn?.addEventListener('click', async () => {
    const email = auth.currentUser?.email;
    if (!email) return toast.error('No se detectó email en la sesión actual.');
    try {
      await sendPasswordResetEmail(auth, email);
      toast.success(`Enviado a ${email}. Revisa tu bandeja.`);
    } catch {
      toast.error('Error al enviar el correo. Intenta más tarde.');
    }
  });

  // Toggles Logic (Reusable)
  const handleToggle = async (
    elementId: string,
    payloadKey: string,
    successMsg: [string, string]
  ) => {
    const toggle = document.getElementById(elementId) as HTMLInputElement;
    toggle?.addEventListener('change', async (e) => {
      const isChecked = (e.target as HTMLInputElement).checked;
      try {
        const { error } = await actions.user.updateProfile({ [payloadKey]: isChecked });
        if (error) throw new Error(error.message);
        toast.success(isChecked ? successMsg[0] : successMsg[1]);
      } catch {
        toast.error('Error al actualizar preferencia');
        toggle.checked = !isChecked; // Revert
      }
    });
  };

  handleToggle('privacy-toggle', 'isPrivate', [
    'Perfil ahora es PRIVADO 🔒',
    'Perfil ahora es PÚBLICO 🌍',
  ]);

  // Logout Logic
  const logoutBtn = document.getElementById('logout-trigger');
  logoutBtn?.addEventListener('click', async () => {
    try {
      const { error } = await actions.auth.logout();
      if (!error) window.location.href = '/';
      else throw new Error(error.message);
    } catch (e) {
      toast.error('Error al cerrar sesión');
    }
  });
</script>
