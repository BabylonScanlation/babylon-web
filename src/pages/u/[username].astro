---
import { and, desc, eq, sql } from 'drizzle-orm';
import MangaCard from '../../components/MangaCard.astro';
import {
  chapters,
  comments,
  // newsComments,
  favorites,
  news,
  series,
  seriesComments,
  seriesRatings,
  userRoles,
  users,
} from '../../db/schema';
import Layout from '../../layouts/Layout.astro';
import { getDB } from '../../lib/db';
import { timeAgo } from '../../lib/utils';

const { username } = Astro.params;
const db = getDB(Astro.locals.runtime.env);

// 1. Fetch Target Profile
const targetUser = await db.select().from(users).where(eq(users.username, username!)).get();

if (!targetUser) {
  return Astro.redirect('/404');
}

// 2. Auth Context
const { user: currentUser } = Astro.locals;
const isOwner = currentUser?.uid === targetUser.id;

// 3. Privacy Check
const isPrivateAccessDenied = targetUser.isPrivate && !isOwner;

// 4. Role Fetching
const targetRoleData = await db
  .select()
  .from(userRoles)
  .where(eq(userRoles.userId, targetUser.id))
  .get();
const isAdmin = targetRoleData?.role === 'admin';
const roleDisplay = isAdmin ? 'Administrador' : 'Explorador';
const roleClass = isAdmin ? 'rank-admin' : 'rank-explorer';

// 5. Data Fetching for Tabs
const currentTab = Astro.url.searchParams.get('tab') || 'activity';

// Activity (Unified Comments)
let userActivity: any[] = [];
if (currentTab === 'activity') {
  // We'll fetch from all 3 comment tables
  const chapterComms = await db
    .select({
      id: comments.id,
      text: comments.commentText,
      date: comments.createdAt,
      type: sql`'chapter'`,
      targetTitle: chapters.title,
      targetNumber: chapters.chapterNumber,
      seriesTitle: series.title,
      seriesSlug: series.slug,
    })
    .from(comments)
    .innerJoin(chapters, eq(comments.chapterId, chapters.id))
    .innerJoin(series, eq(chapters.seriesId, series.id))
    .where(eq(comments.userId, targetUser.id))
    .orderBy(desc(comments.createdAt))
    .limit(20);

  const seriesComms = await db
    .select({
      id: seriesComments.id,
      text: seriesComments.commentText,
      date: seriesComments.createdAt,
      type: sql`'series'`,
      targetTitle: series.title,
      targetNumber: sql`NULL`,
      seriesTitle: series.title,
      seriesSlug: series.slug,
    })
    .from(seriesComments)
    .innerJoin(series, eq(seriesComments.seriesId, series.id))
    .where(eq(seriesComments.userId, targetUser.id))
    .orderBy(desc(seriesComments.createdAt))
    .limit(20);

  userActivity = [...chapterComms, ...seriesComms]
    .sort((a, b) => new Date(b.date || 0).getTime() - new Date(a.date || 0).getTime())
    .slice(0, 20);
}

// Favorites
let userFavorites: any[] = [];
if (currentTab === 'favorites') {
  userFavorites = await db
    .select({
      series: series,
    })
    .from(favorites)
    .innerJoin(series, eq(favorites.seriesId, series.id))
    .where(and(eq(favorites.userId, targetUser.id), eq(favorites.type, 'series')))
    .orderBy(desc(favorites.createdAt))
    .all();
}

// Contributions (News)
let userNews: any[] = [];
if (currentTab === 'news' && isAdmin) {
  userNews = await db
    .select()
    .from(news)
    .where(eq(news.publishedBy, targetUser.id))
    .orderBy(desc(news.createdAt))
    .all();
}

// Global Stats
const totalComments =
  (
    await db
      .select({ count: sql`count(*)` })
      .from(comments)
      .where(eq(comments.userId, targetUser.id))
      .get()
  )?.count || 0;
const totalSeriesComments =
  (
    await db
      .select({ count: sql`count(*)` })
      .from(seriesComments)
      .where(eq(seriesComments.userId, targetUser.id))
      .get()
  )?.count || 0;
const totalActivity = Number(totalComments) + Number(totalSeriesComments);

const totalFavs =
  (
    await db
      .select({ count: sql`count(*)` })
      .from(favorites)
      .where(and(eq(favorites.userId, targetUser.id), eq(favorites.type, 'series')))
      .get()
  )?.count || 0;

const avgRating = Number(
  (
    await db
      .select({ avg: sql`avg(rating)` })
      .from(seriesRatings)
      .where(eq(seriesRatings.userId, targetUser.id))
      .get()
  )?.avg || 0
);

import { siteConfig } from '../../site.config';

// Presentation Data
const avatar =
  targetUser.avatarUrl ||
  `https://ui-avatars.com/api/?name=${targetUser.username}&background=random`;
const bannerUrl = targetUser.bannerUrl || null;
const bio = targetUser.bio || 'Este usuario aún no ha escrito una biografía.';
---

<Layout title={`Perfil de ${targetUser.username} - ${siteConfig.shortName}`}>
  <div class="profile-page-wrapper">
    <header class="profile-hero">
      <div
        class={`hero-banner ${!bannerUrl ? 'premium-gradient' : ''}`}
        style={bannerUrl ? `background-image: url('${bannerUrl}')` : ''}
      >
        {!bannerUrl && <div class="banner-pattern" />}
        <div class="hero-overlay"></div>
      </div>

      <div class="hero-content">
        <div class="profile-main-info">
          <div class="avatar-container">
            <div class="avatar-ring"></div>
            <img src={avatar} alt={targetUser.username} class="main-avatar" />
          </div>
          <div class="user-identity">
            <div class="identity-top">
              <h1>{targetUser.username}</h1>
              <div class="badges-row">
                <span class:list={['user-rank', roleClass]}>{roleDisplay}</span>
                {
                  avgRating > 0 && (
                    <span class="badge-rating">
                      <svg
                        viewBox="0 0 24 24"
                        width="14"
                        height="14"
                        fill="currentColor"
                        class="star-icon"
                      >
                        <path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z" />
                      </svg>
                      {Number(avgRating).toFixed(1)} Crítico
                    </span>
                  )
                }
              </div>
            </div>
            {
              targetUser.website && (
                <a
                  href={targetUser.website}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="user-website"
                >
                  <svg
                    viewBox="0 0 24 24"
                    width="16"
                    height="16"
                    stroke="currentColor"
                    stroke-width="2"
                    fill="none"
                  >
                    <>
                      <circle cx="12" cy="12" r="10" />
                      <line x1="2" y1="12" x2="22" y2="12" />
                      <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
                    </>
                  </svg>
                  {targetUser.website.replace(/^https?:\/\//, '')}
                </a>
              )
            }
          </div>
        </div>
      </div>
    </header>

    <div class="profile-grid">
      {
        isPrivateAccessDenied ? (
          <div class="private-profile-notice glass-card">
            <div class="lock-illustration">
              <svg
                viewBox="0 0 24 24"
                width="64"
                height="64"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <>
                  <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                  <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                </>
              </svg>
            </div>
            <h2>Cuenta Privada</h2>
            <p>
              El contenido de este perfil ha sido restringido por el usuario.
            </p>
            <a href="/" class="back-home-btn">
              Explorar {siteConfig.shortName}
            </a>
          </div>
        ) : (
          <>
            <aside class="profile-sidebar">
              <div class="glass-card sidebar-card">
                <div class="bio-section">
                  <h3>Biografía</h3>
                  <p class="bio-text">{bio}</p>
                </div>

                <div class="user-stats-grid">
                  <div class="stat-item">
                    <span class="stat-value">{totalActivity}</span>
                    <span class="stat-label">Comentarios</span>
                  </div>
                  <div class="stat-item">
                    <span class="stat-value">{totalFavs}</span>
                    <span class="stat-label">Favoritos</span>
                  </div>
                </div>

                <div class="member-since">
                  <svg
                    viewBox="0 0 24 24"
                    width="16"
                    height="16"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                  >
                    <>
                      <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
                      <line x1="16" y1="2" x2="16" y2="6" />
                      <line x1="8" y1="2" x2="8" y2="6" />
                      <line x1="3" y1="10" x2="21" y2="10" />
                    </>
                  </svg>
                  Miembro desde{' '}
                  {new Date(targetUser.createdAt || Date.now()).toLocaleDateString('es-ES', {
                    month: 'long',
                    year: 'numeric',
                  })}
                </div>
              </div>
            </aside>

            <main class="profile-content">
              <nav class="profile-tabs">
                <a
                  href="?tab=activity"
                  class:list={[
                    'tab-link',
                    { active: currentTab === 'activity' },
                  ]}
                >
                  Actividad
                </a>
                <a
                  href="?tab=favorites"
                  class:list={[
                    'tab-link',
                    { active: currentTab === 'favorites' },
                  ]}
                >
                  Favoritos
                </a>
                {isAdmin && (
                  <a
                    href="?tab=news"
                    class:list={['tab-link', { active: currentTab === 'news' }]}
                  >
                    Noticias
                  </a>
                )}
              </nav>

              <div class="tab-content">
                {currentTab === 'activity' && (
                  <div class="activity-feed">
                    {userActivity.length > 0 ? (
                      userActivity.map((item) => (
                        <div class="activity-card glass-card">
                          <div class="activity-header">
                            <span class="activity-type">
                              {item.type === 'chapter'
                                ? 'Comentó en un capítulo'
                                : 'Comentó en una serie'}
                            </span>
                            <span class="activity-date">
                              {timeAgo(item.date)}
                            </span>
                          </div>
                          <div class="activity-target">
                            <a
                              href={`/series/${item.seriesSlug}${item.type === 'chapter' ? `/${item.targetNumber}` : ''}`}
                              class="target-link"
                            >
                              {item.seriesTitle}{' '}
                              {item.type === 'chapter'
                                ? `- Cap. ${item.targetNumber}`
                                : ''}
                            </a>
                          </div>
                          <p class="activity-text">{item.text}</p>
                        </div>
                      ))
                    ) : (
                      <div class="empty-tab">
                        <p>Este usuario no tiene actividad pública reciente.</p>
                      </div>
                    )}
                  </div>
                )}

                {currentTab === 'favorites' && (
                  <div class="favorites-grid">
                    {userFavorites.length > 0 ? (
                      <div class="manga-grid">
                        {userFavorites.map((fav) => (
                          <MangaCard
                            title={fav.series.title}
                            url={`/series/${fav.series.slug}`}
                            coverUrl={fav.series.coverImageUrl}
                            lastChapter={fav.series.status || 'Ver serie'}
                          />
                        ))}
                      </div>
                    ) : (
                      <div class="empty-tab">
                        <p>Aún no ha guardado ninguna serie como favorita.</p>
                      </div>
                    )}
                  </div>
                )}

                {currentTab === 'news' && isAdmin && (
                  <div class="news-list">
                    {userNews.length > 0 ? (
                      userNews.map((post) => (
                        <a
                          href={`/news/${post.id}`}
                          class="news-item glass-card"
                        >
                          <h4>{post.title}</h4>
                          <span class="news-date">
                            {new Date(post.createdAt).toLocaleDateString()}
                          </span>
                        </a>
                      ))
                    ) : (
                      <div class="empty-tab">
                        <p>No ha publicado noticias aún.</p>
                      </div>
                    )}
                  </div>
                )}
              </div>
            </main>
          </>
        )
      }
    </div>
  </div>
</Layout>

<style>
  .profile-page-wrapper {
    min-height: 100vh;
    background-color: #0a0a0a;
    padding-bottom: 5rem;
  }

  /* Hero */
  .profile-hero {
    position: relative;
    height: 380px;
    margin-bottom: 2rem;
  }
  .hero-banner {
    height: 100%;
    background-size: cover;
    background-position: center;
    position: relative;
  }
  .premium-gradient {
    background: linear-gradient(135deg, #111 0%, #050505 100%);
  }
  .banner-pattern {
    position: absolute;
    inset: 0;
    opacity: 0.05;
    background-image: radial-gradient(#fff 1px, transparent 1px);
    background-size: 30px 30px;
  }
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      transparent 0%,
      rgba(10, 10, 10, 0.9) 80%,
      #0a0a0a 100%
    );
  }
  .hero-content {
    position: absolute;
    bottom: 0;
    left: 50%;
    width: 100%;
    max-width: 1200px;
    transform: translateX(-50%);
    padding: 0 2rem;
    z-index: 10;
  }
  .profile-main-info {
    display: flex;
    align-items: flex-end;
    gap: 2.5rem;
    transform: translateY(3rem);
  }

  .avatar-container {
    position: relative;
    width: 180px;
    height: 180px;
    flex-shrink: 0;
  }
  .avatar-ring {
    position: absolute;
    inset: -6px;
    border-radius: 50%;
    background: linear-gradient(135deg, #333, #111);
    padding: 2px;
    opacity: 1;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.5);
  }
  .main-avatar {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 50%;
    border: 6px solid #0a0a0a;
    background: #1a1a1a;
    position: relative;
    z-index: 2;
  }

  .user-identity h1 {
    margin: 0;
    font-size: 3rem;
    font-weight: 900;
    color: #fff;
    line-height: 1;
    text-shadow: 0 4px 10px rgba(0, 0, 0, 0.5);
  }
  .badges-row {
    display: flex;
    gap: 0.75rem;
    margin-top: 0.75rem;
    align-items: center;
  }
  .user-rank {
    display: inline-block;
    padding: 4px 12px;
    border-radius: 8px;
    font-size: 0.7rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    border: 1px solid transparent;
  }
  .rank-admin {
    background: rgba(239, 68, 68, 0.1);
    color: #ef4444;
    border-color: rgba(239, 68, 68, 0.2);
  }
  .rank-explorer {
    background: rgba(59, 130, 246, 0.1);
    color: #3b82f6;
    border-color: rgba(59, 130, 246, 0.2);
  }
  .badge-rating {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    background: rgba(245, 158, 11, 0.1);
    color: #f59e0b;
    padding: 4px 12px;
    border-radius: 8px;
    font-size: 0.7rem;
    font-weight: 700;
    border: 1px solid rgba(245, 158, 11, 0.2);
  }
  .star-icon {
    color: #f59e0b;
  }

  /* Grid Layout */
  .profile-grid {
    max-width: 1200px;
    margin: 6rem auto 0;
    padding: 0 2rem;
    display: grid;
    grid-template-columns: 320px 1fr;
    gap: 3rem;
  }

  /* Sidebar */
  .glass-card {
    background: rgba(30, 30, 35, 0.4);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 24px;
  }
  .sidebar-card {
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 2rem;
    position: sticky;
    top: 100px;
  }
  .bio-section h3 {
    font-size: 0.9rem;
    color: #6b7280;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.75rem;
  }
  .bio-text {
    font-size: 1rem;
    line-height: 1.6;
    color: #d1d5db;
  }
  .user-stats-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    padding: 1.5rem 0;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }
  .stat-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }
  .stat-value {
    font-size: 1.5rem;
    font-weight: 800;
    color: #fff;
  }
  .stat-label {
    font-size: 0.75rem;
    color: #6b7280;
    text-transform: uppercase;
  }
  .member-since {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: #4b5563;
    font-size: 0.85rem;
    font-weight: 500;
  }

  /* Tabs */
  .profile-tabs {
    display: flex;
    gap: 2rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    margin-bottom: 2rem;
  }
  .tab-link {
    padding: 1rem 0;
    color: #6b7280;
    text-decoration: none;
    font-weight: 600;
    font-size: 1rem;
    position: relative;
    transition: color 0.2s;
  }
  .tab-link:hover {
    color: #fff;
  }
  .tab-link.active {
    color: #fff;
  }
  .tab-link.active::after {
    content: '';
    position: absolute;
    bottom: -1px;
    left: 0;
    width: 100%;
    height: 2px;
    background: #3b82f6;
    box-shadow: 0 -2px 10px rgba(59, 130, 246, 0.5);
  }

  /* Activity */
  .activity-feed {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .activity-card {
    padding: 1.5rem;
    transition: transform 0.2s;
  }
  .activity-card:hover {
    transform: translateY(-2px);
    border-color: rgba(255, 255, 255, 0.1);
  }
  .activity-header {
    display: flex;
    justify-content: space-between;
    margin-bottom: 0.75rem;
  }
  .activity-type {
    font-size: 0.75rem;
    color: #3b82f6;
    font-weight: 700;
    text-transform: uppercase;
  }
  .activity-date {
    font-size: 0.75rem;
    color: #4b5563;
  }
  .activity-target {
    margin-bottom: 0.5rem;
  }
  .target-link {
    font-weight: 700;
    color: #fff;
    text-decoration: none;
    font-size: 1.1rem;
  }
  .target-link:hover {
    color: #3b82f6;
  }
  .activity-text {
    color: #9ca3af;
    font-size: 0.95rem;
    line-height: 1.5;
    font-style: italic;
    word-break: break-word;
    overflow-wrap: anywhere;
  }

  /* Favorites */
  .manga-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 1.5rem;
  }

  /* News */
  .news-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .news-item {
    padding: 1.5rem;
    text-decoration: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .news-item h4 {
    margin: 0;
    color: #fff;
  }
  .news-date {
    color: #4b5563;
    font-size: 0.85rem;
  }

  .empty-tab {
    text-align: center;
    padding: 5rem 2rem;
    color: #4b5563;
    font-style: italic;
  }

  /* Private Profile State */
  .private-profile-notice {
    grid-column: 1 / -1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 5rem 2rem;
    gap: 1.5rem;
  }
  .lock-illustration {
    background: rgba(255, 255, 255, 0.03);
    padding: 2rem;
    border-radius: 50%;
    color: #4b5563;
    margin-bottom: 1rem;
  }
  .private-profile-notice h2 {
    font-size: 2rem;
    font-weight: 800;
    color: #fff;
    margin: 0;
  }
  .private-profile-notice p {
    color: #6b7280;
    font-size: 1.1rem;
    max-width: 400px;
    line-height: 1.6;
  }
  .back-home-btn {
    background: #3b82f6;
    color: white;
    text-decoration: none;
    padding: 0.8rem 2rem;
    border-radius: 12px;
    font-weight: 700;
    transition: all 0.2s;
    margin-top: 1rem;
  }
  .back-home-btn:hover {
    background: #2563eb;
    transform: translateY(-2px);
  }

  @media (max-width: 1024px) {
    .profile-grid {
      grid-template-columns: 1fr;
    }
    .sidebar-card {
      position: static;
    }
  }
  @media (max-width: 768px) {
    .profile-hero {
      height: 300px;
    }
    .profile-main-info {
      flex-direction: column;
      align-items: center;
      transform: translateY(1.5rem);
      text-align: center;
    }
    .avatar-container {
      width: 140px;
      height: 140px;
    }
    .user-identity h1 {
      font-size: 2.2rem;
    }
    .manga-grid {
      grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
    }
  }
</style>
