---
import Layout from '../layouts/Layout.astro';
import { siteConfig } from '../site.config';

const { user, runtime } = Astro.locals;
const isSuperAdmin = user?.uid === runtime.env.SUPER_ADMIN_UID;

const success = Astro.url.searchParams.get('success');
const error = Astro.url.searchParams.get('error');

const adminCards = [
  {
    title: 'Análisis & Datos',
    desc: 'Rendimiento, vistas diarias y series más populares.',
    href: '/admin/stats',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"></line><line x1="12" y1="20" x2="12" y2="4"></line><line x1="6" y1="20" x2="6" y2="14"></line></svg>`,
    color: '#00bfff',
  },
  {
    title: 'Biblioteca de Series',
    desc: 'Edita metadatos, gestiona capítulos y visibilidad.',
    href: '/admin/series',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path></svg>`,
    color: '#a29bfe',
  },
  {
    title: 'Control de Contenido',
    desc: 'Crea series y sube nuevos capítulos vía Telegram.',
    href: '/admin/upload',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="17 8 12 3 7 8"></polyline><line x1="12" y1="3" x2="12" y2="15"></line></svg>`,
    color: '#00d2ff',
  },
  {
    title: 'Moderación',
    desc: 'Gestiona comentarios y mantén la comunidad limpia.',
    href: '/admin/comments',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>`,
    color: '#fab1a0',
  },
  {
    title: 'Noticias & Feed',
    desc: 'Comunica actualizaciones y anuncios a los usuarios.',
    href: '/admin/news',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 20H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h10l4 4v10a2 2 0 0 1-2 2z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>`,
    color: '#55efc4',
  },
];

if (isSuperAdmin) {
  adminCards.push({
    title: 'Administradores',
    desc: 'Gestiona privilegios y roles de acceso al sistema.',
    href: '/admin/users',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>`,
    color: '#ff7675',
  });
}
---

<Layout title={`Panel de Administración - ${siteConfig.shortName}`}>
  <main class="admin-dashboard-container">
    
    <header class="admin-header">
      <div class="welcome-section">
        <h1>Panel de Administración</h1>
        <p class="subtitle">Bienvenido al centro de control de {siteConfig.shortName}. Selecciona una zona para comenzar.</p>
      </div>
    </header>

    {success && <div class="alert success">{success}</div>}
    {error && <div class="alert error">{error}</div>}

    <div class="admin-grid">
      {adminCards.map((card) => (
        <div class="admin-card-wrapper">
          <a href={card.href} class="admin-card">
            <div class="card-glow" style={`background: ${card.color}`}></div>
            <div class="card-content">
              <div class="card-icon-wrapper" style={`color: ${card.color}; background: ${card.color}15`}>
                <Fragment set:html={card.icon} />
              </div>
              <div class="card-text">
                <h2>{card.title}</h2>
                <p>{card.desc}</p>
              </div>
              <div class="card-arrow">
                <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="3" fill="none"><polyline points="9 18 15 12 9 6"></polyline></svg>
              </div>
            </div>
          </a>
        </div>
      ))}
    </div>
  </main>
</Layout>

<style>
  .admin-dashboard-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 2rem;
    color: #fff;
    min-height: calc(100vh - 80px);
    display: flex;
    flex-direction: column;
    /* Astra: Asegurar espacio para el header fijo */
    margin-top: 20px;
    /* Astra: Forzar que todo el contenido del panel esté en una capa inferior al Header */
    position: relative;
    z-index: 1;
    isolation: isolate;
  }

  /* Header Section */
  .admin-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 3rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    padding-bottom: 2rem;
  }

  .badge-admin {
    display: inline-block;
    background: rgba(0, 191, 255, 0.1);
    color: var(--accent-color);
    padding: 4px 12px;
    border-radius: 100px;
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    margin-bottom: 1rem;
    border: 1px solid rgba(0, 191, 255, 0.2);
  }

  .admin-header h1 {
    font-size: 3rem;
    font-weight: 800;
    margin: 0 0 0.5rem 0;
    background: linear-gradient(135deg, #fff 0%, #888 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    letter-spacing: -0.02em;
  }

  .subtitle {
    color: #666;
    font-size: 1.1rem;
    margin: 0;
  }

  .status-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(46, 204, 113, 0.1);
    padding: 0.6rem 1.2rem;
    border-radius: 100px;
    border: 1px solid rgba(46, 204, 113, 0.2);
  }

  .status-dot {
    width: 8px;
    height: 8px;
    background: #2ecc71;
    border-radius: 50%;
    box-shadow: 0 0 10px #2ecc71;
    animation: pulse 2s infinite;
  }

  .status-text {
    font-size: 0.8rem;
    font-weight: 700;
    color: #2ecc71;
    text-transform: uppercase;
  }

  @keyframes pulse {
    0% { opacity: 0.5; }
    50% { opacity: 1; }
    100% { opacity: 0.5; }
  }

  /* Grid Layout */
  .admin-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
    flex-grow: 1;
  }

  /* Admin Card Glassmorphism */
  .admin-card-wrapper {
    padding: 15px 0; /* Buffer aumentado para el movimiento de 8px */
    display: flex;
    background: transparent; /* Asegura que capture eventos en toda su área */
  }

  .admin-card {
    position: relative;
    width: 100%;
    background: rgba(255, 255, 255, 0.03);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 24px;
    padding: 2rem;
    text-decoration: none;
    overflow: hidden;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .admin-card-wrapper:hover .admin-card {
    transform: translateY(-8px);
    background: rgba(255, 255, 255, 0.05);
    border-color: rgba(255, 255, 255, 0.15);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
  }

  .card-glow {
    position: absolute;
    top: 0;
    right: 0;
    width: 100px;
    height: 100px;
    filter: blur(60px);
    opacity: 0;
    transition: opacity 0.3s;
    pointer-events: none;
  }

  .admin-card-wrapper:hover .card-glow {
    opacity: 0.3;
  }

  .card-content {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    z-index: 1;
  }

  .card-icon-wrapper {
    width: 60px;
    height: 60px;
    border-radius: 18px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: transform 0.3s ease;
  }

  .admin-card-wrapper:hover .card-icon-wrapper {
    transform: scale(1.1) rotate(5deg);
  }

  .card-icon-wrapper :global(svg) {
    width: 30px;
    height: 30px;
  }

  .card-text {
    flex-grow: 1;
  }

  .card-text h2 {
    margin: 0 0 0.25rem 0;
    font-size: 1.35rem;
    font-weight: 700;
    color: #fff;
  }

  .card-text p {
    margin: 0;
    font-size: 0.95rem;
    color: #888;
    line-height: 1.4;
  }

  .card-arrow {
    color: #444;
    transition: all 0.3s;
    opacity: 0.5;
  }

  .admin-card-wrapper:hover .card-arrow {
    transform: translateX(5px);
    color: #fff;
    opacity: 1;
  }

  /* Alerts */
  .alert {
    padding: 1rem 1.5rem;
    border-radius: 16px;
    margin-bottom: 2.5rem;
    font-weight: 700;
    text-align: center;
    animation: slideIn 0.3s ease-out;
  }

  @keyframes slideIn {
    from { transform: translateY(-10px); opacity: 0; }
    to { transform: translateY(0); opacity: 1; }
  }

  .alert.success { background: rgba(46, 204, 113, 0.1); color: #2ecc71; border: 1px solid rgba(46, 204, 113, 0.2); }
  .alert.error { background: rgba(231, 76, 60, 0.1); color: #e74c3c; border: 1px solid rgba(231, 76, 60, 0.2); }

  @media (max-width: 900px) {
    .admin-dashboard-container { padding: 1rem; margin-top: 10px; }
    .admin-header { flex-direction: column; align-items: flex-start; gap: 1.5rem; margin-bottom: 2rem; }
    .admin-header h1 { font-size: 2rem; }
    .subtitle { font-size: 0.95rem; }
  }

  @media (max-width: 768px) {
    .admin-grid { grid-template-columns: 1fr; }
  }
</style>
