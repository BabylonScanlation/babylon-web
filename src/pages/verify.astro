---
import LayoutVerify from '../layouts/LayoutVerify.astro';

const isDev = import.meta.env.DEV;
const turnstileSiteKey =
  (isDev
    ? import.meta.env.PUBLIC_TURNSTILE_DEV_SITE_KEY
    : import.meta.env.PUBLIC_TURNSTILE_SITE_KEY) || '';
---

<LayoutVerify title="Verificación de Seguridad">
  <div class="age-gate-overlay" id="overlay">
    <div class="gate-card">
      <div class="logo-area">
        <div class="logo-wrapper">
          <img
            src="/favicon.png"
            alt="Babylon Logo"
            width="80"
            height="80"
            fetchpriority="high"
            loading="eager"
            decoding="async"
          />
        </div>
      </div>

      <div class="content-area">
        <h1>Bienvenido a Babylon</h1>
        <p class="subtitle">Confirma que eres mayor de edad y aceptas nuestros términos para continuar.</p>

        <div class="checks-area">
          <label class="checkbox-container">
            <input type="checkbox" id="check-age" />
            <div class="custom-checkbox">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
            </div>
            <span class="label-text">Soy mayor de 18 años</span>
          </label>

          <label class="checkbox-container">
            <input type="checkbox" id="check-terms" />
            <div class="custom-checkbox">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
            </div>
            <span class="label-text">Acepto los <a href="/terms">Términos y Condiciones</a></span>
          </label>
        </div>

        <div class="captcha-area">
          <div id="turnstile-container"></div>
        </div>

        <button class="enter-btn" id="enter-btn" disabled>
          Entrar al Sitio
        </button>
      </div>
    </div>
  </div>

  <div style="display:none" id="turnstile-data" data-sitekey={turnstileSiteKey}></div>

  <script>
    import { actions } from 'astro:actions';

    // Orion: Definición inmediata del estado local
    let captchaToken: string | null = null;

    const ageCheck = document.getElementById('check-age') as HTMLInputElement;
    const termsCheck = document.getElementById('check-terms') as HTMLInputElement;
    const enterBtn = document.getElementById('enter-btn') as HTMLButtonElement;

    // Astra: Función de validación centralizada
    const validateCaptcha = () => {
      enterBtn.disabled = !(ageCheck.checked && termsCheck.checked && captchaToken);
    }

    // Callback para Turnstile (lo asignamos a window para que el SDK de CF lo encuentre si es necesario, 
    // aunque aquí lo manejamos mediante el render directo)
    const onTurnstileVerify = (token: string) => {
      captchaToken = token;
      validateCaptcha();
    }

    ageCheck?.addEventListener('change', validateCaptcha);
    termsCheck?.addEventListener('change', validateCaptcha);

    // Iniciar cuando el DOM esté listo
    document.addEventListener('DOMContentLoaded', () => {
      const turnstileData = document.getElementById('turnstile-data');
      const sitekey = turnstileData?.dataset.sitekey;

      if (!sitekey || sitekey === 'undefined') {
        console.error('[Cloudflare Turnstile] Sitekey is missing or undefined.');
        return;
      }

      let renderAttempts = 0;
      const render = () => {
        // @ts-expect-error Turnstile is loaded via external script
        if (window.turnstile) {
          // @ts-expect-error Turnstile is loaded via external script
          window.turnstile.render('#turnstile-container', {
            sitekey: sitekey,
            theme: 'dark',
            callback: onTurnstileVerify,
            'expired-callback': () => {
               captchaToken = null;
               validateCaptcha();
               // @ts-expect-error Turnstile is loaded via external script
               window.turnstile.reset();
            },
            'error-callback': () => {
               console.warn('Turnstile error, retrying...');
               // @ts-expect-error Turnstile is loaded via external script
               window.turnstile.reset();
            }
          });
        } else if (renderAttempts < 50) {
          renderAttempts++;
          setTimeout(render, 100);
        }
      };
      
      // Esperar un poco a que el script de CF se cargue si no está listo
      if (document.readyState === 'complete') render();
      else window.addEventListener('load', render);
    });

    enterBtn.onclick = async () => {
      if (!captchaToken) return;
      
      try {
        const { error } = await actions.auth.verifyAge({
          token: captchaToken
        });
        
        if (!error) {
          sessionStorage.setItem('site_access_granted', 'true');
          window.location.href = '/';
        } else {
          alert(error.message || 'Error de verificación. Inténtalo de nuevo.');
          window.location.reload();
        }
      } catch (e) {
        console.error(e);
      }
    };
  </script>
</LayoutVerify>
