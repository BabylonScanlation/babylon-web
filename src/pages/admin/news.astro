---
import { asc, desc, sql } from 'drizzle-orm';
import AdminNewsManager from '../../components/AdminNewsManager.svelte';
import { news, series } from '../../db/schema';
import Layout from '../../layouts/Layout.astro';
import { getDB } from '../../lib/db';
import { siteConfig } from '../../site.config';

// Orion: Configuración de paginación
const limit = 18;
const offsetParam = Astro.url.searchParams.get('offset');
const offset = offsetParam ? parseInt(offsetParam, 10) : 0;

const db = getDB(Astro.locals.runtime.env);

// 1. Obtener total para paginación
const totalResult = await db.select({ count: sql<number>`count(*)` }).from(series).get();
const totalSeriesCount = totalResult?.count || 0;

// 2. Obtener series paginadas y ordenadas (Normales -> NSFW, luego Alfabético A-Z)
const allSeries = await db
  .select({
    id: series.id,
    title: series.title,
    coverImageUrl: series.coverImageUrl,
    isNsfw: series.isNsfw,
  })
  .from(series)
  .orderBy(asc(series.isNsfw), asc(series.title))
  .limit(limit)
  .offset(offset)
  .all();

// 3. Obtener todas las noticias (solo IDs de serie para el conteo de badges)
const allNews = await db
  .select()
  .from(news)
  .orderBy(desc(sql`CAST(${news.createdAt} AS INTEGER)`))
  .all();

const user = Astro.locals.user;
// Orion: Forzamos la URL absoluta en local para que el proxy funcione correctamente entre puertos
// Si estamos en localhost, ignoramos la URL pública de R2 porque los archivos están en el almacenamiento local de Wrangler
let r2PublicUrlAssets = Astro.locals.runtime.env.R2_PUBLIC_URL_ASSETS;
const isLocal = Astro.url.hostname === 'localhost' || Astro.url.hostname === '127.0.0.1';

if (isLocal || !r2PublicUrlAssets) {
  r2PublicUrlAssets = `${Astro.url.origin}/api/assets/proxy`;
}
---

<Layout title={`Gestión de Noticias - ${siteConfig.shortName}`}>
  <main class="admin-container">
    <div class="page-header-minimal">
      <a href="/admin" class="back-link-modern">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
        <span>Panel Admin</span>
      </a>
      <div class="header-title-main">
        <h1>Gestor de Novedades</h1>
        <p>Selecciona una obra para administrar sus noticias.</p>
      </div>
    </div>
    
    <!-- Componente Svelte Unificado -->
    <AdminNewsManager 
      client:load 
      allSeries={allSeries} 
      initialNews={allNews} 
      currentUser={user} 
      r2PublicUrlAssets={r2PublicUrlAssets}
    />

    <!-- Controles de Paginación (Solo si no hay una serie seleccionada) -->
    <div 
      class="pagination-outer-wrapper" 
      id="pagination-controls"
      data-offset={offset}
      data-limit={limit}
    >
      <nav class="pagination-wrapper">
        <div class="pagination-info">
          Mostrando <span class="highlight">{allSeries.length}</span> de <span class="highlight">{totalSeriesCount}</span> series
        </div>
        <div class="pagination-controls">
          <button 
            id="prev-page" 
            class:list={['pag-btn', 'prev', { disabled: offset === 0 }]}
            disabled={offset === 0}
          >
            <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="3"><polyline points="15 18 9 12 15 6"></polyline></svg>
          </button>
          
          <div class="page-numbers">
            <span class="current-page">{Math.floor(offset / limit) + 1}</span>
            <span class="separator">/</span>
            <span class="total-pages">{Math.ceil(totalSeriesCount / limit)}</span>
          </div>

          <button 
            id="next-page" 
            class:list={['pag-btn', 'next', { disabled: offset + limit >= totalSeriesCount }]}
            disabled={offset + limit >= totalSeriesCount}
          >
            <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="3"><polyline points="9 18 15 12 9 6"></polyline></svg>
          </button>
        </div>
      </nav>
    </div>
  </main>

  <script>
    const paginationFooter = document.getElementById('pagination-controls');
    const offset = parseInt(paginationFooter?.dataset.offset || '0');
    const limit = parseInt(paginationFooter?.dataset.limit || '18');

    const prevBtn = document.getElementById('prev-page');
    const nextBtn = document.getElementById('next-page');

    window.addEventListener('series-selected', (e: any) => {
      if (paginationFooter) {
        paginationFooter.style.display = e.detail.selected ? 'none' : 'flex';
      }
    });

    prevBtn?.addEventListener('click', () => {
      const newOffset = Math.max(0, offset - limit);
      window.location.href = `/admin/news?offset=${newOffset}`;
    });

    nextBtn?.addEventListener('click', () => {
      const newOffset = offset + limit;
      window.location.href = `/admin/news?offset=${newOffset}`;
    });
  </script>

  <style is:global>
    /* Estilos unificados para la paginación (Estilo Search) */
    .pagination-outer-wrapper {
      margin-top: 3rem;
      display: flex;
      justify-content: center;
      width: 100%;
    }

    .pagination-wrapper {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 1.5rem;
    }

    .pagination-info {
      color: #666;
      font-size: 0.9rem;
      font-weight: 500;
    }

    .pagination-info .highlight {
      color: #aaa;
      font-weight: 700;
    }

    .pagination-controls {
      display: flex;
      align-items: center;
      background: rgba(255, 255, 255, 0.03);
      border: 1px solid rgba(255, 255, 255, 0.08);
      backdrop-filter: blur(10px);
      padding: 0.5rem;
      border-radius: 100px;
      gap: 0.5rem;
    }

    .pag-btn {
      width: 44px;
      height: 44px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: rgba(255, 255, 255, 0.05);
      color: #fff;
      border-radius: 50%;
      border: none;
      cursor: pointer;
      transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }

    .pag-btn:hover:not(.disabled) {
      background: var(--accent-color, #00bfff);
      color: #000;
      transform: scale(1.1);
    }

    .pag-btn.disabled {
      opacity: 0.2;
      cursor: not-allowed;
      pointer-events: none;
    }

    .page-numbers {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      padding: 0 1.5rem;
      font-weight: 800;
    }

    .current-page {
      color: var(--accent-color, #00bfff);
      font-size: 1.2rem;
    }

    .separator {
      color: #333;
      font-size: 0.8rem;
    }

    .total-pages {
      color: #666;
      font-size: 1rem;
    }
  </style>

<style>
  .admin-container {
    padding: 2rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .page-header-minimal {
    display: flex;
    align-items: center;
    gap: 2rem;
    margin-bottom: 3rem;
    border-bottom: 1px solid rgba(255,255,255,0.05);
    padding-bottom: 2rem;
  }

  .header-title-main h1 {
    font-size: 2.5rem;
    font-weight: 900;
    margin: 0;
    background: linear-gradient(to right, #fff, #666);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .header-title-main p {
    color: #555;
    margin: 0.5rem 0 0 0;
    font-weight: 500;
  }

  .back-link-modern {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.6rem 1.2rem;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    color: #aaa;
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 600;
    transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
  }

  .back-link-modern:hover {
    background: rgba(255, 255, 255, 0.08);
    border-color: #fff;
    color: #fff;
    transform: translateX(-4px);
  }
</style>
