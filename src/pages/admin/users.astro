---
// src/pages/admin/users.astro
import Layout from '../../layouts/Layout.astro';
import { logError } from '../../lib/logError';
import { getDB } from '../../lib/db';
import { getAdmins } from '../../lib/data/admin';

const { user, runtime } = Astro.locals;
const superAdminUid = runtime.env.SUPER_ADMIN_UID;

// Solo el Super Admin puede acceder a esta página
if (!user?.isAdmin || user.uid !== superAdminUid) {
  return Astro.redirect('/admin?error=No tienes permiso para gestionar usuarios.');
}

let admins: { uid: string }[] = [];
try {
  const db = getDB(runtime.env);
  admins = await getAdmins(db);
} catch (e) {
  logError(e, 'Error al obtener administradores en SSR', { userId: user?.uid });
}
---

<Layout title="Gestionar Administradores">
  <main class="admin-container">
    <div class="page-header-minimal">
      <a href="/admin" class="back-link-modern">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
        <span>Panel Admin</span>
      </a>
      <div class="header-title-main">
        <h1>Gestionar Administradores</h1>
        <p>Añade o elimina privilegios de administración a usuarios.</p>
      </div>
    </div>

    <div id="dynamic-message-container"></div>

    <div class="admin-grid-layout">
      <!-- Sección Añadir -->
      <section class="glass-editor add-user-pane">
        <header class="editor-header">
          <h3>✨ Añadir Administrador</h3>
        </header>
        <form id="add-admin-form" class="compact-form-grid">
          <div class="input-group-modern">
            <label for="add-uid">UID de Firebase</label>
            <input type="text" id="add-uid" name="uid" placeholder="Pegar UID del usuario..." required class="glass-input" />
          </div>
          <button type="submit" class="btn-glass-primary">
            <span>Añadir Administrador</span>
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="8.5" cy="7" r="4"/><line x1="20" y1="8" x2="20" y2="14"/><line x1="23" y1="11" x2="17" y2="11"/></svg>
          </button>
        </form>
      </section>

      <!-- Sección Lista -->
      <section class="history-pane">
        <header class="section-header">
          <h3>👥 Administradores Activos</h3>
          <span class="count-chip">{admins.length}</span>
        </header>
        
        <div class="history-list" id="admin-list">
          {admins.map(admin => (
            <div class="history-card" data-uid={admin.uid}>
              <div class="card-main">
                <div class="card-info">
                  <h4 class="user-uid-display">{admin.uid}</h4>
                  <div class="card-meta">
                    <span class="status-dot published"></span>
                    <span class="status-text">Administrador</span>
                    {admin.uid === superAdminUid && <span class="badge-super">SUPER</span>}
                  </div>
                </div>
                <div class="card-actions">
                  {admin.uid !== superAdminUid && (
                    <button type="button" class="action-icon delete remove-admin-btn" title="Eliminar permisos">
                      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>
                    </button>
                  )}
                </div>
              </div>
            </div>
          ))}
        </div>
      </section>
    </div>
  </main>
</Layout>

<script is:inline define:vars={{ superAdminUid }}>
  function init() {
    const dynamicMessageContainer = document.getElementById('dynamic-message-container');
    const adminList = document.getElementById('admin-list');
    const addAdminForm = document.getElementById('add-admin-form');
    const addUidInput = document.getElementById('add-uid');

    function displayMessage(message, type) {
      if (!dynamicMessageContainer) return;
      dynamicMessageContainer.innerHTML = `<div class="status-toast ${type}">${message}</div>`;
      setTimeout(() => { dynamicMessageContainer.innerHTML = ''; }, 5000);
    }

    if (addAdminForm) {
      addAdminForm.addEventListener('submit', async (event) => {
        event.preventDefault();
        const uidToAdd = addUidInput.value.trim();
        if (!uidToAdd) return;

        if (uidToAdd === superAdminUid) {
          displayMessage('El Super Admin ya tiene permisos.', 'error');
          return;
        }

        if (!confirm(`¿Dar permisos de admin a: ${uidToAdd}?`)) return;

        try {
          const formData = new FormData();
          formData.append('uid', uidToAdd);
          
          const response = await fetch('/api/admin/users', {
            method: 'POST',
            body: formData
          });

          if (response.ok) {
            displayMessage('Administrador añadido con éxito.', 'success');
            window.location.reload(); // Recargamos para ver cambios
          } else {
            displayMessage('Error al añadir administrador.', 'error');
          }
        } catch {
          displayMessage('Error de conexión.', 'error');
        }
      });
    }

    if (adminList) {
      adminList.addEventListener('click', async (event) => {
        const btn = event.target.closest('.remove-admin-btn');
        if (!btn) return;

        const card = btn.closest('.history-card');
        const uidToRemove = card?.dataset.uid;
        if (!uidToRemove || uidToRemove === superAdminUid) return;

        if (!confirm(`¿Eliminar permisos de administrador a: ${uidToRemove}?`)) return;

        try {
          const formData = new FormData();
          formData.append('uid', uidToRemove);
          formData.append('_method', 'DELETE');

          const response = await fetch('/api/admin/users', {
            method: 'POST',
            body: formData
          });

          if (response.ok) {
            displayMessage('Permisos eliminados.', 'success');
            card.remove();
          } else {
            displayMessage('Error al eliminar permisos.', 'error');
          }
        } catch {
          displayMessage('Error de conexión.', 'error');
        }
      });
    }
  }

  init();
  document.addEventListener('astro:page-load', init);
</script>

<style>
  .admin-container {
    padding: 2rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .admin-grid-layout {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: 3rem;
    align-items: start;
  }

  @media (max-width: 900px) {
    .admin-grid-layout { grid-template-columns: 1fr; }
  }

  .header-title-main h1 {
    font-size: 2.5rem;
    font-weight: 900;
    margin: 0;
    background: linear-gradient(to right, #fff, #666);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .header-title-main p { color: #555; margin: 0.5rem 0 0 0; font-weight: 500; }

  .page-header-minimal {
    display: flex;
    align-items: center;
    gap: 2rem;
    margin-bottom: 3rem;
    border-bottom: 1px solid rgba(255,255,255,0.05);
    padding-bottom: 2rem;
  }

  .back-link-modern {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.6rem 1.2rem;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    color: #aaa;
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 600;
    transition: all 0.3s;
  }

  .back-link-modern:hover { color: #fff; border-color: #fff; transform: translateX(-4px); }

  /* Estilos Glass */
  .glass-editor {
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 24px;
    padding: 2rem;
    backdrop-filter: blur(10px);
  }

  .editor-header h3 { font-size: 0.9rem; text-transform: uppercase; color: #888; font-weight: 800; margin-bottom: 1.5rem; }

  .input-group-modern { display: flex; flex-direction: column; gap: 0.5rem; margin-bottom: 1.5rem; }
  .input-group-modern label { font-size: 0.75rem; font-weight: 800; color: #555; text-transform: uppercase; }

  .glass-input {
    background: #0a0a0a;
    border: 1px solid #222;
    color: #fff;
    border-radius: 12px;
    padding: 0.8rem 1.2rem;
    font-size: 0.9rem;
    font-family: inherit;
    transition: all 0.2s;
  }
  .glass-input:focus { outline: none; border-color: #4facfe; background: #111; }

  .btn-glass-primary {
    background: #fff;
    color: #000;
    border: none;
    padding: 0.8rem 1.5rem;
    border-radius: 12px;
    font-weight: 800;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    transition: all 0.2s;
    width: 100%;
  }
  .btn-glass-primary:hover { transform: translateY(-2px); box-shadow: 0 8px 20px rgba(255,255,255,0.1); }

  /* Lista de Administradores */
  .section-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; }
  .section-header h3 { margin: 0; font-size: 1.1rem; color: #fff; font-weight: 800; }
  .count-chip { background: #252525; padding: 2px 12px; border-radius: 20px; font-size: 0.8rem; color: #aaa; font-weight: 700; }

  .history-list { display: flex; flex-direction: column; gap: 1rem; }
  .history-card { background: #1a1a1a; padding: 1.5rem; border-radius: 20px; border: 1px solid rgba(255,255,255,0.03); transition: all 0.2s; }
  .history-card:hover { border-color: rgba(255,255,255,0.1); background: #222; }

  .card-main { display: flex; justify-content: space-between; align-items: center; }
  .user-uid-display { margin: 0 0 0.4rem 0; font-size: 0.9rem; color: #eee; font-family: monospace; }
  .card-meta { display: flex; align-items: center; gap: 0.6rem; font-size: 0.75rem; color: #666; font-weight: 600; }
  .status-dot { width: 6px; height: 6px; border-radius: 50%; }
  .status-dot.published { background: #2ecc71; box-shadow: 0 0 8px rgba(46, 204, 113, 0.4); }
  .status-text { text-transform: uppercase; letter-spacing: 0.5px; }

  .badge-super { background: #4facfe; color: #000; padding: 1px 6px; border-radius: 4px; font-size: 0.6rem; font-weight: 900; }

  .action-icon { background: transparent; border: none; color: #444; padding: 8px; cursor: pointer; border-radius: 10px; transition: all 0.2s; }
  .action-icon:hover { background: rgba(255, 71, 87, 0.1); color: #ff4757; }

  /* Toasts */
  .status-toast {
    position: fixed;
    top: 2rem;
    right: 2rem;
    padding: 1rem 2rem;
    border-radius: 12px;
    font-weight: 800;
    z-index: 1000;
    animation: slideIn 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
    backdrop-filter: blur(10px);
  }
  .status-toast.success { background: rgba(46, 204, 113, 0.9); color: #fff; }
  .status-toast.error { background: rgba(255, 71, 87, 0.9); color: #fff; }

  @keyframes slideIn { from { transform: translateX(100%); opacity: 0; } to { transform: translateX(0); opacity: 1; } }
</style>