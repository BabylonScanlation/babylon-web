---
import AdminCommentModerationItem from '../../components/AdminCommentModerationItem.svelte';
import Layout from '../../layouts/Layout.astro';
import { getAdminCommentsActivity } from '../../lib/data/admin';
import { getDB } from '../../lib/db';
import { logError } from '../../lib/logError';

let activityFeed: any[] = [];

try {
  const drizzleDb = getDB(Astro.locals.runtime.env);
  activityFeed = await getAdminCommentsActivity(drizzleDb);
} catch (e) {
  logError(e, 'Error al cargar el feed de actividad de comentarios', {
    userId: Astro.locals.user?.uid,
  });
}
---

<Layout title="Moderación Global de Comentarios">
  <main class="admin-container">
    <div class="page-header">
      <div class="header-nav">
        <a href="/admin" class="back-link-modern">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
          Volver al Panel
        </a>
      </div>
      <div class="title-group">
        <h1>Centro de Moderación</h1>
        <p class="subtitle">Feed de actividad reciente de la comunidad en tiempo real.</p>
      </div>
    </div>

    <div class="activity-feed">
      {
        activityFeed.length > 0 ? (
          <div class="feed-grid">
            {activityFeed.map((comment: any) => (
              <AdminCommentModerationItem 
                client:load
                commentId={comment.id}
                userEmail={comment.userEmail || 'Invitado'}
                userName={comment.userName}
                text={comment.text}
                targetType={comment.targetType === 'news' ? 'news' as any : comment.targetType}
                seriesSlug={comment.seriesSlug}
                chapterId={comment.chapterId}
                seriesTitle={comment.targetType === 'chapter' ? `${comment.parentName} - Cap ${comment.targetName}` : comment.targetName}
                createdAt={comment.createdAt}
              />
            ))}
          </div>
        ) : (
          <div class="empty-state">
            <div class="empty-icon">💬</div>
            <h3>Silencio absoluto</h3>
            <p>No se han encontrado comentarios recientes en ninguna sección.</p>
          </div>
        )
      }
    </div>
  </main>
</Layout>

<style>
  .admin-container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 2rem;
    font-family: 'Inter', system-ui, sans-serif;
    color: #e0e0e0;
  }

  /* Header */
  .page-header {
    margin-bottom: 3rem;
    border-bottom: 1px solid rgba(255,255,255,0.05);
    padding-bottom: 2rem;
  }

  .back-link-modern {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.6rem 1.2rem;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    color: #aaa;
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 600;
    transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
    margin-bottom: 1.5rem;
  }

  .back-link-modern:hover {
    background: rgba(255, 255, 255, 0.08);
    border-color: #fff;
    color: #fff;
    transform: translateX(-4px);
  }

  .title-group h1 { font-size: 2.2rem; margin: 0; color: #fff; letter-spacing: -0.5px; }
  .subtitle { color: #666; margin: 0.5rem 0 0 0; font-size: 1rem; }

  /* Feed Grid */
  .feed-grid {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  /* Empty States */
  .empty-state { text-align: center; padding: 8rem 2rem; color: #444; }
  .empty-icon { font-size: 4rem; opacity: 0.2; margin-bottom: 1.5rem; }
  .empty-state h3 { color: #666; margin-bottom: 0.5rem; font-size: 1.5rem; font-weight: 800; }
</style>
