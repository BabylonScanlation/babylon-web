---
import AdminAnalytics from '../../components/AdminAnalytics.svelte';
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Estadísticas - Panel de Administración">
  <main class="admin-container">
    <div class="nav-header">
      <a href="/admin" class="back-link-modern">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
        <span>Volver al Panel</span>
      </a>
      <h1>Estadísticas Globales</h1>
    </div>

    <AdminAnalytics client:load />
  </main>
</Layout>

<style>
  .admin-container {
    padding: 2rem;
    max-width: 1200px;
    margin: 0 auto;
    color: #fff;
  }

  @media (max-width: 768px) {
    .admin-container {
      padding: 1rem;
    }
    
    .nav-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 1.5rem;
      margin-bottom: 1.5rem;
    }
    
    h1 {
      font-size: 1.5rem;
    }
  }
  
  .nav-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2.5rem;
    border-bottom: 1px solid rgba(255,255,255,0.05);
    padding-bottom: 1.5rem;
  }

  h1 {
    font-size: 1.8rem;
    margin: 0;
    font-weight: 800;
    color: #fff;
  }

  .back-link-modern {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.6rem 1.2rem;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    color: #aaa;
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 600;
    transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
  }

  .back-link-modern:hover {
    background: rgba(255, 255, 255, 0.08);
    border-color: #fff;
    color: #fff;
    transform: translateX(-4px);
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.3);
  }
</style>
