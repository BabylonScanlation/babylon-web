---
import Layout from '../layouts/Layout.astro';
import HeroCarousel from '../components/HeroCarousel.astro';
import FeaturedGrid from '../components/FeaturedGrid.astro';
import RecentUpdatesGrid from '../components/RecentUpdatesGrid.astro';
import AdContainer from '../components/AdContainer.astro';
import { getHomeData } from '../lib/data/series';
import { getDB } from '../lib/db';
import { logError } from '../lib/logError';
import { siteConfig } from '../site.config';

const { runtime } = Astro.locals;
const r2PublicUrlAssets = runtime.env.R2_PUBLIC_URL_ASSETS || '/api/assets/proxy';

// Astra: El modo NSFW ahora es global vía cookies (Exclusivo)
const allowNsfw = Astro.cookies.get('babylon_nsfw')?.value === 'true';

let popularSeries: any[] = [];
let seriesByChapterCount: any[] = [];
let seriesWithRecentChapters: any[] = [];
let hasContent = false;

try {
  const db = getDB(runtime.env);

  // Orion: Carga ultra-optimizada en un solo paso
  const homeData = await getHomeData(db, allowNsfw);

  popularSeries = homeData.popularSeries as any;
  seriesByChapterCount = homeData.seriesByChapterCount as any;
  seriesWithRecentChapters = homeData.seriesWithRecentChapters;
  hasContent = homeData.hasContent;
} catch (error) {
  console.error('🔥 ERROR CRÍTICO EN HOME:', error);
  logError(error, 'Error al obtener las listas de series (Ultra Optimizado)');
}

// Orion: Para el FeaturedGrid usamos directamente las series populares
const featuredGridData = popularSeries.slice(0, 6);

// Orion: Garantizamos que la cuadrícula esté siempre ordenada por vistas (descendente)
featuredGridData.sort((a, b) => (b.views || 0) - (a.views || 0));
---

<Layout 
  title={`${siteConfig.name} - Leer Manga, Manhwa y Manhua Online Gratis`}
  description={`La mejor plataforma para leer Manga, Manhwa y Manhua online en español. Capítulos diarios, alta calidad visual y la mejor comunidad. ¡Lee gratis ahora en ${siteConfig.shortName}!`}
>
  <h1 class="sr-only">{siteConfig.name} - Tu plataforma premium para leer Manga, Manhwa y Manhua online gratis</h1>
  {
    hasContent ? (
      <div class="main-content-wrapper">
          {seriesByChapterCount.length > 0 && (
            <HeroCarousel 
              slides={seriesByChapterCount} 
              r2PublicUrlAssets={r2PublicUrlAssets} 
            />
          )}

        <div class="main-sections-container">

          <AdContainer type="bannerLarge" />

          {featuredGridData.length > 0 && (
            <FeaturedGrid mangas={featuredGridData.map((m) => ({...m, loading: 'lazy'}))} />
          )}

          <AdContainer type="bannerSmall" />

          <div class="discovery-zone">
            {seriesWithRecentChapters.length > 0 && (
              <RecentUpdatesGrid
                mangas={seriesWithRecentChapters}
                title="Últimos Capítulos Publicados"
              />
            )}
          </div>

          <AdContainer type="square" />
        </div>
      </div>
    ) : (
      <div class="empty-state-container">
        <img
          src={siteConfig.assets.logoEmpty.startsWith('/') ? `${r2PublicUrlAssets}${siteConfig.assets.logoEmpty}` : siteConfig.assets.logoEmpty}
          alt={`${siteConfig.name} Logo`}
          class="empty-state-logo"
        />
        <p class="empty-state-text">
          Lo sentimos... aún no hay series disponibles.
          <br />
          Vuelva en otro momento.
        </p>
      </div>
    )
  }
</Layout>

