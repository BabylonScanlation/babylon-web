---
import MangaList from '../components/MangaList.astro';
import SearchFilters from '../components/SearchFilters.svelte';
// src/pages/search.astro
import Layout from '../layouts/Layout.astro';
import { searchSeries } from '../lib/data/series';
import { getDB } from '../lib/db';
import { logError } from '../lib/logError';
import { siteConfig } from '../site.config';

const query = Astro.url.searchParams.get('q')?.trim() || '';
const page = parseInt(Astro.url.searchParams.get('page') || '1');
const user = Astro.locals.user;

// Astra: NSFW Toggle via cookie global
const nsfwCookieValue = Astro.cookies.get('babylon_nsfw')?.value;
const allowNsfw = typeof nsfwCookieValue === 'string' 
  ? nsfwCookieValue === 'true' 
  : (user?.isNsfw || false);

let searchResults: any[] = [];
let pagination = { page: 1, totalPages: 1, total: 0 };
let error: string | null = null;

try {
  const db = getDB(Astro.locals.runtime.env);
  const searchParams = Object.fromEntries(Astro.url.searchParams.entries());

  const result = await searchSeries(db, {
    ...searchParams,
    q: query,
    page,
    allowNsfw,
  });

  searchResults = result.results;
  pagination = result.pagination;
} catch (e) {
  logError(e, 'Error al realizar la búsqueda SSR', { query });
  error = 'No se pudo realizar la búsqueda.';
}
---

<Layout title={query ? `Búsqueda: ${query}` : `Buscador - ${siteConfig.shortName}`}>
  <main class="search-page-container">
    <div class="ambient-glow"></div>

    <section class="search-hero">
      <div class="logo-area">
        <h1 class="page-title">
          <span class="gradient-peru">Explorar</span>
          <span class="gradient-argentina">{siteConfig.shortName}</span>
        </h1>
        <p class="page-subtitle">
          Descubre tu próxima aventura en el catálogo más completo
        </p>
      </div>

      <div class="search-interface-wrapper">
        <div class="search-and-filters-row">
          <form action="/search" method="GET" class="search-bar-container" id="main-search-form">
            <div class="input-wrapper">
              <svg
                class="search-icon"
                viewBox="0 0 24 24"
                width="22"
                height="22"
                stroke="currentColor"
                stroke-width="2.5"
                fill="none"
                ><circle cx="11" cy="11" r="8"></circle><line
                  x1="21"
                  y1="21"
                  x2="16.65"
                  y2="16.65"></line></svg
              >
              <input
                type="text"
                name="q"
                id="main-search-input"
                value={query}
                placeholder="Buscar por título, autor o género..."
                class="search-input"
                autocomplete="off"
                autofocus
              />
              {
                query && (
                  <a href="/search" class="clear-btn" title="Limpiar búsqueda">
                    <svg
                      viewBox="0 0 24 24"
                      width="16"
                      height="16"
                      stroke="currentColor"
                      stroke-width="3"
                      fill="none"
                    >
                      <>
                        <line x1="18" y1="6" x2="6" y2="18" />
                        <line x1="6" y1="6" x2="18" y2="18" />
                      </>
                    </svg>
                  </a>
                )
              }
            </div>
          </form>

          <SearchFilters client:idle />
        </div>
      </div>
    </section>

    <script>
      // Astra: Preservar filtros al buscar desde la barra principal
      document.addEventListener('astro:page-load', () => {
        const form = document.getElementById('main-search-form') as HTMLFormElement;
        const input = document.getElementById('main-search-input') as HTMLInputElement;

        form?.addEventListener('submit', (e) => {
          e.preventDefault();
          const url = new URL(window.location.href);
          const searchTerm = input.value.trim();
          
          if (searchTerm) {
            url.searchParams.set('q', searchTerm);
          } else {
            url.searchParams.delete('q');
          }
          
          // Resetear página al buscar
          url.searchParams.set('page', '1');
          
          window.location.href = url.pathname + url.search;
        });
      });
    </script>

    <div class="results-container">
      {
        searchResults.length > 0 ? (
          <div class="results-content">
            <MangaList mangas={searchResults} />
            
            {pagination.totalPages > 1 && (
              <nav class="pagination-wrapper">
                <div class="pagination-info">
                  Mostrando <span class="highlight">{searchResults.length}</span> de <span class="highlight">{pagination.total}</span> series
                </div>
                <div class="pagination-controls">
                  <a 
                    href={pagination.page > 1 ? `?${new URLSearchParams({...Object.fromEntries(Astro.url.searchParams), page: (pagination.page - 1).toString()})}` : '#'} 
                    class={`pag-btn prev ${pagination.page <= 1 ? 'disabled' : ''}`}
                  >
                    <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="3"><polyline points="15 18 9 12 15 6"></polyline></svg>
                  </a>
                  
                  <div class="page-numbers">
                    <span class="current-page">{pagination.page}</span>
                    <span class="separator">/</span>
                    <span class="total-pages">{pagination.totalPages}</span>
                  </div>

                  <a 
                    href={pagination.page < pagination.totalPages ? `?${new URLSearchParams({...Object.fromEntries(Astro.url.searchParams), page: (pagination.page + 1).toString()})}` : '#'} 
                    class={`pag-btn next ${pagination.page >= pagination.totalPages ? 'disabled' : ''}`}
                  >
                    <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="3"><polyline points="9 18 15 12 9 6"></polyline></svg>
                  </a>
                </div>
              </nav>
            )}
          </div>
        ) : (
          <div class="empty-state-wrapper">
            {error ? (
              <div class="error-box-glass">
                <p>{error}</p>
              </div>
            ) : (
              <div class="empty-visual">
                <div class="illustration-container">
                  <div class="circle c1" />
                  <div class="circle c2" />
                  <svg
                    class="search-illustration"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    fill="none"
                    stroke-width="1.5"
                  >
                    <circle cx="11" cy="11" r="8" />
                    <path d="M21 21L16.65 16.65" />
                  </svg>
                </div>
                <h3>
                  {query
                    ? 'No encontramos coincidencias'
                    : '¿Qué buscaremos hoy?'}
                </h3>
                <p>
                  Prueba con palabras clave más generales o usa los filtros.
                </p>
              </div>
            )}
          </div>
        )
      }
    </div>
  </main>
</Layout>

<style>
  .search-page-container {
    padding: 0;
    max-width: 1600px;
    margin: 0 auto;
    position: relative;
  }

  .ambient-glow {
    position: absolute;
    top: -10%;
    left: 50%;
    transform: translateX(-50%);
    width: 100%;
    max-width: 1000px;
    height: 600px;
    background: radial-gradient(
      circle,
      rgba(0, 191, 255, 0.1) 0%,
      transparent 70%
    );
    filter: blur(80px);
    z-index: 0;
    pointer-events: none;
  }

  .search-hero {
    position: relative;
    z-index: 10;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding-top: 5rem;
    margin-bottom: 4rem;
    text-align: center;
  }

  .page-title {
    font-size: 3.5rem;
    font-weight: 950;
    color: #fff;
    letter-spacing: -0.02em;
    margin-bottom: 1rem;
  }

  .page-subtitle {
    color: #b0b0b0;
    font-size: 1.1rem;
    font-weight: 500;
    max-width: 600px;
    margin: 0 auto 3rem;
    text-shadow: 0 2px 10px rgba(0,0,0,0.3);
  }

  .gradient-peru {
    background: linear-gradient(
      to right,
      #d91023 0%,
      #ffffff 50%,
      #d91023 100%
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    filter: drop-shadow(0 0 10px rgba(217, 16, 35, 0.3));
  }

  .gradient-argentina {
    background: linear-gradient(
      to right,
      #74acdf 0%,
      #ffffff 30%,
      #f6b40e 50%,
      #ffffff 70%,
      #74acdf 100%
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    filter: drop-shadow(0 0 10px rgba(116, 172, 223, 0.3));
  }

  .search-interface-wrapper {
    width: 100%;
    max-width: 900px;
  }

  .search-and-filters-row {
    display: flex;
    gap: 1rem;
    align-items: stretch;
    width: 100%;
  }

  .search-bar-container {
    flex: 1;
    min-width: 0;
  }

  .input-wrapper {
    display: flex;
    align-items: center;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    padding: 0 1.5rem;
    height: 64px;
    border-radius: 20px;
    transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
  }

  .input-wrapper:focus-within {
    background: rgba(0, 0, 0, 0.4);
    border-color: var(--accent-color);
    box-shadow: 0 0 40px rgba(0, 191, 255, 0.15);
    transform: translateY(-2px);
  }

  .search-icon {
    color: #444;
    margin-right: 1rem;
    transition: color 0.3s;
  }
  .input-wrapper:focus-within .search-icon {
    color: var(--accent-color);
  }

  .search-input {
    flex: 1;
    background: transparent !important;
    border: none;
    color: #fff;
    font-size: 1.1rem;
    font-weight: 500;
    outline: none;
    height: 100%;
  }

  .clear-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    background: rgba(255, 255, 255, 0.05);
    color: #fff;
    border-radius: 50%;
    margin-left: 0.75rem;
    transition: all 0.2s;
  }
  .clear-btn:hover {
    background: rgba(255, 255, 255, 0.1);
    transform: scale(1.1);
  }

  .results-container {
    position: relative;
    z-index: 5;
  }

  /* Pagination Styles */
  .pagination-wrapper {
    margin-top: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    padding-bottom: 0rem;
  }

  .pagination-info {
    color: #666;
    font-size: 0.9rem;
    font-weight: 500;
  }

  .pagination-info .highlight {
    color: #aaa;
    font-weight: 700;
  }

  .pagination-controls {
    display: flex;
    align-items: center;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(10px);
    padding: 0.5rem;
    border-radius: 100px;
    gap: 0.5rem;
  }

  .pag-btn {
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.05);
    color: #fff;
    border-radius: 50%;
    transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }

  .pag-btn:hover:not(.disabled) {
    background: var(--accent-color);
    color: #000;
    transform: scale(1.1);
  }

  .pag-btn.disabled {
    opacity: 0.2;
    cursor: not-allowed;
    pointer-events: none;
  }

  .page-numbers {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0 1.5rem;
    font-weight: 800;
  }

  .current-page {
    color: var(--accent-color);
    font-size: 1.2rem;
  }

  .separator {
    color: #333;
    font-size: 0.8rem;
  }

  .total-pages {
    color: #666;
    font-size: 1rem;
  }

  /* Empty State Premium */
  .empty-state-wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 6rem 0;
    text-align: center;
  }

  .illustration-container {
    position: relative;
    margin-bottom: 2.5rem;
  }

  .circle {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    border-radius: 50%;
    border: 1px solid rgba(0, 191, 255, 0.1);
  }
  .c1 {
    width: 120px;
    height: 120px;
    animation: pulse-empty 4s infinite;
  }
  .c2 {
    width: 180px;
    height: 180px;
    animation: pulse-empty 4s infinite 1s;
  }

  @keyframes pulse-empty {
    0% {
      transform: translate(-50%, -50%) scale(0.8);
      opacity: 0;
    }
    50% {
      opacity: 0.5;
    }
    100% {
      transform: translate(-50%, -50%) scale(1.2);
      opacity: 0;
    }
  }

  .search-illustration {
    width: 80px;
    height: 80px;
    color: #222;
    position: relative;
    z-index: 2;
  }

  .empty-visual h3 {
    font-size: 1.8rem;
    font-weight: 800;
    color: #fff;
    margin-bottom: 0.75rem;
  }
  .empty-visual p {
    color: #555;
    font-size: 1rem;
  }

  .error-box-glass {
    background: rgba(255, 107, 107, 0.05);
    border: 1px solid rgba(255, 107, 107, 0.1);
    padding: 1.5rem 3rem;
    border-radius: 100px;
    color: #ff6b6b;
    font-weight: 700;
  }

  @media (max-width: 768px) {
    .page-title {
      font-size: 2.2rem;
    }
    .page-subtitle {
      font-size: 0.95rem;
    }
    .input-wrapper {
      height: 52px;
      padding: 0 1rem;
    }
    .search-input {
      font-size: 0.95rem;
    }
    .search-hero {
      padding-top: 3rem;
      margin-bottom: 2rem;
    }
  }

  @media (min-width: 1024px) {
    .search-page-container {
      padding: 0 4rem 0;
      max-width: 100%; /* Force full width override */
      width: 100%;
      margin: 0;
    }

    .search-hero {
      display: flex !important;
      flex-direction: column !important; /* Stack vertical */
      justify-content: center !important;
      align-items: center !important;
      text-align: center !important; /* Center text */
      padding-top: 2rem; /* Estándar ASTRA (antes 1rem) */
      margin-bottom: 4rem; /* Reduced from 6rem */
      gap: 2rem; /* Tighter gap between text and search bar */
      width: 100%;
      max-width: 1200px;
      margin-left: auto;
      margin-right: auto;
      z-index: 3000; /* Superar al Header (2000) para el modal */
    }

    .logo-area {
      flex: none;
      max-width: 800px;
    }

    .page-title {
      font-size: 3.5rem; /* Balanced Title */
      line-height: 1;
      margin-bottom: 1rem;
    }

    .page-subtitle {
      font-size: 1.1rem;
      margin: 0 auto;
      max-width: 600px;
      opacity: 0.85;
    }

    .search-interface-wrapper {
      flex: none;
      width: 100%;
      max-width: 850px; /* Optimal centered width */
    }

    .input-wrapper {
      height: 64px; /* Refined Input */
      border-radius: 20px;
      padding: 0 1.5rem;
      background: rgba(255, 255, 255, 0.05); /* Lighter glass */
      border: 1px solid rgba(255, 255, 255, 0.1);
    }

    .search-input {
      font-size: 1.1rem;
    }

    .search-icon {
      width: 24px;
      height: 24px;
      margin-right: 1rem;
    }

    /* Decorative Desktop Element */
    .search-hero::before {
      content: '';
      position: absolute;
      right: -10%;
      top: -20%;
      width: 600px;
      height: 600px;
      background: radial-gradient(
        circle,
        rgba(0, 191, 255, 0.08) 0%,
        transparent 70%
      );
      filter: blur(100px);
      z-index: -1;
      pointer-events: none;
    }
  }
</style>
