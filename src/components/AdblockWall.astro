<!-- src/components/AdblockWall.astro -->
<div id="adblock-wall" class="adblock-wall-overlay" style="display: none;">
  <div class="adblock-content-card">
    <div class="wall-header">
      <div class="wall-icon-container">
        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="shield-icon"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
      </div>
      <h2 id="wall-title">Bloqueador Detectado</h2>
    </div>
    
    <div class="wall-body">
      <p id="wall-message">
        Para seguir leyendo gratis, por favor desactiva tu <strong>bloqueador de anuncios</strong>. Los anuncios mantienen vivo este proyecto.
      </p>
      
      <div class="browser-tip">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="16" x2="12" y2="12"></line><line x1="12" y1="8" x2="12.01" y2="8"></line></svg>
        <p>Revisa también tus <span>DNS (AdGuard/NextDNS)</span>, VPN o el escudo del navegador.</p>
      </div>
    </div>

    <div class="wall-actions">
      <button id="verify-adblock-btn" class="btn-verify">
        VERIFICAR AHORA
      </button>
    </div>
  </div>
</div>

<!-- Astra: Elemento Cebo Invisible para Bloqueadores -->
<div id="tester-wrap" class="ad-unit ad-box ads-container pub_300x250 ads-banner" style="position: absolute; left: -9999px; top: -9999px; width: 1px; height: 1px; visibility: hidden; opacity: 0; pointer-events: none;">
  &nbsp;
</div>

<!-- Banner de aviso suave para la Home -->
<div id="adblock-toast" class="adblock-soft-toast" style="display: none;">
  <span class="toast-text">🛡️ Desactiva el Adblock para apoyar al Scan.</span>
  <button class="close-toast" onclick="document.getElementById('adblock-toast').style.display='none'">&times;</button>
</div>

<script>
  // Inicialización de variables globales de red
  window.isVignetteBlocked = window.isVignetteBlocked || false;
  window.isAdsterraBlocked = window.isAdsterraBlocked || false;
  window.isMonetagBlocked = window.isMonetagBlocked || false;

  let isAdblockDetected = false;
  const isReaderPage = window.location.pathname.includes('/series/') && window.location.pathname.split('/').filter(Boolean).length >= 3;

  async function checkAdBlock() {
    let suspicionScore = 0;

    const localCheck = await new Promise((resolve) => {
      const script = document.createElement('script');
      script.src = '/js/ads.js?' + Math.random().toString(36).substring(7);
      script.onload = () => {
        resolve(window.canRunAds ? false : true);
      };
      script.onerror = () => resolve(true);
      document.head.appendChild(script);
    });

    if (localCheck) suspicionScore += 2;

    // --- PRUEBA DE RED ACTIVA (NUEVO) ---
    const networkCheck = await fetch('https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js', { 
      method: 'HEAD', 
      mode: 'no-cors' 
    }).catch(() => null);
    
    if (networkCheck === null) {
      suspicionScore += 1; // El dominio de Google Ads está bloqueado
    }

    const staticBaitWrap = document.getElementById('tester-wrap');
    if (staticBaitWrap) {
        const styleWrap = window.getComputedStyle(staticBaitWrap);
        const isStaticBlocked = staticBaitWrap.offsetParent === null || staticBaitWrap.offsetHeight === 0 || styleWrap.display === 'none';
        if (isStaticBlocked) suspicionScore += 2;
    }

    let networkFailures = 0;
    if (window.isVignetteBlocked) networkFailures++;
    if (window.isAdsterraBlocked) networkFailures++;
    if (window.isMonetagBlocked) networkFailures++;

    if (networkFailures > 0) {
        suspicionScore += (networkFailures >= 2 ? 2 : 1);
    }

    return suspicionScore >= 2;
  }

  function showToast() {
    const toast = document.getElementById('adblock-toast');
    if (toast) toast.style.display = 'flex';
  }

  async function runDetection() {
    isAdblockDetected = await checkAdBlock();
    if (isAdblockDetected) {
      if (isReaderPage) {
        showWall(); // Llamamos a la función que activa el vigilante 60fps
      } else {
        showToast();
      }
    }
  }

  function showWall() {
    const wallId = 'adblock-wall';
    const wall = document.getElementById(wallId);
    if (!wall) {
        window.location.reload();
        return;
    }

    wall.style.display = 'flex';
    document.body.style.overflow = 'hidden';

    // --- DEFENSA NIVEL NUCLEAR (Versión Optimizada) ---
    let isBreached = false;
    const check = () => {
      if (isBreached) return;

      const el = document.getElementById(wallId);
      const style = el ? window.getComputedStyle(el) : null;
      
      const isGone = !el;
      const isHidden = style && (style.display === 'none' || style.visibility === 'hidden' || parseFloat(style.opacity) < 0.1);
      const isSmall = el && (el.offsetHeight < 10 || el.offsetWidth < 10);

      if (isGone || isHidden || isSmall) {
        isBreached = true;
        clearInterval(heartbeat); // Detenemos el intervalo
        document.body.innerHTML = `
          <div style="background:#000;color:#fff;height:100vh;display:flex;flex-direction:column;justify-content:center;align-items:center;text-align:center;font-family:sans-serif;padding:20px;">
            <h1 style="color:red;font-size:2rem;margin-bottom:1rem;">⚠️ ERROR DE INTEGRIDAD</h1>
            <p style="color:#aaa;margin-bottom:2rem;">Se ha detectado una manipulación de los sistemas de seguridad del sitio.</p>
            <button onclick="location.reload()" style="background:red;color:white;border:none;padding:12px 24px;border-radius:8px;cursor:pointer;font-weight:bold;font-size:1rem;">RECARGAR SITIO</button>
          </div>
        `;
        document.body.style.overflow = 'hidden';
        console.warn('Security system engaged.');
      }
    };
    
    // Chequeo cada 500ms: Suficiente para móviles y consume 0 batería
    const heartbeat = setInterval(check, 500);
  }

  window.addEventListener('load', () => { setTimeout(runDetection, 2000); });
  document.getElementById('verify-adblock-btn')?.addEventListener('click', () => { window.location.reload(); });
</script>

<style>
  .adblock-wall-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.9);
    z-index: 99999;
    display: flex;
    justify-content: center;
    align-items: center;
    backdrop-filter: blur(8px);
    padding: 1rem;
  }

  .adblock-content-card {
    background: linear-gradient(180deg, #111 0%, #080808 100%);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 32px;
    padding: 3rem 2.5rem;
    max-width: 440px;
    width: 100%;
    text-align: center;
    box-shadow: 0 30px 60px rgba(0,0,0,0.8);
    animation: cardAppear 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  @keyframes cardAppear {
    from { opacity: 0; transform: translateY(30px) scale(0.95); }
    to { opacity: 1; transform: translateY(0) scale(1); }
  }

  .wall-icon-container {
    background: radial-gradient(circle, rgba(0, 191, 255, 0.15) 0%, transparent 70%);
    width: 80px;
    height: 80px;
    border-radius: 24px;
    display: flex;
    justify-content: center;
    align-items: center;
    margin: 0 auto 1.5rem;
    color: var(--accent-color);
    border: 1px solid rgba(0, 191, 255, 0.2);
  }

  h2 {
    color: #fff;
    margin: 0 0 1rem;
    font-size: 1.8rem;
    font-weight: 800;
    letter-spacing: -0.02em;
  }

  .wall-body p {
    color: #888;
    line-height: 1.6;
    font-size: 1rem;
    margin-bottom: 2rem;
  }

  .wall-body strong { color: #fff; font-weight: 700; }

  .browser-tip {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    background: rgba(255, 255, 255, 0.03);
    padding: 0.8rem 1.25rem;
    border-radius: 16px;
    margin-bottom: 2.5rem;
    border: 1px solid rgba(255, 255, 255, 0.05);
  }

  .browser-tip p { margin: 0; font-size: 0.85rem; color: #aaa; }
  .browser-tip span { color: var(--accent-color); font-weight: 700; }
  .browser-tip svg { color: var(--accent-color); flex-shrink: 0; opacity: 0.8; }

  .btn-verify {
    background: #fff;
    color: #000;
    border: none;
    padding: 1.1rem;
    border-radius: 16px;
    font-weight: 900;
    font-size: 0.95rem;
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.23, 1, 0.32, 1);
    width: 100%;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    box-shadow: 0 10px 20px rgba(255, 255, 255, 0.1);
  }

  .btn-verify:hover { 
    transform: translateY(-3px); 
    box-shadow: 0 15px 30px rgba(255, 255, 255, 0.2);
    background: var(--accent-color);
  }

  /* Toast Compact */
  .adblock-soft-toast {
    position: fixed;
    bottom: 20px;
    right: 20px;
    background: #111;
    border: 1px solid #333;
    color: white;
    padding: 0.6rem 1rem;
    border-radius: 12px;
    z-index: 10000;
    display: flex;
    align-items: center;
    gap: 1rem;
    font-size: 0.85rem;
    box-shadow: 0 10px 20px rgba(0,0,0,0.4);
  }

  .close-toast {
    background: none;
    border: none;
    color: #666;
    cursor: pointer;
    font-size: 1.2rem;
    padding: 0;
  }
</style>