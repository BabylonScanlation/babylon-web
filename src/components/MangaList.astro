---
import LibraryCard from './LibraryCard.astro';
import type { Series } from '../types';

interface Props {
  mangas: Series[];
  title?: string;
}

const { mangas = [], title } = Astro.props;
---

<section class="manga-list-section">
  {title && <h2>{title}</h2>}
  <ul>
    {
      mangas && mangas.length > 0 ? (
        mangas.map((manga) => (
          <li>
            <LibraryCard manga={manga} />
          </li>
        ))
      ) : (
        <p>No hay mangas en la biblioteca.</p>
      )
    }
  </ul>
</section>

<style>
  /* ✅ CAMBIO: Eliminamos padding para que se ajuste al nuevo marco */
  .manga-list-section {
    padding: 0;
  }
  h2 {
    font-size: 1.8rem;
    margin-bottom: 1.5rem;
    color: #eee;
    padding-bottom: 0.5rem;
    max-width: 1200px;
    margin-left: auto;
    margin-right: auto;
  }
  ul {
    list-style: none;
    padding: 0;
    display: grid;
    /* Astra: Diseño Mobile-First (2 columnas por defecto) */
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
    margin-bottom: 3rem;
  }

  /* Tablet: Grilla fluida intermedia */
  @media (min-width: 768px) {
    ul {
      grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
      gap: 2rem;
      margin-bottom: 5rem;
    }
  }

  /* PC: Grilla de Alta Densidad (Compacta y Responsiva al Ancho) */
  @media (min-width: 1024px) {
    ul {
      grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); /* Más columnas, tarjetas densas */
      gap: 1.5rem; /* Espacio más ajustado */
      max-width: 100%; /* Ocupar todo el contenedor padre */
    }
    
    h2 {
      font-size: 2.5rem; /* Título acorde a la escala PC */
      margin-bottom: 2rem;
      text-align: left; /* Alineación editorial */
      max-width: 100%;
    }
  }
  p {
    color: #aaa;
    font-style: italic;
  }
</style>
