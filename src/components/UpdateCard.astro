---
// src/components/UpdateCard.astro
import Image from './Image.astro';
import type { Series } from '../types';
import { timeAgo } from '../lib/utils';

interface Props {
  series: Series;
}

const { series } = Astro.props;

// Astra: Normalizamos el acceso a los capítulos recientes (ya vienen agrupados por Orion)
const recentChapters = (series as any).recentChapters || [];
---

<div class="premium-update-card-wrapper">
  <div class="premium-update-card-inner">
    <!-- El link principal a la serie -->
    <a href={`/series/${series.slug}`} class="cover-link">
      <div class="art-box">
        <Image
          src={series.coverImageUrl || ''}
          alt={series.title}
          width={400}
          height={600}
          loading="lazy"
          class="main-cover"
        />
        <div class="glass-gradient-overlay"></div>
      </div>
    </a>

    <div class="card-info-overlay">
      <a href={`/series/${series.slug}`} class="series-title-link">
        <h3 class="series-name-title">{series.title}</h3>
      </a>
      
      <div class="recent-chapters-stack">
        {
          recentChapters.map((chapter: any) => (
            <a href={`/series/${series.slug}/${chapter.number}`} class="chapter-pill" data-astro-prefetch="false">
              <div class="pill-left">
                <span class="chap-badge">CAP {chapter.number}</span>
              </div>
              <div class="pill-right">
                <span class="time-text">{timeAgo(chapter.createdAt)}</span>
              </div>
            </a>
          ))
        }
        {recentChapters.length === 0 && (
          <div class="no-chapters-msg">Próximamente</div>
        )}
      </div>
    </div>
  </div>
</div>

<style>
  /* Wrapper Estático: Ocupa el espacio en el grid */
  .premium-update-card-wrapper {
    position: relative;
    width: 100%;
    aspect-ratio: 2 / 3;
    z-index: 1;
    /* No se mueve */
  }

  /* Inner Dinámico: Se anima */
  .premium-update-card-inner {
    position: relative;
    width: 100%;
    height: 100%;
    border-radius: 24px;
    overflow: hidden;
    background: #111;
    border: 1px solid rgba(255, 255, 255, 0.05);
    transition: all 0.4s cubic-bezier(0.25, 0.8, 0.25, 1);
    isolation: isolate;
    will-change: transform;
  }

  /* Trigger en Wrapper -> Efecto en Inner */
  .premium-update-card-wrapper:hover .premium-update-card-inner {
    transform: translateY(-10px) scale(1.02);
    border-color: var(--accent-color);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.6);
  }

  .cover-link {
    position: absolute;
    inset: 0;
    z-index: 0;
    text-decoration: none;
    color: inherit;
  }

  .art-box {
    width: 100%;
    height: 100%;
  }

  .main-cover {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.8s cubic-bezier(0.25, 0.8, 0.25, 1);
  }

  .premium-update-card-wrapper:hover .main-cover {
    transform: scale(1.1);
  }

  .glass-gradient-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.98) 0%,
      rgba(0, 0, 0, 0.6) 40%,
      transparent 100%
    );
  }

  .card-info-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 1.25rem;
    z-index: 5;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    pointer-events: none; /* Let links inside pass clicks */
  }

  .series-title-link {
    text-decoration: none;
    pointer-events: auto;
  }

  .series-name-title {
    font-size: 1.1rem;
    font-weight: 900;
    color: #fff;
    margin: 0;
    line-height: 1.2;
    text-shadow: 0 2px 10px rgba(0,0,0,0.8);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .recent-chapters-stack {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    pointer-events: auto;
  }

  .chapter-pill {
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: rgba(255, 255, 255, 0.03);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.08);
    padding: 8px 12px;
    border-radius: 12px;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .chapter-pill:hover {
    background: var(--accent-color);
    border-color: var(--accent-color);
    transform: translateX(5px);
  }

  .chap-badge {
    font-size: 0.75rem;
    font-weight: 900;
    color: var(--accent-color);
    letter-spacing: 0.05em;
    transition: color 0.3s;
  }

  .chapter-pill:hover .chap-badge {
    color: #000;
  }

  .time-text {
    font-size: 0.65rem;
    font-weight: 700;
    color: #666;
    text-transform: uppercase;
    transition: color 0.3s;
  }

  .chapter-pill:hover .time-text {
    color: rgba(0, 0, 0, 0.6);
  }

  .no-chapters-msg {
    font-size: 0.75rem;
    color: #444;
    font-weight: 800;
    text-transform: uppercase;
    text-align: center;
    padding: 0.5rem;
  }

  @media (max-width: 768px) {
    .card-info-overlay { padding: 1rem; gap: 0.5rem; }
    .series-name-title { font-size: 0.95rem; }
    .chapter-pill { padding: 6px 10px; border-radius: 10px; }
    .chap-badge { font-size: 0.7rem; }
    .time-text { display: none; } /* Hide time on small mobile cards to save space */
  }
</style>