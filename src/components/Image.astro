---
// src/components/Image.astro
// Astra: Componente de imagen responsivo y blindado contra desbordamientos.

import { obfuscate } from '../lib/obfuscator';

interface Props {
  src: string;
  alt: string;
  class?: string;
  fetchpriority?: 'high' | 'low' | 'auto';
  width?: number;
  height?: number;
  style?: string;
  eager?: boolean;
  loading?: 'lazy' | 'eager';
  forceLazy?: boolean;
}

const {
  src,
  alt,
  class: className = '',
  fetchpriority = 'auto',
  width = 300,
  height = 450,
  style = '',
  eager = false,
  loading: propLoading,
  forceLazy = false,
} = Astro.props;

// Astra: Si propLoading es 'eager', forzamos eager. Si forceLazy es true, forzamos lazy.
const isEager = (propLoading === 'eager' || eager) && !forceLazy;
const finalLoading = isEager ? 'eager' : 'lazy';

const keyToEncrypt = src.startsWith('http') ? src : src.replace(/^\//, '');
const salt = Astro.locals.runtime.env.INTERNAL_CRYPTO_SALT;
if (!salt) throw new Error('[SECURITY] INTERNAL_CRYPTO_SALT is not configured');
const encryptedKey = obfuscate(keyToEncrypt, salt);

// Orion: URL para el cargador nativo del navegador (Sin Waterfall de JS)
const proxyUrl = `/api/assets/proxy/${encryptedKey}?w=${width}&q=60&fmt=webp`;
---

<div
  class={`image-protected-container ${className}`}
  style={`
    width: 100%;
    height: 100%;
    aspect-ratio: ${width} / ${height};
    position: relative;
    overflow: hidden;
    background: rgba(255,255,255,0.03);
    ${style}
  `}
>
  <img
    src={isEager ? proxyUrl : "data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///yH5BAEAAAAALAAAAAABAAEAAAIBRAA7"}
    data-src={!isEager ? proxyUrl : undefined}
    alt={alt}
    loading={finalLoading}
    width={width}
    height={height}
    fetchpriority={fetchpriority}
    class:list={["protected-img", { "lazy-img": !isEager }]}
    style={`width:100%; height:100%; object-fit:cover; display:block; user-select:none; -webkit-user-drag:none; opacity: ${isEager ? '1' : '0'}; transition: opacity 0.5s ease-in-out;`}
  />
  <div class="shield-overlay" style="position: absolute; inset: 0; z-index: 20; background: transparent;"></div>
</div>

<style is:inline>
  /* Astra: Estilos para el nuevo componente blindado */
  .image-protected-container {
    transition: opacity 0.4s ease;
    border-radius: inherit;
  }

  .protected-img {
    transition: opacity 0.5s ease-in-out;
  }

  /* Fade-in suave para imágenes cargadas */
  .protected-img[loading="lazy"] {
    opacity: 0;
  }

  .protected-img.loaded {
    opacity: 1;
  }
</style>
