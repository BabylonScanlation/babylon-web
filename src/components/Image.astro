---
// src/components/Image.astro
// Astra: Componente de imagen responsivo y blindado contra desbordamientos.

import { obfuscate } from '../lib/obfuscator';

interface Props {
  src: string;
  alt: string;
  class?: string;
  loading?: 'lazy' | 'eager';
  fetchpriority?: 'high' | 'low' | 'auto';
  width?: number;
  height?: number;
  style?: string;
  forceLazy?: boolean;
}

const {
  src,
  alt,
  class: className = '',
  loading = 'lazy',
  fetchpriority = 'auto',
  width = 300,
  height = 450,
  style = '',
  forceLazy = false,
} = Astro.props;

const { runtime } = Astro.locals;

function buildProtectedUrl(inputSrc: string) {
  if (!inputSrc) return '';
  
  // Orion: Si ya tiene el formato webp de protección, lo dejamos
  if (inputSrc.includes('fmt=webp') && inputSrc.startsWith('/api/')) return inputSrc;

  // Orion: Cifrado de ruta para TODO (Interno y Externo)
  // Limpiamos la ruta si es interna, o usamos la URL completa si es externa
  const keyToEncrypt = inputSrc.startsWith('http') ? inputSrc : inputSrc.replace(/^\//, '');
  const encryptedKey = obfuscate(keyToEncrypt);
  
  return `/api/assets/proxy/${encryptedKey}?w=300&q=60&fmt=webp`;
}

const finalUrl = buildProtectedUrl(src);
const isGhost = loading === 'lazy' || forceLazy;

// Astra: Construimos la clase manualmente para evitar errores de tipo en Astro
const finalClass = `${className} ${isGhost ? 'lazy-ghost' : ''}`.trim();
---

<img
  src={isGhost ? 'data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///yH5BAEAAAAALAAAAAABAAEAAAIBRAA7' : finalUrl}
  data-src={isGhost ? finalUrl : undefined}
  alt={alt}
  class={finalClass}
  loading={loading}
  fetchpriority={fetchpriority}
  decoding="async"
  width={width}
  height={height}
  style={`width: 100%; height: 100%; aspect-ratio: ${width} / ${height}; object-fit: cover; display: block; ${style}`}
/>
