---
// src/components/Image.astro
// Astra: Componente de imagen responsivo y blindado contra desbordamientos.

import { obfuscate } from '../lib/obfuscator';

interface Props {
  src: string;
  alt: string;
  class?: string;
  loading?: 'lazy' | 'eager';
  fetchpriority?: 'high' | 'low' | 'auto';
  width?: number;
  height?: number;
  style?: string;
  forceLazy?: boolean;
}

const {
  src,
  alt,
  class: className = '',
  loading = 'lazy',
  width = 300,
  height = 450,
  style = '',
  forceLazy = false,
} = Astro.props;

// Astra Orion: Construcción de la clase manualmente para evitar errores de tipo en Astro
const isGhost = loading === 'lazy' || forceLazy;
const finalClass = `${className} ${isGhost ? 'lazy-ghost' : ''}`.trim();

// Astra Orion: Generación de la KEY cifrada (Base64) para el cargador ofuscado
const keyToEncrypt = src.startsWith('http') ? src : src.replace(/^\//, '');
const salt = Astro.locals.runtime.env.INTERNAL_CRYPTO_SALT;
if (!salt) throw new Error('[SECURITY] INTERNAL_CRYPTO_SALT is not configured');
const encryptedKey = obfuscate(keyToEncrypt, salt);
const ghostKey = Buffer.from(encryptedKey).toString('base64');
---

<div
  role="img"
  aria-label={alt}
  class={`image-protected-container ${finalClass}`}
  data-ghost-key={ghostKey}
  style={`
    width: 100%;
    height: 100%;
    aspect-ratio: ${width} / ${height};
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    display: block;
    position: relative;
    user-select: none;
    pointer-events: none;
    ${style}
  `}
>
  <div class="shield-overlay" style="position: absolute; inset: 0; z-index: 20; background: transparent;"></div>
</div>

<style is:global>
  /* Astra: Estilos para el nuevo componente blindado */
  .image-protected-container {
    transition: opacity 0.4s ease;
    background-color: rgba(255, 255, 255, 0.05);
  }

  .image-protected-container.lazy-ghost {
    background-color: rgba(255, 255, 255, 0.03);
  }

  /* Evitar que puedan arrastrar el contenedor */
  .image-protected-container * {
    -webkit-user-drag: none;
    -khtml-user-drag: none;
    -moz-user-drag: none;
    -o-user-drag: none;
    user-drag: none;
  }
</style>
