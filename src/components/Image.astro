---
// src/components/Image.astro
// Astra: Componente de imagen responsivo y blindado contra desbordamientos.

interface Props {
  src: string;
  alt: string;
  class?: string;
  loading?: 'lazy' | 'eager';
  fetchpriority?: 'high' | 'low' | 'auto';
  width?: number;
  height?: number;
  style?: string;
  forceLazy?: boolean;
}

const { 
  src, alt, class: className = '', 
  loading = 'lazy', 
  fetchpriority = 'auto', 
  width = 300, height = 450, 
  style = '',
  forceLazy = false
} = Astro.props;

const { runtime } = Astro.locals;
const r2Base = runtime?.env?.R2_PUBLIC_URL_ASSETS || '/api/assets/proxy';

function buildFinalUrl(inputSrc: string) {
  if (!inputSrc) return '';
  if (inputSrc.includes('fmt=webp')) return inputSrc;
  const base = r2Base.replace(/\/$/, '');
  const path = inputSrc.startsWith('/') ? inputSrc : `/${inputSrc}`;
  const url = inputSrc.startsWith('http') ? inputSrc : `${base}${path}`;
  return `${url}${url.includes('?') ? '&' : '?'}w=300&q=60&fmt=webp`;
}

const finalUrl = buildFinalUrl(src);
const isGhost = forceLazy && loading !== 'eager';

// Astra: Construimos la clase manualmente para evitar errores de tipo en Astro
const finalClass = `${className} ${isGhost ? 'lazy-ghost' : ''}`.trim();
---

<img
  src={isGhost ? 'data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///yH5BAEAAAAALAAAAAABAAEAAAIBRAA7' : finalUrl}
  data-src={isGhost ? finalUrl : undefined}
  alt={alt}
  class={finalClass}
  loading={loading}
  fetchpriority={fetchpriority}
  decoding="async"
  width={width}
  height={height}
  style={`width: 100%; height: 100%; aspect-ratio: ${width} / ${height}; object-fit: cover; display: block; ${style}`}
/>
