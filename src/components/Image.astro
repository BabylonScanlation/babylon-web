---
// src/components/Image.astro
// VERSIÓN FINAL CORREGIDA

interface Props {
  src: string;
  alt: string;
  class?: string;
  loading?: 'lazy' | 'eager';
  fetchpriority?: 'high' | 'low' | 'auto';
  width: number;
  height: number;
  [key: string]: any;
}

const { src, alt, class: className, loading = 'lazy', fetchpriority = 'auto', width, height, ...rest } = Astro.props;

const { runtime } = Astro.locals;
const r2Base = runtime?.env?.R2_PUBLIC_URL_ASSETS || '/api/assets/proxy';

// Normalización de la URL: Si es relativa y no empieza por /, le ponemos el prefijo de R2
let finalSrc = src;
if (src && !src.startsWith('http') && !src.startsWith('/')) {
  finalSrc = `${r2Base}/${src}`.replace(/([^:]\/)\/+/g, '$1');
  
  // Astra: Añadir parámetros de optimización si tenemos el ancho
  if (width) {
    const separator = finalSrc.includes('?') ? '&' : '?';
    finalSrc = `${finalSrc}${separator}w=${width}&q=60`;
  }
}
---

<img
  src={finalSrc}
  alt={alt}
  class:list={['img-skeleton', className]}
  loading={loading}
  fetchpriority={fetchpriority}
  decoding="async"
  width={width}
  height={height}
  {...rest}
  style={`width: 100%; height: 100%; aspect-ratio: ${width} / ${height}; object-fit: cover; display: block; ${rest.style || ''}`}
  onload="this.classList.remove('img-skeleton')"
/>

<style>
  .img-skeleton {
    background: linear-gradient(
      110deg,
      rgba(255, 255, 255, 0.03) 8%,
      rgba(255, 255, 255, 0.08) 18%,
      rgba(255, 255, 255, 0.03) 33%
    );
    background-size: 200% 100%;
    animation: skeleton-shine 1.5s linear infinite;
  }

  @keyframes skeleton-shine {
    to {
      background-position-x: -200%;
    }
  }
</style>
