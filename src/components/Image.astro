---
// src/components/Image.astro
// Astra: Componente híbrido. Usa src real para el Hero y data-src para el resto.

interface Props {
  src: string;
  alt: string;
  class?: string;
  loading?: 'lazy' | 'eager';
  fetchpriority?: 'high' | 'low' | 'auto';
  width?: number;
  height?: number;
  style?: string;
  // Si es true, la imagen no cargará hasta que el scroll llegue (Zona Fantasma)
  forceLazy?: boolean;
}

const { 
  src, alt, class: className, 
  loading = 'lazy', 
  fetchpriority = 'auto', 
  width = 300, height = 450, 
  style = '',
  forceLazy = false
} = Astro.props;

const { runtime } = Astro.locals;
const r2Base = runtime?.env?.R2_PUBLIC_URL_ASSETS || '/api/assets/proxy';

function buildFinalUrl(inputSrc: string) {
  if (!inputSrc) return '';
  if (inputSrc.includes('fmt=webp')) return inputSrc;
  const base = r2Base.replace(/\/$/, '');
  const path = inputSrc.startsWith('/') ? inputSrc : `/${inputSrc}`;
  const url = inputSrc.startsWith('http') ? inputSrc : `${base}${path}`;
  return `${url}${url.includes('?') ? '&' : '?'}w=300&q=60&fmt=webp`;
}

const finalUrl = buildFinalUrl(src);
// Una imagen es "Ghost" si forzamos el lazy y no es crítica
const isGhost = forceLazy && loading !== 'eager';
---

<img
  src={isGhost ? 'data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///yH5BAEAAAAALAAAAAABAAEAAAIBRAA7' : finalUrl}
  data-src={isGhost ? finalUrl : undefined}
  alt={alt}
  class:list={[className, { 'lazy-ghost': isGhost }]}
  loading={loading}
  fetchpriority={fetchpriority}
  decoding="async"
  width={width}
  height={height}
  style={`aspect-ratio: ${width} / ${height}; object-fit: cover; display: block; ${style}`}
/>
