---
import { count, desc, eq, sql } from 'drizzle-orm';
import { news, users } from '../db/schema';
import { siteConfig } from '../site.config';
import NewsCounter from './NewsCounter.svelte';

const { user, db, runtime } = Astro.locals;

// Orion: Sistema de Noticias encapsulado (La cuenta manda sobre el navegador)
let lastSeenId: string | null = null;
const isNsfwActive = Astro.cookies.get('babylon_nsfw')?.value === 'true';

if (user) {
  try {
    let prefs = (user as any).preferences;

    // Si las preferencias no están en locals (JWT path), intentamos un fetch rápido de DB
    if (!prefs && db) {
      const dbUser = await db.select({ preferences: users.preferences }).from(users).where(eq(users.id, user.uid)).get();        
      prefs = dbUser?.preferences;
    }

    const parsedPrefs = typeof prefs === 'string' ? JSON.parse(prefs) : (prefs || {});
    lastSeenId = parsedPrefs?.lastSeenNewsId || null;
  } catch (e) {
    console.error('[Header Prefs Error]:', e);
    lastSeenId = null;
  }
} else {
  lastSeenId = Astro.cookies.get('last_news_id')?.value || null;
}

// Orion: Limpieza de valores nulos/undefined en string
if (lastSeenId === 'undefined' || lastSeenId === 'null' || !lastSeenId) {
  lastSeenId = null;
}
let unreadNewsCount = 0;
if (db) {
  try {
    if (!lastSeenId) {
      const result = await db
        .select({ total: count() })
        .from(news)
        .where(eq(news.status, 'published'))
        .get();
      unreadNewsCount = result?.total ?? 0;
    } else {
      const latestNews = await db
        .select({ id: news.id })
        .from(news)
        .where(eq(news.status, 'published'))
        .orderBy(desc(sql`CAST(${news.createdAt} AS INTEGER)`))
        .limit(50)
        .all();

      if (latestNews && latestNews.length > 0) {
        const lastSeenIdStr = String(lastSeenId).trim();
        const lastSeenIndex = latestNews.findIndex((n) => String(n.id).trim() === lastSeenIdStr);
        
        if (lastSeenIndex === -1) {
          const result = await db
            .select({ total: count() })
            .from(news)
            .where(eq(news.status, 'published'))
            .get();
          unreadNewsCount = result?.total ?? 0;
        } else {
          unreadNewsCount = lastSeenIndex;
        }
      }
    }
  } catch (e) {
    console.error('[Header News Error]:', e);
  }
}

const r2PublicUrlAssets = runtime.env.R2_PUBLIC_URL_ASSETS || '/api/assets/proxy';
---

<header class:list={['site-header', { 'nsfw-active': isNsfwActive }]} id="main-header">
  <script is:inline>
    // Astra: Aplicar modo NSFW instantáneamente en el cliente, respetando si la página forzó el estado en el HTML
    (function() {
      // Si el HTML tiene explícitamente nsfw-mode (forzado por el Layout), el header debe coincidir
      const htmlHasMode = document.documentElement.classList.contains('nsfw-mode');
      const isNsfwCookie = document.cookie.split(';').some(c => c.trim().startsWith('babylon_nsfw=true'));
      
      // Si estamos en una página que fuerza NO ser roja (ej. serie SFW), no pintamos el header de rojo
      if (isNsfwCookie || htmlHasMode) {
        document.getElementById('main-header')?.classList.add('nsfw-active');
      }
    })();
  </script>
  <div class="header-container">
    <div class="logo-section">
      <a href="/" class="logo-link" id="header-logo-toggle">
        <img
          src={siteConfig.assets.logoHeader.startsWith('/') ? `${r2PublicUrlAssets}${siteConfig.assets.logoHeader}` : siteConfig.assets.logoHeader}
          alt={`${siteConfig.name} Logo`}
          class="header-logo"
        />
      </a>
    </div>

    <nav class="desktop-nav">
      <div class="main-nav-links">
        <a href="/" class="nav-link-pc"><span>INICIO</span></a>
        <a href="/search" class="nav-link-pc"><span>EXPLORAR</span></a>
        <a href="/news" class="nav-link-pc news-link">
          <span>NOTICIAS</span>
          <NewsCounter client:load initialCount={unreadNewsCount} />
        </a>
        <a href="/library" class="nav-link-pc"><span>BIBLIOTECA</span></a>
      </div>

      <div class="user-actions">
        <a
          href={user ? '/profile' : '#'}
          class="nav-link-pc profile-link"
          data-open-modal={!user ? 'login' : undefined}
          onclick={!user ? "event.preventDefault(); window.dispatchEvent(new CustomEvent('open-auth-modal', { detail: { view: 'login' } }))" : undefined}
        >
          <span>PERFIL</span>
        </a>
      </div>
    </nav>
  </div>
</header>

<script>
  import { actions } from 'astro:actions';

  let headerObserver: MutationObserver | null = null;

  function initHeader() {
    const header = document.querySelector('.site-header') as HTMLElement;
    const logoToggle = document.getElementById('header-logo-toggle');
    
    if (!header || !logoToggle) return;

    // Orion: Limpiar observador previo
    if (headerObserver) headerObserver.disconnect();

    headerObserver = new MutationObserver(() => {
      const isModalOpen = document.body.getAttribute('data-reader-modal') === 'open' || 
                          document.body.classList.contains('modal-open');
      header.style.opacity = isModalOpen ? '0' : '';
      header.style.pointerEvents = isModalOpen ? 'none' : '';
      header.style.zIndex = isModalOpen ? '-1' : '5000';
    });

    headerObserver.observe(document.body, { attributes: true, attributeFilter: ['data-reader-modal', 'class'] });

    // Astra: NSFW Toggle sincronizado vía Actions
    let isToggling = false;
    logoToggle.onclick = async (e) => {
      if (isToggling) return;
      isToggling = true;

      e.preventDefault();
      e.stopPropagation();
      
      // Feedback visual inmediato
      (logoToggle as HTMLElement).style.opacity = '0.5';
      
      try {
        // Orion: Cambiar estado en el servidor (100% fiable)
        const { data, error } = await actions.ui.toggleNsfw();
        
        if (!error && data?.success) {
          // Aplicar clases localmente antes de recargar
          if (data.newValue) {
            header.classList.add('nsfw-active');
            document.documentElement.classList.add('nsfw-mode');
          } else {
            header.classList.remove('nsfw-active');
            document.documentElement.classList.remove('nsfw-mode');
          }
          
          // Forzar navegación limpia
          window.location.assign('/'); 
        }
      } catch (err) {
        console.error('[NSFW Toggle Error]:', err);
        isToggling = false;
        (logoToggle as HTMLElement).style.opacity = '';
      }
    };
  }

  // Inicializar
  initHeader();
  document.addEventListener('astro:page-load', initHeader);
</script>

<style>
  .news-link {
    position: relative;
    overflow: visible !important; /* Vital para que el badge no se corte */
  }

  .news-badge-dot {
    position: absolute;
    top: -8px;
    right: -12px;
    background: #ff4444;
    color: white;
    font-size: 0.6rem;
    font-weight: 900;
    min-width: 16px;
    height: 16px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2px;
    box-shadow: 0 0 10px rgba(255, 68, 68, 0.5);
    border: 2px solid #050505;
    z-index: 10;
  }

  .news-badge-dot.hidden {
    display: none;
  }

  /* --- MUNDO PC: Diseño de Escritorio (No te sigue al scrollear) --- */
  @media (min-width: 1024px) {
    .site-header {
      width: 100%;
      position: absolute; /* Astra: Se queda anclado arriba de la página */
      top: 0;
      left: 0;
      z-index: 5000; /* Astra: Elevado para ser interactivo, pero debajo de modales */
      height: 90px; /* Astra: Incrementado para dar aire al logo de 60px */
      display: flex;
      align-items: center;
      background: transparent;
    }

    .header-container {
      width: 100%;
      max-width: 1600px;
      margin: 0 auto;
      padding: 0 3rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .header-logo {
      height: 60px; /* Astra: Reducido para dar más aire y elegancia */
      filter: drop-shadow(0 0 25px var(--accent-glow));
    }

    .desktop-nav {
      display: flex;
      align-items: center;
      gap: 2rem; /* Espacio entre navegación y perfil */
    }

    .main-nav-links {
      display: flex;
      gap: 2rem;
      align-items: center;
    }
    .nav-link-pc {
      color: #fff;
      font-weight: 800;
      font-size: 0.85rem;
      letter-spacing: 0.1em;
      opacity: 0.7;
      text-decoration: none;
      transition: opacity 0.2s;
      display: flex;
      align-items: center;
    }
    .nav-link-pc:hover {
      opacity: 1;
    }

    .user-actions {
      display: flex;
      align-items: center;
    }
  }

  /* --- MUNDO MÓVIL: Diseño de App (Se integra con el lector) --- */
  @media (max-width: 1023px) {
    .site-header {
      width: 100%;
      position: relative; /* Astra: Ahora ocupa espacio real y empuja el contenido */
      height: auto;
      min-height: 80px;
      background: #020205;
      display: flex;
      align-items: center;
      justify-content: center;
      z-index: 5000;
      transition: all 0.3s ease;
      padding: 15px 0;
    }

    /* Astra: Ocultar header totalmente si hay un modal abierto para liberar espacio */
    :global(body[data-reader-modal='open']) .site-header {
      display: none !important;
      z-index: -1 !important;
    }

    .header-container {
      display: flex;
      justify-content: center;
      padding: 0;
    }

    .header-logo {
      height: 80px; /* Astra: Recuperamos el tamaño premium */
      filter: drop-shadow(0 0 15px var(--accent-glow));
    }

    .desktop-nav {
      display: none !important;
    }
  }

  /* Astra: NSFW Mode Styles (Minimalist Ruby) */
  .site-header.nsfw-active {
    background: transparent !important;
    border-bottom: 1px solid rgba(255, 0, 0, 0.1);
  }

  .site-header.nsfw-active .logo-link {
    position: relative;
    display: inline-flex;
  }

  .site-header.nsfw-active .header-logo {
    filter: drop-shadow(0 0 15px rgba(255, 0, 0, 0.3)) !important;
  }

  .logo-link:active {
    transform: scale(0.9);
  }
  .site-header.nsfw-active .news-badge-dot {
    background: var(--accent-color);
    box-shadow: 0 0 10px var(--accent-glow);
  }
</style>
