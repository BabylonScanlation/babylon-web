---
import { siteConfig } from '../site.config';

const { user, runtime } = Astro.locals;
const isNsfwActive = Astro.cookies.get('babylon_nsfw')?.value === 'true';
const r2PublicUrlAssets =
  runtime.env.R2_PUBLIC_URL_ASSETS || '/api/assets/proxy';

const currentLogo = isNsfwActive
  ? siteConfig.assets.logoHeaderNsfw
  : siteConfig.assets.logoHeader;
const logoUrl = currentLogo.startsWith('/')
  ? `${r2PublicUrlAssets}${currentLogo}`
  : currentLogo;
---

<header
  class:list={['site-header', { 'nsfw-active': isNsfwActive }]}
  id="main-header"
>
  <script
    is:inline
    define:vars={{
      logoNormal: siteConfig.assets.logoHeader,
      logoNsfw: siteConfig.assets.logoHeaderNsfw,
      r2Url: r2PublicUrlAssets,
    }}
  >
    // Astra: Aplicar modo NSFW instantáneamente en el cliente, respetando estrictamente la cookie manual
    (function () {
      const isNsfwCookie = document.cookie
        .split(';')
        .some((c) => c.trim().startsWith('babylon_nsfw=true'));

      const header = document.getElementById('main-header');
      const logoImg = document.getElementById('header-logo-img');

      // Orion: Solo activamos el visual si el usuario lo pidió manualmente vía cookie
      if (isNsfwCookie) {
        header?.classList.add('nsfw-active');
        if (logoImg) {
          const newLogo = logoNsfw.startsWith('/')
            ? `${r2Url}${logoNsfw}`
            : logoNsfw;
          logoImg.src = newLogo;
        }
      }
    })();
  </script>
  <div class="header-container">
    <div class="logo-section">
      <!-- Astra: Badge +18 interactivo EXCLUSIVO para móviles (Ahora a la izquierda) -->
      <button
        id="nsfw-toggle-mobile"
        class:list={['nsfw-mobile-badge', { 'is-active': isNsfwActive }]}
      >
        <span>+18</span>
      </button>
      <a href="/" class="logo-link">
        <img
          src={logoUrl}
          alt={`${siteConfig.name} Logo`}
          class="header-logo"
          id="header-logo-img"
        />
      </a>
    </div>

    <script>
      import { actions } from 'astro:actions';

      const setupToggle = (id) => {
        const btn = document.getElementById(id);
        if (btn) {
          btn.addEventListener('click', async (e) => {
            e.preventDefault();
            btn.classList.add('loading');
            try {
              const { data } = await actions.ui.toggleNsfw();
              if (data?.success) window.location.reload();
            } catch (err) {
              console.error('Error:', err);
            } finally {
              btn.classList.remove('loading');
            }
          });
        }
      };

      setupToggle('nsfw-toggle-btn'); // Desktop
      setupToggle('nsfw-toggle-mobile'); // Mobile
    </script>

    <nav class="desktop-nav">
      <div class="main-nav-links">
        <a href="/" class="nav-link-pc"><span>INICIO</span></a>
        <a href="/search" class="nav-link-pc"><span>EXPLORAR</span></a>
        <!-- Astra: Restaurado botón original en PC -->
        <button
          id="nsfw-toggle-btn"
          class:list={['nav-link-pc nsfw-link', { 'is-active': isNsfwActive }]}
        >
          <span>ZONA +18</span>
        </button>
        <a href="/news" class="nav-link-pc news-link">
          <span>NOTICIAS</span>
          <span data-news-badge class="news-badge-pc hidden">0</span>
        </a>
        <a href="/library" class="nav-link-pc"><span>BIBLIOTECA</span></a>
      </div>

      <div class="user-actions">
        <a
          href={user ? '/profile' : '#'}
          class="nav-link-pc profile-link"
          data-open-modal={!user ? 'login' : undefined}
          onclick={!user
            ? "event.preventDefault(); window.dispatchEvent(new CustomEvent('open-auth-modal', { detail: { view: 'login' } }))"
            : undefined}
        >
          <span>PERFIL</span>
        </a>
      </div>
    </nav>
  </div>
</header>

<style is:global>
  .logo-section {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }

  /* Astra: Estilo original para PC */
  .nsfw-link {
    all: unset;
    cursor: pointer;
    display: flex;
    align-items: center;
  }
  .nsfw-link span {
    color: #fff;
    opacity: 0.7;
    font-weight: 800;
    font-size: 0.85rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    transition: opacity 0.2s ease;
  }
  .nsfw-link.is-active span {
    color: #ff003c !important;
    opacity: 1 !important;
  }

  /* Astra: Badge Móvil (ESTRICTAMENTE OCULTO EN PC) */
  .nsfw-mobile-badge {
    display: none !important;
  }

  @media (max-width: 1024px) {
    .nsfw-link {
      display: none !important;
    }

    .nsfw-mobile-badge {
      display: flex !important;
      all: unset;
      cursor: pointer;
      background: rgba(255, 0, 60, 0.05);
      border: 2px solid rgba(255, 255, 255, 0.3);
      border-radius: 8px;
      padding: 8px 14px;
      line-height: 1;
      transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .nsfw-mobile-badge span {
      color: rgba(255, 255, 255, 0.9);
      font-size: 14px;
      font-weight: 900;
      letter-spacing: 0.05em;
      white-space: nowrap;
    }

    .nsfw-mobile-badge.is-active {
      background: rgba(255, 0, 60, 0.15);
      border-color: #ff003c;
      box-shadow: 0 0 10px rgba(255, 0, 60, 0.3);
    }

    .nsfw-mobile-badge.is-active span {
      color: #ff003c;
    }
  }

  /* Astra: Centrado total del LOGO en móviles con Grid de 3 columnas (Badge a la IZQUIERDA) */
  @media (max-width: 768px) {
    .header-container {
      width: 100%;
      padding: 0.5rem 0;
    }

    .logo-section {
      display: grid !important;
      grid-template-columns: 1fr auto 1fr;
      width: 100%;
      align-items: center;
      gap: 0;
    }

    /* El botón se posiciona en la PRIMERA columna, pegado a la izquierda */
    .nsfw-mobile-badge {
      justify-self: start;
      margin-left: 1.8rem; /* Astra: Movido un poco más a la derecha */
    }

    .logo-link {
      display: flex;
      justify-content: center;
    }

    /* Columna derecha vacía para equilibrar el Grid y centrar el logo */
    .logo-section::after {
      content: '';
      display: block;
    }

    .desktop-nav {
      display: none;
    }
  }
</style>
