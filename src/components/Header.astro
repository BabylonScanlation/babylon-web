---
import { siteConfig } from '../site.config';
const { user, runtime } = Astro.locals;
const { unreadNewsCount = 0 } = Astro.props;
const r2PublicUrlAssets =
  runtime.env.R2_PUBLIC_URL_ASSETS || '/api/assets/proxy';
---

<header class="site-header">
  <div class="header-container">
    <div class="logo-section">
      <a href="/" class="logo-link">
        <img
          src={siteConfig.assets.logoHeader.startsWith('/') ? `${r2PublicUrlAssets}${siteConfig.assets.logoHeader}` : siteConfig.assets.logoHeader}
          alt={`${siteConfig.name} Logo`}
          class="header-logo"
        />
      </a>
    </div>

    <nav class="desktop-nav">
      <div class="main-nav-links">
        <a href="/" class="nav-link-pc"><span>INICIO</span></a>
        <a href="/search" class="nav-link-pc"><span>EXPLORAR</span></a>
        <a href="/news" class="nav-link-pc news-link">
          <span>NOTICIAS</span>
          <span data-news-badge class={`news-badge-dot ${unreadNewsCount > 0 ? '' : 'hidden'}`}>
            {unreadNewsCount > 9 ? '+9' : unreadNewsCount}
          </span>
        </a>
        <a href="/library" class="nav-link-pc"><span>BIBLIOTECA</span></a>
      </div>

      <div class="user-actions">
        <a
          href={user ? '/profile' : '#'}
          class="nav-link-pc profile-link"
          data-open-modal={!user ? 'login' : undefined}
          onclick={!user ? "event.preventDefault(); window.dispatchEvent(new CustomEvent('open-auth-modal', { detail: { view: 'login' } }))" : undefined}
        >
          <span>PERFIL</span>
        </a>
      </div>
    </nav>
  </div>
</header>

<script>
  let headerObserver: MutationObserver | null = null;

  document.addEventListener('astro:page-load', () => {
    const header = document.querySelector('.site-header') as HTMLElement;
    if (!header) return;

    // Orion: Limpiar observador previo si existe para evitar duplicados en el body
    if (headerObserver) {
      headerObserver.disconnect();
    }

    // Asegurar visibilidad inicial al navegar
    header.style.opacity = '';
    header.style.pointerEvents = '';
    header.style.zIndex = '5000';

    // Orion: Vigilante de modales (Garantía de limpieza visual)
    headerObserver = new MutationObserver(() => {
      const isModalOpen = document.body.getAttribute('data-reader-modal') === 'open' || 
                          document.body.classList.contains('modal-open');
      
      if (isModalOpen) {
        header.style.opacity = '0';
        header.style.pointerEvents = 'none';
        header.style.zIndex = '-1';
      } else {
        header.style.opacity = '';
        header.style.pointerEvents = '';
        header.style.zIndex = '5000';
      }
    });

    headerObserver.observe(document.body, { attributes: true, attributeFilter: ['data-reader-modal', 'class'] });
  });
</script>

<style>
  .news-link {
    position: relative;
  }

  .news-badge-dot {
    position: absolute;
    top: -8px;
    right: -12px;
    background: #ff4444;
    color: white;
    font-size: 0.6rem;
    font-weight: 900;
    min-width: 16px;
    height: 16px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2px;
    box-shadow: 0 0 10px rgba(255, 68, 68, 0.5);
    border: 2px solid #050505;
    z-index: 10;
  }

  .news-badge-dot.hidden {
    display: none;
  }

  /* --- MUNDO PC: Diseño de Escritorio (No te sigue al scrollear) --- */
  @media (min-width: 1024px) {
    .site-header {
      width: 100%;
      position: absolute; /* Astra: Se queda anclado arriba de la página */
      top: 0;
      left: 0;
      z-index: 5000; /* Astra: Elevado para ser interactivo, pero debajo de modales */
      height: 90px; /* Astra: Incrementado para dar aire al logo de 60px */
      display: flex;
      align-items: center;
      background: transparent;
    }

    .header-container {
      width: 100%;
      max-width: 1600px;
      margin: 0 auto;
      padding: 0 3rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .header-logo {
      height: 60px; /* Astra: Reducido para dar más aire y elegancia */
      filter: drop-shadow(0 0 25px var(--accent-glow));
    }

    .desktop-nav {
      display: flex;
      align-items: center;
      gap: 2rem; /* Espacio entre navegación y perfil */
    }

    .main-nav-links {
      display: flex;
      gap: 2rem;
      align-items: center;
    }
    .nav-link-pc {
      color: #fff;
      font-weight: 800;
      font-size: 0.85rem;
      letter-spacing: 0.1em;
      opacity: 0.7;
      text-decoration: none;
      transition: opacity 0.2s;
      display: flex;
      align-items: center;
    }
    .nav-link-pc:hover {
      opacity: 1;
    }

    .user-actions {
      display: flex;
      align-items: center;
    }
  }

  /* --- MUNDO MÓVIL: Diseño de App (Se integra con el lector) --- */
  @media (max-width: 1023px) {
    .site-header {
      width: 100%;
      position: relative; /* Astra: Ahora ocupa espacio real y empuja el contenido */
      height: auto;
      min-height: 80px;
      background: #020205;
      display: flex;
      align-items: center;
      justify-content: center;
      z-index: 5000;
      transition: all 0.3s ease;
      padding: 15px 0;
    }

    /* Astra: Ocultar header totalmente si hay un modal abierto para liberar espacio */
    :global(body[data-reader-modal='open']) .site-header {
      display: none !important;
      z-index: -1 !important;
    }

    .header-container {
      display: flex;
      justify-content: center;
      padding: 0;
    }

    .header-logo {
      height: 80px; /* Astra: Recuperamos el tamaño premium */
      filter: drop-shadow(0 0 15px var(--accent-glow));
    }

    .desktop-nav {
      display: none !important;
    }
  }
</style>
