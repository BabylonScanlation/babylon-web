---
import { siteConfig } from '../site.config';

const { user, runtime } = Astro.locals;
const isNsfwActive = Astro.cookies.get('babylon_nsfw')?.value === 'true';
const r2PublicUrlAssets = runtime.env.R2_PUBLIC_URL_ASSETS || '/api/assets/proxy';

const currentLogo = isNsfwActive ? siteConfig.assets.logoHeaderNsfw : siteConfig.assets.logoHeader;
const logoUrl = currentLogo.startsWith('/') ? `${r2PublicUrlAssets}${currentLogo}` : currentLogo;
---

<header
  class:list={['site-header', { 'nsfw-active': isNsfwActive }]}
  id="main-header"
>
  <div class="header-container">
    <div class="logo-section">
      <!-- Astra: Badge +18 interactivo EXCLUSIVO para móviles (Ahora a la izquierda) -->
      <button
        id="nsfw-toggle-mobile"
        class:list={['nsfw-mobile-badge', { 'is-active': isNsfwActive }]}
      >
        <span>+18</span>
      </button>
      <a href="/" class="logo-link">
        <img
          src={logoUrl}
          alt={`${siteConfig.name} Logo`}
          class="header-logo"
          id="header-logo-img"
        />
      </a>
    </div>

    <nav class="desktop-nav">
      <div class="main-nav-links">
        <a href="/" class="nav-link-pc"><span>INICIO</span></a>
        <a href="/search" class="nav-link-pc"><span>EXPLORAR</span></a>
        <!-- Astra: Restaurado botón original en PC -->
        <button
          id="nsfw-toggle-btn"
          class:list={['nav-link-pc nsfw-link', { 'is-active': isNsfwActive }]}
        >
          <span>ZONA +18</span>
        </button>
        <a href="/news" class="nav-link-pc news-link">
          <span>NOTICIAS</span>
          <!-- Astra: El badge se actualiza vía initAll en Layout.astro (JS Nativo) -->
          <span data-news-badge class="news-badge-pc hidden"></span>
        </a>
        <a href="/library" class="nav-link-pc"><span>BIBLIOTECA</span></a>
      </div>

      <div class="user-actions">
        <a
          href={user ? '/profile' : '#'}
          class="nav-link-pc profile-link"
          data-open-modal={!user ? 'login' : undefined}
          onclick={!user
            ? "event.preventDefault(); window.dispatchEvent(new CustomEvent('open-auth-modal', { detail: { view: 'login' } }))"
            : undefined}
        >
          <span>PERFIL</span>
        </a>
      </div>
    </nav>
  </div>
</header>

<style>
  @media (min-width: 1024px) {
    .site-header {
      width: 100%;
      position: absolute;
      top: 0;
      left: 0;
      z-index: 5000;
      height: 90px;
      display: flex;
      align-items: center;
      background: transparent;
    }

    .header-container {
      width: 100%;
      max-width: 1600px;
      margin: 0 auto;
      padding: 0 3rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .header-logo {
      height: 60px;
      filter: drop-shadow(0 0 25px var(--accent-glow));
    }

    .desktop-nav {
      display: flex;
      align-items: center;
      gap: 2rem;
    }

    .main-nav-links {
      display: flex;
      gap: 2rem;
      align-items: center;
    }
    .nav-link-pc {
      color: #fff;
      font-weight: 800;
      font-size: 0.85rem;
      letter-spacing: 0.1em;
      opacity: 0.7;
      text-decoration: none;
      transition: opacity 0.2s;
      display: flex;
      align-items: center;
    }
    .nav-link-pc:hover {
      opacity: 1;
    }

    .user-actions {
      display: flex;
      align-items: center;
    }
  }

  @media (max-width: 1023px) {
    .site-header {
      width: 100%;
      position: relative;
      height: auto;
      min-height: 80px;
      background: #020205;
      display: flex;
      align-items: center;
      justify-content: center;
      z-index: 5000;
      transition: all 0.3s ease;
      padding: 15px 0;
    }

    :global(body[data-reader-modal="open"]) .site-header {
      display: none !important;
      z-index: -1 !important;
    }

    .header-container {
      display: flex;
      justify-content: center;
      padding: 0;
    }

    .header-logo {
      height: 80px;
      filter: drop-shadow(0 0 15px var(--accent-glow));
    }

    .desktop-nav {
      display: none !important;
    }
  }

  .site-header.nsfw-active {
    background: transparent !important;
    border-bottom: 1px solid rgba(255, 0, 0, 0.1);
  }

  .site-header.nsfw-active .logo-link {
    position: relative;
    display: inline-flex;
  }

  .site-header.nsfw-active .header-logo {
    filter: drop-shadow(0 0 15px rgba(255, 0, 0, 0.3)) !important;
  }

  .logo-link:active {
    transform: scale(0.9);
  }
  .site-header.nsfw-active .news-badge-dot {
    background: var(--accent-color);
    box-shadow: 0 0 10px var(--accent-glow);
  }

  /* Consolidated Header Styles */
  .logo-section {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }
  .nsfw-link {
    all: unset;
    cursor: pointer;
    display: flex;
    align-items: center;
  }
  .nsfw-link span {
    color: #fff;
    opacity: 0.7;
    font-weight: 800;
    font-size: 0.85rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    transition: opacity 0.2s ease;
  }
  .nsfw-link:hover span {
    opacity: 1;
  }
  .nsfw-link.is-active span {
    color: #ff003c !important;
    opacity: 1 !important;
  }
  .news-badge-pc {
    background: #ff4444;
    color: #fff;
    font-size: 0.65rem;
    font-weight: 900;
    min-width: 18px;
    height: 18px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2px;
    box-shadow: 0 0 10px rgba(255, 68, 68, 0.5);
    border: 2px solid #050505;
    position: absolute;
    top: -8px;
    right: -12px;
    z-index: 10;
  }
  .news-badge-pc.hidden {
    display: none !important;
  }
  .nsfw-mobile-badge {
    display: none !important;
  }
  @media (max-width: 1024px) {
    .nsfw-link {
      display: none !important;
    }
    .nsfw-mobile-badge {
      display: flex !important;
      all: unset;
      cursor: pointer;
      background: rgba(255, 0, 60, 0.05);
      border: 2px solid rgba(255, 255, 255, 0.3);
      border-radius: 8px;
      padding: 8px 14px;
      line-height: 1;
      transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .nsfw-mobile-badge span {
      color: rgba(255, 255, 255, 0.9);
      font-size: 14px;
      font-weight: 900;
      letter-spacing: 0.05em;
      white-space: nowrap;
    }
    .nsfw-mobile-badge.is-active {
      background: rgba(255, 0, 60, 0.15);
      border-color: #ff003c;
      box-shadow: 0 0 10px rgba(255, 0, 60, 0.3);
    }
    .nsfw-mobile-badge.is-active span {
      color: #ff003c;
    }
  }
  @media (max-width: 768px) {
    .header-container {
      width: 100%;
      padding: 0.5rem 0;
    }
    .logo-section {
      display: grid !important;
      grid-template-columns: 1fr auto 1fr;
      width: 100%;
      align-items: center;
      gap: 0;
    }
    .nsfw-mobile-badge {
      justify-self: start;
      margin-left: 1.8rem;
    }
    .logo-link {
      display: flex;
      justify-content: center;
    }
    .logo-section::after {
      content: "";
      display: block;
    }
    .desktop-nav {
      display: none;
    }
  }
</style>
