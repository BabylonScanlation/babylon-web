---
// src/components/AdContainer.astro
import { siteConfig } from '../site.config';

interface Props {
  type: 'banner' | 'bannerLarge' | 'bannerSmall' | 'square' | 'native';
  id?: string;
  className?: string;
}

const { type, id, className = "" } = Astro.props;
const { user } = Astro.locals;

// Orion: Determinar el ID del anuncio según el tipo
const adKey = siteConfig.ads.adsterra[type as keyof typeof siteConfig.ads.adsterra] || siteConfig.ads.adsterra.banner;

// Dimensiones estándar para Adsterra
const dimensions = {
  banner: { w: 728, h: 90 },
  bannerLarge: { w: 728, h: 90 },
  bannerSmall: { w: 468, h: 60 },
  square: { w: 300, h: 250 },
  native: { w: 0, h: 0 }
};

const dim = dimensions[type as keyof typeof dimensions] || dimensions.banner;

// Orion: Mostrar anuncios si están habilitados globalmente
const shouldShowAds = siteConfig.ads.enabled;
---

{shouldShowAds && (
  <div class:list={["ad-container-root", type, className]} id={id}>
    <div class="ad-inner-wrapper">
      <div class="ad-content-slot">
        {/* Adsterra Logic Centralized */}
        <script is:inline set:html={`
          window.atOptions = {
            'key' : '${adKey}',
            'format' : 'iframe',
            'height' : ${dim.h},
            'width' : ${dim.w},
            'params' : {}
          };
        `} />
        <script is:inline data-cfasync="false" src={`https://crowdsubsequentadmire.com/${adKey}/invoke.js`} onerror="window.isAdsterraBlocked = true;"></script>
        <div id={`container-${adKey}`}></div>
      </div>
      
      <div class="ad-info-overlay">
        <span>AD</span>
      </div>
    </div>
  </div>
)}

<style>
  .ad-container-root {
    width: 100%;
    margin: 0;
    padding: 0;
    display: flex;
    justify-content: center;
    align-items: center;
    line-height: 0;
  }

  .ad-inner-wrapper {
    position: relative;
    display: flex;
    flex-direction: column;
    background: #080808;
    border: none; /* Astra: Eliminado borde para evitar líneas */
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.6);
    max-width: 100%;
    min-width: 300px; /* Ancho mínimo para banners estándar */
    min-height: 50px;  /* Altura mínima para que el script pueda inicializarse */
    transition: all 0.3s ease;
  }

  .ad-content-slot {
    padding: 0;
    margin: 0;
    display: block;
    width: 100%;
    /* Devolvemos la normalidad para que los scripts lean bien el DOM */
    line-height: normal;
    font-size: 1rem;
  }

  /* Astra: Centrado de los anuncios inyectados */
  :global(.ad-content-slot > div),
  :global(.ad-content-slot iframe),
  :global(.ad-content-slot ins) {
    margin: 0 auto !important;
    display: block !important;
    max-width: 100% !important;
  }

  .ad-info-overlay {
    position: absolute;
    top: 0;
    right: 0;
    background: rgba(0, 0, 0, 0.6);
    padding: 2px 6px;
    border-bottom-left-radius: 8px;
    z-index: 10;
    pointer-events: none;
  }

  .ad-info-overlay span {
    font-family: system-ui, sans-serif;
    font-size: 7px;
    font-weight: 900;
    color: #444;
    letter-spacing: 1px;
  }
</style>