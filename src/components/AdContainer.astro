---
// src/components/AdContainer.astro
import { siteConfig } from '../site.config';

interface Props {
  type: 'banner' | 'bannerLarge' | 'bannerSmall' | 'square' | 'native';
  id?: string;
  className?: string;
}

const { type, id, className = '' } = Astro.props;
const { user } = Astro.locals;

const adKeys = siteConfig.ads.adsterra;
const adKey = adKeys[type as keyof typeof adKeys] || adKeys.banner;

const dimensions = {
  banner: { w: 728, h: 90 },
  bannerLarge: { w: 728, h: 90 },
  bannerSmall: { w: 468, h: 60 },
  square: { w: 300, h: 250 },
  native: { w: 0, h: 0 },
};

const shouldShowAds = siteConfig.ads.enabled && !user?.isAdmin;

// Generar un ID único para esta instancia de anuncio
const instanceId = id || `ad-inst-${Math.random().toString(36).substring(2, 9)}`;
---

{shouldShowAds && (
  <div 
    class:list={["ad-container-root", type, className]} 
    id={instanceId}
    data-ad-type={type}
    data-ad-keys={JSON.stringify(adKeys)}
    data-ad-dims={JSON.stringify(dimensions)}
    data-ad-initial={adKey}
  >
    <div class="ad-inner-wrapper">
      <div class="ad-content-slot" id={`slot-${instanceId}`}>
        <div id={`container-${instanceId}`}></div>
      </div>
      
      <div class="ad-info-overlay">
        <span>AD</span>
      </div>
    </div>
  </div>
)}


