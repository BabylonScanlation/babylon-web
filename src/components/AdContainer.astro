---
// src/components/AdContainer.astro
import { siteConfig } from '../site.config';

interface Props {
  type: 'banner' | 'bannerLarge' | 'bannerSmall' | 'square' | 'native';
  id?: string;
  className?: string;
}

const { type, id, className: _className = '' } = Astro.props;
const { user } = Astro.locals;

const adKeys = siteConfig.ads.adsterra;
const _adKey = adKeys[type as keyof typeof adKeys] || adKeys.banner;

const _dimensions = {
  banner: { w: 728, h: 90 },
  bannerLarge: { w: 728, h: 90 },
  bannerSmall: { w: 468, h: 60 },
  square: { w: 300, h: 250 },
  native: { w: 0, h: 0 },
};

const _shouldShowAds = siteConfig.ads.enabled && !user?.isAdmin;

// Generar un ID único para esta instancia de anuncio
const _instanceId = id || `ad-inst-${Math.random().toString(36).substring(2, 9)}`;
---

{_shouldShowAds && (
  <div 
    class:list={["ad-container-root", type, _className]} 
    id={_instanceId}
    data-ad-type={type}
    data-ad-keys={JSON.stringify(adKeys)}
    data-ad-dims={JSON.stringify(_dimensions)}
    data-ad-initial={_adKey}
  >
    <div class="ad-inner-wrapper">
      <div class="ad-content-slot" id={`slot-${_instanceId}`}>
        <div id={`container-${_instanceId}`}></div>
      </div>
    </div>
  </div>
)}
<style is:inline>
  /* --- Ad Container (Modularized) --- */
  .content-dynamic-wrap {
    display: flex;
    justify-content: center;
    align-items: flex-start;
    width: 100%;
    margin: 2.5rem 0;
    overflow: visible !important;
    position: relative;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .content-dynamic-wrap.square {
    min-height: 250px;
    margin: 2.5rem auto;
  }

  /* Legacy / Root Styles from global.css */
  .ad-container-root {
    width: 100%;
    max-width: 100vw;
    margin: 0;
    padding: 0;
    display: flex;
    justify-content: center;
    align-items: center;
    overflow: visible !important;
    min-height: 90px;
  }

  .ad-container-root.banner,
  .ad-container-root.bannerLarge {
    min-height: 90px;
  }

  .ad-container-root.bannerSmall {
    min-height: 60px;
  }

  .ad-container-root.square {
    min-height: 250px;
  }

  .ad-inner-wrapper, .dynamic-inner-box {
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    background: #080808;
    border-radius: 16px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.6);
    max-width: 100vw;
    min-width: 300px;
    min-height: inherit;
    transition: all 0.3s ease;
    overflow: visible !important;
  }

  .ad-content-slot, .dynamic-content-slot {
    padding: 0;
    margin: 0;
    display: block;
    width: 100%;
    line-height: normal;
    font-size: 1rem;
    overflow: visible !important;
  }

  :global(.ad-content-slot > div),
  :global(.ad-content-slot iframe),
  :global(.ad-content-slot ins),
  :global(.dynamic-content-slot > div),
  :global(.dynamic-content-slot iframe),
  :global(.dynamic-content-slot ins) {
    margin: 0 auto !important;
    display: block !important;
    max-width: 100vw !important;
  }

</style>
