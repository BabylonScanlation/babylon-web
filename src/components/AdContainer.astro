---
import '../styles/components.css';
// src/components/AdContainer.astro
import { siteConfig } from '../site.config';

interface Props {
  type: 'banner' | 'bannerLarge' | 'bannerSmall' | 'square' | 'native';
  id?: string;
  className?: string;
}

const { type, id, className = '' } = Astro.props;

const adKey =
  siteConfig.ads.adsterra[type as keyof typeof siteConfig.ads.adsterra] ||
  siteConfig.ads.adsterra.banner;

const dimensions = {
  banner: { w: 728, h: 90 },
  bannerLarge: { w: 728, h: 90 },
  bannerSmall: { w: 468, h: 60 },
  square: { w: 300, h: 250 },
  native: { w: 0, h: 0 },
};

const dim = dimensions[type as keyof typeof dimensions] || dimensions.banner;
const shouldShowAds = siteConfig.ads.enabled;

// Generar un ID único para esta instancia de anuncio
const instanceId = id || `ad-inst-${Math.random().toString(36).substring(2, 9)}`;
---

{shouldShowAds && (
  <div class:list={["ad-container-root", type, className]} id={instanceId}>
    <div class="ad-inner-wrapper">
      <div class="ad-content-slot" id={`slot-${instanceId}`}>
        <div id={`container-${adKey}`}></div>
        
        <script is:inline define:vars={{ adKey, dim, instanceId }}>
          // Función para registrar el anuncio en la cola
          const registerAd = () => {
            if (window[`loaded_${instanceId}`]) return;
            window[`loaded_${instanceId}`] = true;

            window.babylonAdQueue = window.babylonAdQueue || [];
            window.babylonAdQueue.push({ key: adKey, h: dim.h, w: dim.w, id: instanceId });

            if (!window.babylonAdRunnerActive) {
              window.babylonAdRunnerActive = true;
              const runNextAd = () => {
                const ad = window.babylonAdQueue.shift();
                if (!ad) {
                  window.babylonAdRunnerActive = false;
                  return;
                }
                const slot = document.getElementById(`slot-${ad.id}`);
                if (!slot) { runNextAd(); return; }

                window.atOptions = { 'key' : ad.key, 'format' : 'iframe', 'height' : ad.h, 'width' : ad.w, 'params' : {} };
                const s = document.createElement('script');
                s.type = 'text/javascript'; s.src = `https://crowdsubsequentadmire.com/${ad.key}/invoke.js`; s.async = true;
                s.onload = () => setTimeout(runNextAd, 1000);
                s.onerror = () => setTimeout(runNextAd, 500);
                slot.appendChild(s);
              };
              setTimeout(runNextAd, 100);
            }
          };

          // Astra: Usar IntersectionObserver para carga perezosa real
          const el = document.getElementById(instanceId);
          if (el && 'IntersectionObserver' in window) {
            const observer = new IntersectionObserver((entries) => {
              if (entries[0].isIntersecting) {
                registerAd();
                observer.disconnect();
              }
            }, { rootMargin: '400px' }); // Cargar 400px antes de llegar
            observer.observe(el);
          } else {
            // Fallback para navegadores antiguos
            setTimeout(registerAd, 5000);
          }
        </script>
      </div>
      
      <div class="ad-info-overlay">
        <span>AD</span>
      </div>
    </div>
  </div>
)}


