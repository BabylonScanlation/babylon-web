---
// src/components/MangaCard.astro
import Image from './Image.astro';

const { coverImageUrl, title, lastChapter, url, loading = 'lazy' } = Astro.props;
---

<a href={url} class="card-wrapper">
  <!-- DESKTOP CARD (Poster Style) -->
  <div class="card desktop-view">
    <div class="image-container">
      <Image
        src={coverImageUrl}
        alt={`Portada de ${title}`}
        loading={loading}
        width={200}
        height={300}
        class="card-image"
        style={`transition-name: cover-${url.split('/').pop()}`}
        fetchpriority={loading === 'eager' ? 'high' : 'auto'}
      />
      <div class="gradient-overlay"></div>
      <div class="new-chapter-tag">NUEVO</div>

      <div class="card-content">
        <h3 class="title">{title}</h3>
        <p class="chapter">{lastChapter}</p>
      </div>
    </div>
  </div>

  <!-- MOBILE CARD (List Style) -->
  <div class="card mobile-view">
    <div class="mobile-thumb">
      <Image
        src={coverImageUrl}
        alt={`Portada de ${title}`}
        loading={loading}
        width={80}
        height={110}
        class="thumb-image"
        style={`transition-name: cover-${url.split('/').pop()}`}
      />
    </div>
    <div class="mobile-details">
      <h3 class="mobile-title">{title}</h3>
      <div class="mobile-meta">
        <span class="chapter-pill">{lastChapter}</span>
        <span class="read-action">LEER ›</span>
      </div>
    </div>
  </div>
</a>

<style>
  .card-wrapper {
    display: block;
    text-decoration: none;
    transition: transform 0.3s ease;
  }

  .card-wrapper:hover {
    transform: translateY(-5px);
  }

  /* --- DESKTOP VIEW --- */
  .desktop-view {
    display: block;
    border-radius: 12px;
    overflow: hidden;
    position: relative;
    background: #1a1a1a;
    aspect-ratio: 2/3;
  }

  .image-container {
    position: relative;
    width: 100%;
    height: 100%;
  }

  .card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .gradient-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.9) 0%,
      rgba(0, 0, 0, 0.2) 50%,
      transparent 100%
    );
    z-index: 1;
  }

  .new-chapter-tag {
    position: absolute;
    top: 10px;
    right: 10px;
    background: var(--accent-color);
    color: #000;
    font-size: 0.65rem;
    font-weight: 900;
    padding: 2px 8px;
    border-radius: 4px;
    z-index: 2;
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.3);
  }

  .card-content {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 1.25rem;
    z-index: 2;
  }

  .title {
    color: #fff;
    font-size: 1rem;
    font-weight: 800;
    margin: 0;
    line-height: 1.2;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }

  .chapter {
    color: var(--accent-color);
    font-size: 0.75rem;
    font-weight: 700;
    margin: 0.25rem 0 0 0;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* --- MOBILE VIEW --- */
  .mobile-view {
    display: none;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 12px;
    padding: 0.75rem;
    gap: 1rem;
    align-items: center;
  }

  .mobile-thumb {
    width: 80px;
    height: 110px;
    flex-shrink: 0;
    border-radius: 8px;
    overflow: hidden;
    background: #111;
  }

  .mobile-details {
    flex: 1;
    min-width: 0;
  }

  .mobile-title {
    color: #fff;
    font-size: 0.95rem;
    font-weight: 700;
    margin: 0 0 0.5rem 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .mobile-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .chapter-pill {
    background: var(--accent-glow);
    color: var(--accent-color);
    font-size: 0.7rem;
    font-weight: 800;
    padding: 2px 8px;
    border-radius: 6px;
  }

  .read-action {
    color: #555;
    font-size: 0.7rem;
    font-weight: 800;
  }

  @media (max-width: 640px) {
    .desktop-view {
      display: none;
    }
    .mobile-view {
      display: flex;
    }
  }
</style>