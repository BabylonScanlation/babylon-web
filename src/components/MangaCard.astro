---
import Image from './Image.astro';

interface Props {
  coverImageUrl: string | null;
  title: string;
  lastChapter: string;
  url: string;
  loading?: 'lazy' | 'eager';
}

const { coverImageUrl, title, lastChapter, url, loading = 'lazy' } = Astro.props;
---

<a href={url} class="card-wrapper">
  <!-- SHARED IMAGE COMPONENT (Single Request) -->
  <div class="card-container-adaptive">
    <div class="image-container">
      <Image
        src={coverImageUrl || ''}
        alt={`Portada de ${title}`}
        loading={loading}
        width={300}
        height={450}
        class="main-card-image"
        style={`transition-name: cover-${url.split('/').pop()}`}
        fetchpriority={loading === 'eager' ? 'high' : 'auto'}
        forceLazy={true}
      />
      <div class="gradient-overlay desktop-only"></div>
      <div class="new-chapter-tag desktop-only">NUEVO</div>
    </div>

    <div class="card-details-adaptive">
      <!-- Desktop Layout -->
      <div class="desktop-content desktop-only">
        <h3 class="title">{title}</h3>
        <p class="chapter">{lastChapter}</p>
      </div>

      <!-- Mobile Layout -->
      <div class="mobile-content mobile-only">
        <h3 class="mobile-title">{title}</h3>
        <div class="mobile-meta">
          <span class="chapter-pill">{lastChapter}</span>
          <span class="read-action">LEER ›</span>
        </div>
      </div>
    </div>
  </div>
</a>

<style>
  .card-wrapper {
    display: block;
    text-decoration: none;
    transition: transform 0.3s ease;
  }

  .card-wrapper:hover {
    transform: translateY(-5px);
  }

  /* --- ADAPTIVE CONTAINER --- */
  .card-container-adaptive {
    display: flex;
    flex-direction: column;
    border-radius: 12px;
    overflow: hidden;
    position: relative;
    background: #1a1a1a;
  }

  .image-container {
    position: relative;
    width: 100%;
    aspect-ratio: 2/3;
  }

  .main-card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* --- DESKTOP SPECIFIC --- */
  .desktop-only { display: block; }
  .mobile-only { display: none; }

  .gradient-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.9) 0%,
      rgba(0, 0, 0, 0.2) 50%,
      transparent 100%
    );
    z-index: 1;
  }

  .new-chapter-tag {
    position: absolute;
    top: 10px;
    right: 10px;
    background: var(--accent-color);
    color: #000;
    font-size: 0.65rem;
    font-weight: 900;
    padding: 2px 8px;
    border-radius: 4px;
    z-index: 2;
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.3);
  }

  .desktop-content {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 1.25rem;
    z-index: 2;
  }

  .title {
    color: #fff;
    font-size: 1rem;
    font-weight: 800;
    margin: 0;
    line-height: 1.2;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }

  .chapter {
    color: var(--accent-color);
    font-size: 0.75rem;
    font-weight: 700;
    margin: 0.25rem 0 0 0;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* --- MOBILE SPECIFIC --- */
  @media (max-width: 640px) {
    .desktop-only { display: none !important; }
    .mobile-only { display: block !important; }

    .card-container-adaptive {
      flex-direction: row;
      background: rgba(255, 255, 255, 0.02);
      border: 1px solid rgba(255, 255, 255, 0.05);
      padding: 0.75rem;
      gap: 1rem;
      align-items: center;
      aspect-ratio: auto;
    }

    .image-container {
      width: 80px;
      height: 110px;
      flex-shrink: 0;
      border-radius: 8px;
      overflow: hidden;
      aspect-ratio: auto;
    }

    .card-details-adaptive {
      flex: 1;
      min-width: 0;
    }

    .mobile-title {
      color: #fff;
      font-size: 0.95rem;
      font-weight: 700;
      margin: 0 0 0.5rem 0;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .mobile-meta {
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .chapter-pill {
      background: var(--accent-glow);
      color: var(--accent-color);
      font-size: 0.7rem;
      font-weight: 800;
      padding: 2px 8px;
      border-radius: 6px;
    }

    .read-action {
      color: #555;
      font-size: 0.7rem;
      font-weight: 800;
    }
  }
</style>
