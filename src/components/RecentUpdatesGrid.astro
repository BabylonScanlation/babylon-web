---
import '../styles/components.css';
import type { Series } from '../types';
import UpdateCard from './UpdateCard.astro';

interface Props {
  mangas: Series[];
  title?: string;
}

const { mangas = [], title = 'Últimos Capítulos Publicados' } = Astro.props;
---

<section class="updates-premium-section">
  <div class="section-header centered">
    <div class="header-line"></div>
    <h2 class="section-title">
      <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2.5" fill="none"><path d="M13 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"></path><polyline points="13 2 13 9 20 9"></polyline></svg>
      {title}
    </h2>
    <div class="header-line reversed"></div>
  </div>

  {
    mangas && mangas.length > 0 ? (
      <div class="swiper-outer-container">
        <div class="swiper recent-updates-swiper">
          <div class="swiper-wrapper">
            {mangas.map((manga) => (
              <div class="swiper-slide custom-slide">
                <UpdateCard series={manga} />
              </div>
            ))}
          </div>
          <!-- Barra de progreso minimalista -->
          <div class="swiper-scrollbar premium-scrollbar"></div>
        </div>
      </div>
    ) : (
      <div class="empty-updates">
        <p>No hay actualizaciones recientes para mostrar.</p>
      </div>
    )
  }
</section>

<script is:inline>
  const initRecentUpdatesSwiper = () => {
    const swiperEl = document.querySelector('.recent-updates-swiper');
    // @ts-ignore
    if (!swiperEl || swiperEl.swiper || !window.Swiper) return;

    const observer = new IntersectionObserver((entries) => {
      if (entries[0].isIntersecting) {
        // @ts-ignore
        new window.Swiper(swiperEl, {
          init: true,
          slidesPerView: 'auto',
          spaceBetween: 15,
          freeMode: true,
          grabCursor: true,
          scrollbar: {
            el: '.premium-scrollbar',
            draggable: true,
            snapOnRelease: true
          },
          breakpoints: {
            768: { spaceBetween: 25 }
          }
        });
        observer.disconnect();
      }
    }, { rootMargin: '100px' });
    observer.observe(swiperEl);
  };

  document.addEventListener('astro:page-load', initRecentUpdatesSwiper);
  if (document.readyState !== 'loading') initRecentUpdatesSwiper();
  else document.addEventListener('DOMContentLoaded', initRecentUpdatesSwiper);
</script>
