---
import { timeAgo } from '../lib/utils';
import type { Series } from '../types';
import Image from './Image.astro';

interface Props {
  mangas: Series[];
  title?: string;
}

const { mangas = [], title = 'Últimos Capítulos Publicados' } = Astro.props;
const displayMangas = mangas.slice(0, 20);
---

<section class="updates-premium-section">
  <div class="section-header centered">
    <div class="header-line"></div>
    <h2 class="section-title">
      <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2.5" fill="none"><path d="M13 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"></path><polyline points="13 2 13 9 20 9"></polyline></svg>
      {title}
    </h2>
    <div class="header-line reversed"></div>
  </div>

  {
    displayMangas && displayMangas.length > 0 ? (
      <div class="swiper-outer-container">
        <div class="swiper recent-updates-swiper">
          <div class="swiper-wrapper">
            {displayMangas.map((series) => {
              const recentChapters = (series as any).recentChapters || [];
              return (
                <div class="swiper-slide custom-slide">
                  <div class="premium-update-card-wrapper">
                    <div class="premium-update-card-inner">
                      <a href={`/series/${series.slug}`} class="cover-link" data-astro-prefetch="false">
                        <div class="art-box">
                          <Image
                            src={series.coverImageUrl || ''}
                            alt={series.title}
                            width={300}
                            height={450}
                            loading="lazy"
                            class="main-cover"
                            forceLazy={true}
                          />
                          <div class="glass-gradient-overlay"></div>
                        </div>
                      </a>

                      <div class="card-info-overlay">
                        <a href={`/series/${series.slug}`} class="series-title-link" data-astro-prefetch="false">
                          <h3 class="series-name-title">{series.title}</h3>
                        </a>

                        <div class="recent-chapters-stack">
                          {
                            recentChapters.map((chapter: any) => (
                              <a href={`/series/${series.slug}/${chapter.number}`} class="chapter-pill" data-astro-prefetch="false">
                                <div class="pill-left">
                                  <span class="chap-badge">CAP {chapter.number}</span>
                                </div>
                                <div class="pill-right">
                                  <span class="time-text">{timeAgo(chapter.createdAt)}</span>
                                </div>
                              </a>
                            ))
                          }
                          {recentChapters.length === 0 && (
                            <div class="no-chapters-msg">Próximamente</div>
                          )}
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              );
            })}
          </div>
        </div>

        <!-- Contenedor externo para la scrollbar -->
        <div class="premium-scrollbar-external-box">
          <div class="swiper-scrollbar premium-scrollbar"></div>
        </div>
      </div>
    ) : (
      <div class="empty-updates">
        <p>No hay actualizaciones recientes para mostrar.</p>
      </div>
    )
  }
</section>

<script>
  import Swiper from 'swiper';
  import { Scrollbar, FreeMode, Mousewheel } from 'swiper/modules';
  import 'swiper/css';
  import 'swiper/css/scrollbar';

  function initRecentUpdatesSwiper() {
    // Buscamos todos los swipers de actualizaciones (por si acaso hay más de uno)
    const swiperElements = document.querySelectorAll('.recent-updates-swiper');

    swiperElements.forEach((el) => {
      // Evitar doble inicialización
      if ((el as any).swiper) return;

      new Swiper(el as HTMLElement, {
        modules: [Scrollbar, FreeMode, Mousewheel],
        slidesPerView: 'auto',
        spaceBetween: 12,
        grabCursor: true,
        resistance: true,
        resistanceRatio: 0.85,
        freeMode: {
          enabled: true,
          sticky: false,
          momentum: true,
          momentumRatio: 2.5, // Astra: Mucho más inercia
          momentumVelocityRatio: 2.5, // Astra: Deslizamiento más rápido y natural
          minimumVelocity: 0.02,
        },
        mousewheel: {
          forceToAxis: true,
          sensitivity: 2, // Astra: Sensibilidad aumentada para escritorio
        },
        scrollbar: {
          el: el.parentElement?.querySelector('.premium-scrollbar') as HTMLElement || '.premium-scrollbar',
          draggable: true,
          hide: false,
          snapOnRelease: false,
        },
        breakpoints: {
          320: { spaceBetween: 10 },
          768: { spaceBetween: 15 },
          1024: { spaceBetween: 20 },
        },
        observer: true,
        observeParents: true,
        watchSlidesProgress: true,
        roundLengths: true, // Astra: Evita vibraciones de texto por sub-píxeles
        touchRatio: 1.5, // Astra: Más responsivo al tacto en móvil
      });
    });
  }

  // Inicializar en carga inicial
  initRecentUpdatesSwiper();

  // Reinicializar tras cada navegación de Astro (View Transitions)
  document.addEventListener('astro:page-load', () => {
    initRecentUpdatesSwiper();
  });
</script>

<style>
  /* --- Recent Updates Grid --- */
  .updates-premium-section {
    width: 100%;
    margin: 0 0 1.5rem 0; /* Astra: Eliminado margin-top para evitar duplicidad con el gap del padre */
    position: relative;
  }

  .section-header.centered {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 2rem;
    margin-bottom: 1rem; /* Astra: Título aún más cerca de la cuadrícula */
    width: 100%;
  }

  .header-line {
    height: 1px;
    width: 100%;
    background: linear-gradient(90deg, transparent, var(--accent-color));
    opacity: 0.2;
  }

  .header-line.reversed {
    background: linear-gradient(90deg, var(--accent-color), transparent);
  }

  .section-title {
    font-size: 1.6rem;
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    white-space: nowrap;
  }

  .section-title svg {
    color: var(--accent-color);
    filter: drop-shadow(0 0 8px var(--accent-color));
  }

  .swiper-outer-container {
    position: relative;
    width: 100%;
    padding: 0;
    /* Astra: Permitimos que las sombras respiren sin romper el clipping horizontal */
    overflow: visible;
  }

  .recent-updates-swiper {
    width: 100%;
    /* Astra: El contenedor swiper DEBE tener overflow hidden para el clipping correcto */
    overflow: hidden !important;
    padding: 10px 0 25px 0 !important; /* Astra: Compactado */
    margin: -10px 0 0 0;
    /* Astra: Forzar capa de composición */
    transform: translateZ(0);
  }

  .swiper-wrapper {
    will-change: transform;
  }

  .custom-slide {
    flex-shrink: 0;
    width: 240px !important;
    height: auto;
    /* Astra: Aceleración por hardware */
    backface-visibility: hidden;
    transform: translateZ(0);
  }

  /* --- Scrollbar Visual Fix (Visible & Integrated) --- */
  .premium-scrollbar-external-box {
    width: 100%;
    height: 20px;
    margin-top: 5px; 
    display: flex !important;
    justify-content: center;
    align-items: center;
    position: relative;
    z-index: 100 !important;
    padding: 0 2px; /* Astra: Pequeño resguardo lateral */
    box-sizing: border-box;
  }

  :global(.premium-scrollbar.swiper-scrollbar) {
    background: rgba(255, 255, 255, 0.1) !important;
    height: 6px !important; /* Astra: Incrementado para mejor visibilidad y tacto */
    position: relative !important;
    width: 100% !important; /* Astra: Ocupa el 100% del contenedor protegido */
    max-width: none !important;
    border-radius: 100px !important;
    opacity: 1 !important;
    visibility: visible !important;
    display: block !important;
    border: 1px solid rgba(255, 255, 255, 0.05) !important;
    left: 0 !important;
    right: 0 !important;
  }

  :global(.premium-scrollbar .swiper-scrollbar-drag) {
    background: var(--accent-color) !important;
    height: 100% !important;
    border-radius: 100px !important;
    opacity: 1 !important;
    visibility: visible !important;
    box-shadow: 0 0 15px var(--accent-color) !important; /* Astra: Brillo más intenso */
    cursor: grab !important;
  }

  /* --- Premium Card Styles (Restored) --- */
  .premium-update-card-wrapper {
    position: relative;
    width: 100%;
    aspect-ratio: 2 / 3;
    z-index: 1;
  }

  .premium-update-card-inner {
    position: relative;
    width: 100%;
    height: 100%;
    border-radius: 24px;
    overflow: hidden;
    background: #111;
    border: 1px solid rgba(255, 255, 255, 0.05);
    transition: all 0.4s cubic-bezier(0.25, 0.8, 0.25, 1);
    isolation: isolate;
  }

  .premium-update-card-wrapper:hover .premium-update-card-inner {
    transform: translateY(-8px);
    border-color: var(--accent-color);
    box-shadow: 0 15px 30px rgba(0, 0, 0, 0.5);
  }

  .main-cover {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.8s cubic-bezier(0.25, 0.8, 0.25, 1);
  }

  .premium-update-card-wrapper:hover .main-cover {
    transform: scale(1.1);
  }

  .glass-gradient-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.98) 0%,
      rgba(0, 0, 0, 0.6) 40%,
      transparent 100%
    );
  }

  .card-info-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 1.25rem;
    z-index: 30; /* Astra: Por encima del shield-overlay (z-index 20) de Image.astro */
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    pointer-events: none;
  }

  .series-name-title {
    font-size: 1.1rem;
    font-weight: 900;
    color: #fff;
    margin: 0;
    line-height: 1.2;
    text-shadow: 0 2px 10px rgba(0, 0, 0, 0.8);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .recent-chapters-stack {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    pointer-events: auto;
  }

  .chapter-pill {
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: rgba(20, 20, 20, 0.9); /* Astra: Fondo sólido para máximo rendimiento */
    border: 1px solid rgba(255, 255, 255, 0.08);
    padding: 8px 12px;
    border-radius: 12px;
    text-decoration: none;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    /* Astra: Prevenir parpadeos */
    backface-visibility: hidden;
  }

  .chapter-pill:hover {
    background: var(--accent-color);
    border-color: var(--accent-color);
    transform: translateX(5px);
  }

  .chap-badge {
    font-size: 0.75rem;
    font-weight: 900;
    color: var(--accent-color);
    transition: color 0.3s;
  }

  .chapter-pill:hover .chap-badge {
    color: #000;
  }

  .time-text {
    font-size: 0.65rem;
    font-weight: 700;
    color: #888;
    text-transform: uppercase;
  }

  .chapter-pill:hover .time-text {
    color: #fff;
    opacity: 0.8;
  }

  @media (max-width: 768px) {
    .updates-premium-section { margin: 1rem 0; }
    .section-header.centered { gap: 1rem; margin-bottom: 1.5rem; }
    .section-title { font-size: 1.1rem; letter-spacing: 0.1em; }
    .header-line { display: none; }
    .premium-scrollbar-external-box { margin-top: 10px; }
    .recent-updates-swiper { padding-bottom: 25px !important; }
  }
</style>
