---
import type { Series } from '../types';
import Image from './Image.astro';
import { timeAgo } from '../lib/utils';

interface Props {
  mangas: Series[];
  title?: string;
}

const { mangas = [], title = 'Últimos Capítulos Publicados' } = Astro.props;
const displayMangas = mangas.slice(0, 20);
---

<section class="updates-premium-section">
  <div class="section-header centered">
    <div class="header-line"></div>
    <h2 class="section-title">
      <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2.5" fill="none"><path d="M13 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"></path><polyline points="13 2 13 9 20 9"></polyline></svg>
      {title}
    </h2>
    <div class="header-line reversed"></div>
  </div>

  {
    displayMangas && displayMangas.length > 0 ? (
      <div class="swiper-outer-container">
        <div class="swiper recent-updates-swiper">
          <div class="swiper-wrapper">
            {displayMangas.map((series) => {
              const recentChapters = (series as any).recentChapters || [];
              return (
                <div class="swiper-slide custom-slide">
                  <div class="premium-update-card-wrapper">
                    <div class="premium-update-card-inner">
                      <a href={`/series/${series.slug}`} class="cover-link" data-astro-prefetch="false">
                        <div class="art-box">
                          <Image
                            src={series.coverImageUrl || ''}
                            alt={series.title}
                            width={300}
                            height={450}
                            loading="lazy"
                            class="main-cover"
                            forceLazy={true}
                          />
                          <div class="glass-gradient-overlay"></div>
                        </div>
                      </a>

                      <div class="card-info-overlay">
                        <a href={`/series/${series.slug}`} class="series-title-link" data-astro-prefetch="false">
                          <h3 class="series-name-title">{series.title}</h3>
                        </a>
                        
                        <div class="recent-chapters-stack">
                          {
                            recentChapters.map((chapter: any) => (
                              <a href={`/series/${series.slug}/${chapter.number}`} class="chapter-pill" data-astro-prefetch="false">
                                <div class="pill-left">
                                  <span class="chap-badge">CAP {chapter.number}</span>
                                </div>
                                <div class="pill-right">
                                  <span class="time-text">{timeAgo(chapter.createdAt)}</span>
                                </div>
                              </a>
                            ))
                          }
                          {recentChapters.length === 0 && (
                            <div class="no-chapters-msg">Próximamente</div>
                          )}
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              );
            })}
          </div>
        </div>
        
        <!-- Contenedor externo para la scrollbar -->
        <div class="premium-scrollbar-external-box">
          <div class="swiper-scrollbar premium-scrollbar"></div>
        </div>
      </div>
    ) : (
      <div class="empty-updates">
        <p>No hay actualizaciones recientes para mostrar.</p>
      </div>
    )
  }
</section>

<style is:inline>
  /* --- Recent Updates Grid --- */
  .updates-premium-section {
    width: 100%;
    margin: 0;
    position: relative;
  }

  .section-header.centered {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 2rem;
    margin-bottom: 1.5rem;
    width: 100%;
  }

  .header-line {
    height: 1px;
    width: 100%;
    background: linear-gradient(90deg, transparent, var(--accent-color));
    opacity: 0.2;
  }

  .header-line.reversed {
    background: linear-gradient(90deg, var(--accent-color), transparent);
  }

  .section-title {
    font-size: 1.6rem;
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    white-space: nowrap;
  }

  .section-title svg {
    color: var(--accent-color);
    filter: drop-shadow(0 0 8px var(--accent-color));
  }

  .swiper-outer-container {
    position: relative;
    width: 100%;
    padding: 0;
  }

  .recent-updates-swiper {
    width: 100%;
    height: auto;
    overflow: visible !important;
    padding-bottom: 3.5rem !important;
    position: relative;
    display: block;
  }

  .recent-updates-swiper:not(.swiper-initialized) .swiper-wrapper {
    display: flex;
    gap: 20px;
  }

  @media (min-width: 768px) {
    .recent-updates-swiper:not(.swiper-initialized) .swiper-wrapper {
      gap: 30px;
    }
  }

  @media (min-width: 1024px) {
    .recent-updates-swiper:not(.swiper-initialized) .swiper-wrapper {
      gap: 40px;
    }
  }

  .custom-slide {
    flex-shrink: 0;
    width: 240px !important;
    height: auto;
    transform: none;
    -webkit-font-smoothing: antialiased;
    backface-visibility: hidden;
  }

  /* --- Inlined Update Card Styles --- */
  .premium-update-card-wrapper {
    position: relative;
    width: 100%;
    aspect-ratio: 2 / 3;
    z-index: 1;
  }

  .premium-update-card-inner {
    position: relative;
    width: 100%;
    height: 100%;
    border-radius: 24px;
    overflow: hidden;
    background: #111;
    border: 1px solid rgba(255, 255, 255, 0.05);
    transition: all 0.4s cubic-bezier(0.25, 0.8, 0.25, 1);
    isolation: isolate;
  }

  .premium-update-card-wrapper:hover .premium-update-card-inner {
    transform: translateY(-8px);
    border-color: var(--accent-color);
    box-shadow: 0 15px 30px rgba(0, 0, 0, 0.5);
  }

  .cover-link {
    position: absolute;
    inset: 0;
    z-index: 0;
    text-decoration: none;
    color: inherit;
  }

  .art-box {
    width: 100%;
    height: 100%;
  }

  .main-cover {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.8s cubic-bezier(0.25, 0.8, 0.25, 1);
  }

  .premium-update-card-wrapper:hover .main-cover {
    transform: scale(1.1);
  }

  .glass-gradient-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.98) 0%,
      rgba(0, 0, 0, 0.6) 40%,
      transparent 100%
    );
  }

  .card-info-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 1.25rem;
    z-index: 5;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    pointer-events: none;
  }

  .series-title-link {
    text-decoration: none;
    pointer-events: auto;
  }

  .series-name-title {
    font-size: 1.1rem;
    font-weight: 900;
    color: #fff;
    margin: 0;
    line-height: 1.2;
    text-shadow: 0 2px 10px rgba(0, 0, 0, 0.8);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
    transform: translateZ(0);
  }

  .recent-chapters-stack {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    pointer-events: auto;
    transform: translateZ(0);
  }

  .chapter-pill {
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: rgba(255, 255, 255, 0.04);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.08);
    padding: 8px 12px;
    border-radius: 12px;
    text-decoration: none;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    -webkit-font-smoothing: antialiased;
    backface-visibility: hidden;
    transform: translateZ(0);
  }

  .chapter-pill:hover {
    background: var(--accent-color);
    border-color: var(--accent-color);
    transform: translateX(5px);
  }

  .chap-badge {
    font-size: 0.75rem;
    font-weight: 900;
    color: var(--accent-color);
    letter-spacing: 0.05em;
    transition: color 0.3s;
  }

  .chapter-pill:hover .chap-badge {
    color: #000;
  }

  .time-text {
    font-size: 0.65rem;
    font-weight: 700;
    color: #888;
    text-transform: uppercase;
    transition: all 0.3s ease;
  }

  .chapter-pill:hover .time-text {
    color: #fff;
    opacity: 0.8;
  }

  .no-chapters-msg {
    font-size: 0.75rem;
    color: #444;
    font-weight: 800;
    text-transform: uppercase;
    text-align: center;
    padding: 0.5rem;
  }

  /* --- Scrollbar Styles --- */
  :global(.premium-scrollbar) {
    position: absolute !important;
    bottom: 15px !important;
    left: 10% !important;
    width: 80% !important;
    height: 6px !important;
    background: rgba(255, 255, 255, 0.02) !important;
    border-radius: 100px !important;
    border: 1px solid rgba(255, 255, 255, 0.03) !important;
    overflow: visible !important;
    opacity: 1 !important;
  }

  :global(.premium-scrollbar .swiper-scrollbar-drag) {
    background: var(--accent-color) !important;
    border-radius: 100px !important;
    height: 100% !important;
    position: relative !important;
    cursor: grab !important;
    transition: background 0.3s, box-shadow 0.3s, filter 0.3s !important;
    will-change: transform;
    box-shadow: 0 0 8px var(--accent-glow) !important;
  }

  :global(.premium-scrollbar:hover .swiper-scrollbar-drag),
  :global(.premium-scrollbar .swiper-scrollbar-drag:active) {
    filter: brightness(1.3);
    box-shadow: 0 0 10px var(--accent-color), 0 0 20px var(--accent-glow) !important;
    cursor: grabbing !important;
  }

  .empty-updates {
    text-align: center;
    padding: 4rem;
    background: rgba(255, 255, 255, 0.02);
    border-radius: 24px;
    color: #444;
    font-weight: 700;
  }

  @media (max-width: 768px) {
    .premium-scrollbar-external-box { display: none !important; }
    .recent-updates-swiper { padding-bottom: 0.5rem !important; }
    .section-title { font-size: 1.1rem; letter-spacing: 0.1em; }
    .header-line { display: none; }
    .updates-premium-section { margin: 2.5rem 0; }
  }
</style>
