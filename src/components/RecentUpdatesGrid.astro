---
import type { Series } from '../types';
import UpdateCard from './UpdateCard.astro';

interface Props {
  mangas: Series[];
  title?: string;
}

const { mangas = [], title = 'Últimos Capítulos Publicados' } = Astro.props;
const displayMangas = mangas.slice(0, 20);
---

<section class="updates-premium-section">
  <div class="section-header centered">
    <div class="header-line"></div>
    <h2 class="section-title">
      <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2.5" fill="none"><path d="M13 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"></path><polyline points="13 2 13 9 20 9"></polyline></svg>
      {title}
    </h2>
    <div class="header-line reversed"></div>
  </div>

  {
    displayMangas && displayMangas.length > 0 ? (
      <div class="swiper-outer-container">
        <div class="swiper recent-updates-swiper">
          <div class="swiper-wrapper">
            {displayMangas.map((manga) => (
              <div class="swiper-slide custom-slide">
                <UpdateCard series={manga} loading="lazy" />
              </div>
            ))}
          </div>
        </div>
        
        <!-- Contenedor externo para la scrollbar -->
        <div class="premium-scrollbar-external-box">
          <div class="swiper-scrollbar premium-scrollbar"></div>
        </div>
      </div>
    ) : (
      <div class="empty-updates">
        <p>No hay actualizaciones recientes para mostrar.</p>
      </div>
    )
  }
</section>

<style>
  /* --- Recent Updates Grid --- */
  .updates-premium-section {
    width: 100%;
    margin: 0; /* Astra: Espaciado controlado por el padre */
    position: relative;
  }

  /* Astra: T├¡tulo centrado sim├⌐trico con Grid */
  .section-header.centered {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 2rem;
    margin-bottom: 1.5rem; /* Astra: T├¡tulo m├ís cerca del contenido */
    width: 100%;
  }

  .header-line {
    height: 1px;
    width: 100%;
    background: linear-gradient(90deg, transparent, var(--accent-color));
    opacity: 0.2;
  }

  .header-line.reversed {
    background: linear-gradient(90deg, var(--accent-color), transparent);
  }

  .section-title {
    font-size: 1.6rem;
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    white-space: nowrap;
  }

  .section-title svg {
    color: var(--accent-color);
    filter: drop-shadow(0 0 8px var(--accent-color));
  }

  .swiper-outer-container {
    position: relative;
    width: 100%;
    padding: 0;
  }

  .recent-updates-swiper {
    width: 100%;
    height: auto;
    overflow: visible !important;
    padding-bottom: 3.5rem !important; /* Espacio para la scrollbar sin cajas feas */
    position: relative;
    display: block;
  }

  /* Astra: Espaciado proactivo antes de que Swiper despierte */
  .recent-updates-swiper:not(.swiper-initialized) .swiper-wrapper {
    display: flex;
    gap: 20px;
  }

  @media (min-width: 768px) {
    .recent-updates-swiper:not(.swiper-initialized) .swiper-wrapper {
      gap: 30px;
    }
  }

  @media (min-width: 1024px) {
    .recent-updates-swiper:not(.swiper-initialized) .swiper-wrapper {
      gap: 40px;
    }
  }

  /* Astra: Reset de nitidez absoluta para textos */
  .custom-slide {
    flex-shrink: 0;
    width: 240px !important;
    height: auto;
    transform: none;
    -webkit-font-smoothing: antialiased;
    backface-visibility: hidden;
  }

  .series-name-title {
    font-size: 1.15rem;
    font-weight: 900;
    color: #fff;
    margin: 0;
    line-height: 1.3;
    text-shadow: 0 2px 8px rgba(0, 0, 0, 1);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    transform: none;
  }

  /* --- Estilo de la Barra de Desplazamiento Neón --- */
  :global(.premium-scrollbar) {
    position: absolute !important;
    bottom: 15px !important;
    left: 10% !important;
    width: 80% !important;
    height: 6px !important; /* Astra: Agrandado de 4px a 6px */
    background: rgba(255, 255, 255, 0.02) !important;
    border-radius: 100px !important;
    border: 1px solid rgba(255, 255, 255, 0.03) !important;
    overflow: visible !important;
    opacity: 1 !important;
  }

  /* El tirador (Drag handle) */
  :global(.premium-scrollbar .swiper-scrollbar-drag) {
    background: var(--accent-color) !important;
    border-radius: 100px !important;
    height: 100% !important;
    position: relative !important;
    cursor: grab !important;
    /* Astra: Transición SOLO para efectos visuales, NO para el movimiento (transform) */
    transition: background 0.3s, box-shadow 0.3s, filter 0.3s !important;
    /* Optimización de hardware */
    will-change: transform;
    /* Brillo de reposo más suave */
    box-shadow: 0 0 8px var(--accent-glow) !important;
  }

  /* Efecto de Luz Azul Suave al interactuar */
  :global(.premium-scrollbar:hover .swiper-scrollbar-drag),
  :global(.premium-scrollbar .swiper-scrollbar-drag:active) {
    filter: brightness(1.3);
    box-shadow: 
      0 0 10px var(--accent-color),
      0 0 20px var(--accent-glow) !important;
    cursor: grabbing !important;
  }

  /* Halo de luz sutil bajo la barra */
  :global(.premium-scrollbar)::after {
    content: '';
    position: absolute;
    inset: -4px;
    background: var(--accent-color);
    filter: blur(20px);
    opacity: 0.03; /* Astra: Luz ultra suave */
    z-index: -1;
    border-radius: 100px;
  }

  @media (max-width: 768px) {
    .premium-scrollbar-external-box {
      display: none !important; /* Ocultar scrollbar en m├│viles donde se puede deslizar con el dedo */
    }

    .recent-updates-swiper {
      padding-bottom: 0.5rem !important; /* Eliminar el espacio vac├¡o dejado por la barra oculta */
    }
  }

  .empty-updates {
    text-align: center;
    padding: 4rem;
    background: rgba(255, 255, 255, 0.02);
    border-radius: 24px;
    color: #444;
    font-weight: 700;
  }

  @media (max-width: 768px) {
    .section-title {
      font-size: 1.1rem;
      letter-spacing: 0.1em;
    }
    .header-line {
      display: none;
    }
    .updates-premium-section {
      margin: 2.5rem 0;
    }
    .swiper-fade-left,
    .swiper-fade-right {
      width: 30px;
    }
  }
</style>
