---
import '../styles/components.css';
// src/components/HeroCarousel.astro
import type { Series } from '../types';
import { getImageUrl } from '../lib/utils';
import 'swiper/css';
import 'swiper/css/pagination';
import 'swiper/css/navigation';
import 'swiper/css/effect-fade';

interface Props {
  slides: Series[];
  title?: string;
  r2PublicUrlAssets?: string;
}

const { slides = [], title, r2PublicUrlAssets } = Astro.props;

// Orion: Optimización quirúrgica de URL (Solo red, no diseño)
const getOptUrl = (path: any) => {
  const url = getImageUrl(path, r2PublicUrlAssets, 'series');
  return url.includes('?') ? `${url}&w=280&q=60` : `${url}?w=280&q=60`;
};

// Duplicar slides si son pocos
let renderSlides = [...slides];
if (renderSlides.length > 0 && renderSlides.length < 3) {
  while (renderSlides.length < 4) {
    renderSlides = [...renderSlides, ...slides];
  }
}
---

<section class="hero-carousel-section">
  {title && <h2 class="carousel-section-title">{title}</h2>}
  
  <div class="carousel-outer-frame">
    <div class="swiper hero-swiper">
      <div class="swiper-wrapper">
        {renderSlides.map((slide) => (
          <div class="swiper-slide">
            <a href={`/series/${slide.slug}`} class="slide-main-link" draggable="false" data-astro-prefetch="false">
              <!-- Background layer -->
              <div
                class="slide-bg-art"
                style={`background-image: url(${getOptUrl(slide.coverImageUrl)})`}
              />
              <div class="slide-overlay-master" />
              
              <!-- Content layer -->
              <div class="slide-inner-content">
                <div class="content-grid-hero">
                  <div class="hero-art-box">
                    <div class="art-shimmer"></div>
                    <img
                      src={getOptUrl(slide.coverImageUrl)}
                      alt={slide.title}
                      class="hero-poster"
                      loading="lazy"
                      draggable="false"
                    />
                  </div>
                  
                  <div class="hero-text-glass">
                    <div class="badge-new">RECOMENDADO</div>
                    <h3 class="hero-title"><span class="hero-title-text">{slide.title}</span></h3>
                    <p class="hero-description">{slide.description}</p>
                    
                    <div class="hero-actions">
                      <span class="btn-read-now">
                        <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2.5" fill="none"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path></svg>
                        LEER AHORA
                      </span>
                    </div>
                  </div>
                </div>
              </div>
            </a>
          </div>
        ))}
      </div>
    </div>
    
    <!-- Premium Controls -->
    <div class="swiper-pagination premium-pagination"></div>
    <div class="swiper-button-prev premium-nav prev">
      <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="3" fill="none"><polyline points="15 18 9 12 15 6"></polyline></svg>
    </div>
    <div class="swiper-button-next premium-nav next">
      <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="3" fill="none"><polyline points="9 18 15 12 9 6"></polyline></svg>
    </div>
  </div>
</section>

<script is:inline>
  const initHeroSwiper = () => {
    const swiperEl = document.querySelector('.hero-swiper');
    if (!swiperEl || swiperEl.swiper || !window.Swiper) return;

    const paginationEl = document.querySelector('.premium-pagination');
    const prevEl = document.querySelector('.premium-nav.prev');
    const nextEl = document.querySelector('.premium-nav.next');

    const swiper = new window.Swiper(swiperEl, {
      init: false,
      slidesPerView: 1,
      loop: true,
      effect: 'fade',
      fadeEffect: { crossFade: true },
      allowTouchMove: true,
      speed: 800,
      autoplay: {
        delay: 6000,
        disableOnInteraction: false,
        pauseOnMouseEnter: true,
      },
      pagination: {
        el: paginationEl,
        clickable: true,
      },
      navigation: {
        prevEl: prevEl,
        nextEl: nextEl,
      },
    });

    requestAnimationFrame(() => {
      swiper.init();
    });
  };

  document.addEventListener('astro:page-load', initHeroSwiper);
  if (document.readyState !== 'loading') initHeroSwiper();
  else document.addEventListener('DOMContentLoaded', initHeroSwiper);
</script>


