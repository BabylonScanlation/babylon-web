---
// src/components/HeroCarousel.astro
import type { Series } from '../types';
import Image from './Image.astro';

interface Props {
  slides: Series[];
  title?: string;
  r2PublicUrlAssets?: string;
}

const { slides = [], title } = Astro.props;
---

<section class="hero-carousel-section">
  {title && <h2 class="carousel-section-title">{title}</h2>}
  
  <div class="carousel-outer-frame">
    <div class="swiper hero-swiper">
      <div class="swiper-wrapper">
        {slides.map((slide, index) => (
          <div class="swiper-slide">
            <a href={`/series/${slide.slug}`} class="slide-main-link" draggable="false" data-astro-prefetch="false">
              <!-- Background layer (Optimized: Using same Image component for cache hit) -->
              <div class="slide-bg-container">
                <Image 
                  src={slide.coverImageUrl || ''} 
                  alt="" 
                  class="slide-bg-art-optimized"
                  loading={index === 0 ? "eager" : "lazy"}
                  width={300}
                  height={450}
                  forceLazy={index !== 0}
                />
              </div>
              <div class="slide-overlay-master" />
              
              <!-- Content layer -->
              <div class="slide-inner-content">
                <div class="content-grid-hero">
                  <div class="hero-art-box">
                    <div class="art-shimmer"></div>
                    <Image
                      src={slide.coverImageUrl || ''}
                      alt={slide.title}
                      class="hero-poster"
                      width={300}
                      height={450}
                      loading={index === 0 ? "eager" : "lazy"}
                      fetchpriority={index === 0 ? "high" : "auto"}
                      forceLazy={index !== 0}
                    />
                  </div>
                  
                  <div class="hero-text-glass">
                    <div class="badge-new">RECOMENDADO</div>
                    <h3 class="hero-title"><span class="hero-title-text">{slide.title}</span></h3>
                    <p class="hero-description">{slide.description}</p>
                    
                    <div class="hero-actions">
                      <span class="btn-read-now">
                        <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2.5" fill="none"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path></svg>
                        LEER AHORA
                      </span>
                    </div>
                  </div>
                </div>
              </div>
            </a>
          </div>
        ))}
      </div>
    </div>
    
    <!-- Premium Controls -->
    <div class="swiper-pagination premium-pagination"></div>
    <!-- Botones Premium con Flecha 'Heavy Delta' Centrada -->
    <div class="premium-nav prev" aria-label="Previous">
      <svg viewBox="0 0 24 24" fill="currentColor" style="overflow: visible !important;">
        <path d="M18 5l-12 7 12 7-3-7 3-7z"></path>
      </svg>
    </div>
    
    <div class="premium-nav next" aria-label="Next">
      <svg viewBox="0 0 24 24" fill="currentColor" style="overflow: visible !important;">
        <path d="M6 5l12 7-12 7 3-7-3-7z"></path>
      </svg>
    </div>
    </div>
    </section>

    <style is:inline>
    .hero-carousel-section {
    width: 100vw; /* Full Viewport Width */
    position: relative;
    left: 50%;
    right: 50%;
    margin-left: -50vw;
    margin-right: -50vw;
    margin-bottom: 3rem;
    z-index: 0;
    }

    .carousel-outer-frame {
    position: relative;
    width: 100%;
    height: 520px; /* Reduced from 600px */
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }

    .hero-swiper {
    width: 100%;
    height: 100%;
    background: #000;
    /* Astra: Evitar flash de duplicado antes de inicializar */
    overflow: hidden;
    }

    .hero-swiper:not(.swiper-initialized) .swiper-slide:not(:first-child) {
    display: none !important;
    }

    .slide-main-link {
    display: block;
    width: 100%;
    height: 100%;
    position: relative;
    text-decoration: none;
    color: inherit;
    overflow: hidden;
    }

    /* Art Layer Optimized */
    .slide-bg-container {
      position: absolute;
      inset: 0;
      z-index: 0;
      overflow: hidden;
      filter: blur(20px) brightness(0.4) saturate(1.2); /* Astra: Desenfoque suavizado y brillo recuperado */
      transform: scale(1.1);

    }

    .slide-bg-art-optimized {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 10s ease-out;
    }

    .swiper-slide-active .slide-bg-art-optimized {
    transform: scale(1.05);
    }

    .slide-overlay-master {
    position: absolute;
    inset: 0;
    background: radial-gradient(
      circle at 50% 50%,
      rgba(0, 0, 0, 0.5) 0%,
      rgba(0, 0, 0, 0.85) 100%
    ); /* Astra: Overlay más centrado y oscuro */
    z-index: 1;
    }

    /* Content Grid */
    .slide-inner-content {
    position: relative;
    z-index: 10;
    width: 100%;
    height: 100%;
    max-width: 100%; /* Astra: Maximizar ancho */
    margin: 0 auto;
    padding: 0 7rem; /* Astra: Espacio aumentado para evitar colisi├│n con flechas */
    display: flex;
    align-items: center;
    justify-content: center;
    }

    .content-grid-hero {
    display: grid;
    grid-template-columns: 280px 1fr; /* Astra: Texto flexible ocupa todo el espacio */
    gap: 4rem;
    align-items: center;
    justify-content: center;
    width: 100%;
    max-width: 1400px; /* Astra: L├¡mite interno para pantallas ultra-wide */
    }

    .hero-art-box {
    position: relative;
    aspect-ratio: 2 / 3;
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 30px 60px rgba(0, 0, 0, 0.8);
    border: 1px solid rgba(255, 255, 255, 0.1);
    transform: perspective(1000px) rotateY(10deg);
    transition: all 0.5s ease;
    }

    .slide-main-link:hover .hero-art-box {
    transform: perspective(1000px) rotateY(0deg) scale(1.02);
    border-color: var(--accent-color);
    }

    .hero-poster {
    width: 100%;
    height: 100%;
    object-fit: cover;
    }

    .art-shimmer {
    position: absolute;
    top: 0;
    left: -150%;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      120deg,
      transparent,
      rgba(255, 255, 255, 0.1),
      transparent
    );
    animation: shimmer 4s infinite;
    }

    @keyframes shimmer {
    0% {
      left: -150%;
    }
    30% {
      left: 150%;
    }
    100% {
      left: 150%;
    }
    }

    /* Text Glass Box */
    .hero-text-glass {
    max-width: 100%; /* Astra: Liberado para ocupar todo el ancho disponible */
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    padding-right: 2rem; /* Astra: Peque├▒o respiro visual contra la flecha derecha */
    }

    .badge-new {
    width: fit-content;
    background: var(--accent-glow);
    color: var(--accent-color);
    padding: 4px 12px;
    border-radius: 100px;
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    border: 1px solid var(--accent-color);
    opacity: 0.9;
    }

    .hero-title {
    font-size: 3.5rem; /* Astra: Reducido ligeramente de 4rem para mayor seguridad */
    font-weight: 900;
    margin: 0;
    line-height: 1.2;
    padding-bottom: 0.1em;
    letter-spacing: -0.02em;
    /* Soluci├│n al filtro oscuro: usar drop-shadow en vez de text-shadow sobre texto transparente */
    filter: drop-shadow(0 10px 15px rgba(0, 0, 0, 0.6));
    /* Astra: Control de desbordamiento para t├¡tulos largos */
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    }

    .hero-title-text {
    /* Degradado met├ílico aplicado por cada l├¡nea individualmente */
    background: linear-gradient(
      to bottom,
      #ffffff 0%,
      #ffffff 15%,
      #dcdcdc 50%,
      #aaaaaa 85%,
      #888888 100%
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    /* La magia definitiva: el degradado envuelve perfectamente cada l├¡nea sin importar los descenders */
    -webkit-box-decoration-break: clone;
    box-decoration-break: clone;
    display: inline;
    }

    .hero-description {
    font-size: 1.15rem;
    color: #aaa;
    line-height: 1.6;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    mask-image: linear-gradient(to bottom, #fff 70%, transparent 100%);
    }

    .hero-actions {
    margin-top: 1rem;
    }

    .btn-read-now {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    background: var(--accent-color);
    color: #000;
    padding: 1rem 2.5rem;
    border-radius: 16px;
    font-weight: 800;
    font-size: 1rem;
    box-shadow: 0 10px 25px var(--accent-glow);
    transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }

    @media (max-width: 900px) {
    .carousel-outer-frame {
      height: auto !important;
      min-height: 520px;
    }
    .slide-inner-content {
      /* Astra: Aumentado padding inferior para proteger la paginación de títulos largos */
      padding: 2.5rem 1.5rem 4.5rem !important;
      height: auto !important;
      min-height: 520px;
    }
    .content-grid-hero {
      grid-template-columns: 1fr !important;
      gap: 2rem !important;
      text-align: center;
    }
    .hero-art-box {
      width: 180px !important;
      margin: 0 auto !important;
      transform: none !important;
      box-shadow: 0 20px 40px rgba(0, 0, 0, 0.6) !important;
    }
    .hero-text-glass {
      align-items: center !important;
      padding-right: 0 !important;
    }
    .hero-title {
      font-size: 2.25rem !important;
    }
    .hero-description {
      font-size: 1rem !important;
      -webkit-line-clamp: 3 !important;
      max-width: 500px;
      margin: 0 auto !important;
    }
    .badge-new {
      margin: 0 auto !important;
    }
    .premium-pagination {
      right: 50% !important;
      transform: translateX(50%) !important;
      bottom: 20px !important;
    }
    }

    @media (max-width: 600px) {
    .carousel-outer-frame,
    .slide-inner-content {
      min-height: 480px;
    }
    .hero-title {
      font-size: 1.85rem !important;
    }
    .hero-art-box {
      width: 140px !important;
    }
    .btn-read-now {
      padding: 0.8rem 2rem;
      font-size: 0.9rem;
    }
    }

    .slide-main-link:hover .btn-read-now {
    transform: scale(1.05) translateY(-3px);
    box-shadow: 0 15px 35px var(--accent-glow);
    }

    /* Controls */
    .premium-pagination {
    bottom: 40px !important;
    left: 50% !important;
    right: auto !important;
    transform: translateX(-50%) !important;
    width: auto !important;
    display: flex;
    justify-content: center;
    gap: 10px;
    z-index: 10;
    }

    :global(.premium-pagination .swiper-pagination-bullet) {
    background: rgba(255, 255, 255, 0.2);
    opacity: 1;
    width: 40px;
    height: 4px;
    border-radius: 100px;
    margin: 0 !important;
    transition: all 0.4s ease;
    }

    :global(.premium-pagination .swiper-pagination-bullet-active) {
    background: var(--accent-color);
    width: 80px;
    box-shadow: 0 0 15px var(--accent-glow);
    }

    /* Consolidated HeroCarousel Styles */
    .premium-nav {
    position: absolute !important;
    width: 56px !important;
    height: 56px !important;
    background: rgba(10, 10, 15, 0.5) !important;
    backdrop-filter: blur(15px) saturate(180%) !important;
    -webkit-backdrop-filter: blur(15px) saturate(180%) !important;
    border: 1px solid rgba(255, 255, 255, 0.1) !important;
    border-radius: 50% !important;
    color: #fff !important;
    top: 50% !important;
    transform: translateY(-50%) !important;
    z-index: 100 !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    padding: 0 !important;
    margin: 0 !important;
    cursor: pointer !important;
    transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1) !important;
    line-height: 0 !important;
    }
    .premium-nav svg {
    width: 32px !important;
    height: 32px !important;
    display: block !important;
    margin: 0 !important;
    flex-shrink: 0 !important;
    transition:
      color 0.3s ease,
      transform 0.3s ease !important;
    filter: none !important;
    }
    .premium-nav:hover {
    background: rgba(10, 10, 15, 0.5) !important;
    border-color: var(--accent-color) !important;
    transform: translateY(-50%) scale(1.1) !important;
    box-shadow:
      0 0 10px var(--accent-color),
      0 0 20px var(--accent-glow) !important;
    }
    .premium-nav:hover svg {
    color: var(--accent-color) !important;
    animation: none !important;
    }
    .premium-nav::after {
    display: none !important;
    }
    .prev {
    left: 2rem !important;
    }
    .next {
    right: 2rem !important;
    }
    @media (max-width: 900px) {
    .premium-nav {
      display: none !important;
    }
    }
    </style>