---
// src/components/HeroCarousel.astro
import type { Series } from '../types';
import { getImageUrl } from '../lib/utils';

interface Props {
  slides: Series[];
  title?: string;
  r2PublicUrlAssets?: string;
}

const { slides = [], title, r2PublicUrlAssets } = Astro.props;

// Orion: Optimización quirúrgica de URL (Solo red, no diseño)
const getOptUrl = (path: any) => {
  const url = getImageUrl(path, r2PublicUrlAssets, 'series');
  const params = 'w=280&q=50&format=avif';
  return url.includes('?') ? `${url}&${params}` : `${url}?${params}`;
};

// Duplicar slides si son pocos
let renderSlides = [...slides];
if (renderSlides.length > 0 && renderSlides.length < 3) {
  while (renderSlides.length < 4) {
    renderSlides = [...renderSlides, ...slides];
  }
}
---

<section class="hero-carousel-section">
  {title && <h2 class="carousel-section-title">{title}</h2>}
  
  <div class="carousel-outer-frame">
    <div class="swiper hero-swiper">
      <div class="swiper-wrapper">
        {renderSlides.map((slide, index) => (
          <div class="swiper-slide">
            <a href={`/series/${slide.slug}`} class="slide-main-link" draggable="false" data-astro-prefetch="false">
              <!-- Background layer -->
              <div
                class="slide-bg-art"
                style={`background-image: url(${getOptUrl(slide.coverImageUrl)})`}
              />
              <div class="slide-overlay-master" />
              
              <!-- Content layer -->
              <div class="slide-inner-content">
                <div class="content-grid-hero">
                  <div class="hero-art-box">
                    <div class="art-shimmer"></div>
                    <img
                      src={getOptUrl(slide.coverImageUrl)}
                      alt={slide.title}
                      class="hero-poster"
                      loading={index === 0 ? "eager" : "lazy"}
                      fetchpriority={index === 0 ? "high" : "auto"}
                      decoding="async"
                      draggable="false"
                    />
                  </div>
                  
                  <div class="hero-text-glass">
                    <div class="badge-new">RECOMENDADO</div>
                    <h3 class="hero-title"><span class="hero-title-text">{slide.title}</span></h3>
                    <p class="hero-description">{slide.description}</p>
                    
                    <div class="hero-actions">
                      <span class="btn-read-now">
                        <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2.5" fill="none"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path></svg>
                        LEER AHORA
                      </span>
                    </div>
                  </div>
                </div>
              </div>
            </a>
          </div>
        ))}
      </div>
    </div>
    
    <!-- Premium Controls -->
    <div class="swiper-pagination premium-pagination"></div>
    <!-- Botones Premium con Flecha 'Heavy Delta' Centrada -->
    <div class="premium-nav prev" aria-label="Previous">
      <svg viewBox="0 0 24 24" fill="currentColor" style="overflow: visible !important;">
        <path d="M18 5l-12 7 12 7-3-7 3-7z"></path>
      </svg>
    </div>
    
    <div class="premium-nav next" aria-label="Next">
      <svg viewBox="0 0 24 24" fill="currentColor" style="overflow: visible !important;">
        <path d="M6 5l12 7-12 7 3-7-3-7z"></path>
      </svg>
    </div>
  </div>
</section>

<style is:global>
  .premium-nav {
    position: absolute !important;
    width: 56px !important;
    height: 56px !important;
    background: rgba(10, 10, 15, 0.5) !important;
    backdrop-filter: blur(15px) saturate(180%) !important;
    -webkit-backdrop-filter: blur(15px) saturate(180%) !important;
    border: 1px solid rgba(255, 255, 255, 0.1) !important;
    border-radius: 50% !important;
    color: #fff !important;
    top: 50% !important;
    transform: translateY(-50%) !important;
    z-index: 100 !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    padding: 0 !important; /* Astra: Eliminar padding para centrado real */
    margin: 0 !important;
    cursor: pointer !important;
    transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1) !important;
    line-height: 0 !important;
  }

  .premium-nav svg {
    width: 32px !important; 
    height: 32px !important;
    display: block !important;
    margin: 0 !important;
    flex-shrink: 0 !important;
    transition: color 0.3s ease, transform 0.3s ease !important;
    filter: none !important;
  }

  .premium-nav:hover {
    background: rgba(10, 10, 15, 0.5) !important;
    border-color: var(--accent-color) !important;
    transform: translateY(-50%) scale(1.1) !important;
    /* Resplandor Externo del Círculo Reducido */
    box-shadow: 0 0 10px var(--accent-color), 0 0 20px var(--accent-glow) !important;
  }

  .premium-nav:hover svg {
    color: var(--accent-color) !important;
    animation: none !important; /* Eliminado pulso interno */
  }

  .premium-nav::after { display: none !important; }

  .prev { left: 2rem !important; }
  .next { right: 2rem !important; }

  @media (max-width: 900px) {
    .premium-nav { display: none !important; }
  }
</style>