---
// src/components/HeroCarousel.astro
import type { Series } from '../types';
import { getImageUrl } from '../lib/utils';
import 'swiper/css';
import 'swiper/css/pagination';
import 'swiper/css/navigation';
import 'swiper/css/effect-fade';

interface Props {
  slides: Series[];
  title?: string;
  r2PublicUrlAssets?: string;
}

const { slides = [], title, r2PublicUrlAssets } = Astro.props;

// Duplicar slides si son pocos
let renderSlides = [...slides];
if (renderSlides.length > 0 && renderSlides.length < 3) {
  while (renderSlides.length < 4) {
    renderSlides = [...renderSlides, ...slides];
  }
}
---

<section class="hero-carousel-section">
  {title && <h2 class="carousel-section-title">{title}</h2>}
  
  <div class="carousel-outer-frame">
    <div class="swiper hero-swiper">
      <div class="swiper-wrapper">
        {renderSlides.map((slide) => (
          <div class="swiper-slide">
            <a href={`/series/${slide.slug}`} class="slide-main-link" draggable="false">
              <!-- Background layer -->
              <div
                class="slide-bg-art"
                style={`background-image: url(${getImageUrl(slide.coverImageUrl, r2PublicUrlAssets, 'series')})`}
              />
              <div class="slide-overlay-master" />
              
              <!-- Content layer -->
              <div class="slide-inner-content">
                <div class="content-grid-hero">
                  <div class="hero-art-box">
                    <div class="art-shimmer"></div>
                    <img
                      src={getImageUrl(slide.coverImageUrl, r2PublicUrlAssets, 'series')}
                      alt={slide.title}
                      class="hero-poster"
                      loading="lazy"
                      draggable="false"
                    />
                  </div>
                  
                  <div class="hero-text-glass">
                    <div class="badge-new">RECOMENDADO</div>
                    <h3 class="hero-title">{slide.title}</h3>
                    <p class="hero-description">{slide.description}</p>
                    
                    <div class="hero-actions">
                      <span class="btn-read-now">
                        <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2.5" fill="none"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path></svg>
                        LEER AHORA
                      </span>
                    </div>
                  </div>
                </div>
              </div>
            </a>
          </div>
        ))}
      </div>
    </div>
    
    <!-- Premium Controls -->
    <div class="swiper-pagination premium-pagination"></div>
    <div class="swiper-button-prev premium-nav prev">
      <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="3" fill="none"><polyline points="15 18 9 12 15 6"></polyline></svg>
    </div>
    <div class="swiper-button-next premium-nav next">
      <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="3" fill="none"><polyline points="9 18 15 12 9 6"></polyline></svg>
    </div>
  </div>
</section>

<script>
  import Swiper from 'swiper';
  import { Pagination, Navigation, Autoplay, EffectFade } from 'swiper/modules';

  const initSwiper = () => {
    const swiperEl = document.querySelector('.hero-swiper') as HTMLElement;
    if (!swiperEl || (swiperEl as any).swiper) return;

    const setup = () => {
      const paginationEl = document.querySelector('.premium-pagination') as HTMLElement;
      const prevEl = document.querySelector('.premium-nav.prev') as HTMLElement;
      const nextEl = document.querySelector('.premium-nav.next') as HTMLElement;

      const swiper = new Swiper(swiperEl, {
        modules: [Pagination, Navigation, Autoplay, EffectFade],
        init: false, // Orion: Init diferido
        slidesPerView: 1,
        loop: true,
        effect: 'fade',
        fadeEffect: { crossFade: true },
        allowTouchMove: true,
        speed: 800,
        autoplay: {
          delay: 6000,
          disableOnInteraction: false,
          pauseOnMouseEnter: true,
        },
        pagination: {
          el: paginationEl,
          clickable: true,
        },
        navigation: {
          prevEl: prevEl,
          nextEl: nextEl,
        },
      });

      requestAnimationFrame(() => {
        swiper.init();
      });
    };

    // Astra: Inicialización inmediata para el Hero (está arriba), pero sin bloquear frame
    if ('IntersectionObserver' in window) {
      const observer = new IntersectionObserver((entries) => {
        if (entries && entries[0] && entries[0].isIntersecting) {
          setup();
          observer.disconnect();
        }
      }, { rootMargin: '200px' });
      observer.observe(swiperEl);
    } else {
      setup();
    }
  };

  document.addEventListener('astro:page-load', initSwiper);
  
  if (document.readyState !== 'loading') {
    initSwiper();
  } else {
    document.addEventListener('DOMContentLoaded', initSwiper);
  }
</script>

<style>
  .hero-carousel-section {
    width: 100vw; /* Full Viewport Width */
    position: relative;
    left: 50%;
    right: 50%;
    margin-left: -50vw;
    margin-right: -50vw;
    margin-bottom: 3rem;
    z-index: 0;
  }

  .carousel-outer-frame {
    position: relative;
    width: 100%;
    height: 520px; /* Reduced from 600px */
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }

  .hero-swiper {
    width: 100%;
    height: 100%;
    background: #000;
  }

  .slide-main-link {
    display: block;
    width: 100%;
    height: 100%;
    position: relative;
    text-decoration: none;
    color: inherit;
    overflow: hidden;
  }

  /* Art Layer */
  .slide-bg-art {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center 20%;
    filter: blur(20px) brightness(0.4) saturate(1.2);
    transform: scale(1.1);
    transition: transform 10s ease-out;
  }

  .swiper-slide-active .slide-bg-art {
    transform: scale(1);
  }

  .slide-overlay-master {
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 20% 50%, rgba(0,0,0,0.4) 0%, rgba(0,0,0,0.8) 100%);
    z-index: 1;
  }

  /* Content Grid */
  .slide-inner-content {
    position: relative;
    z-index: 10;
    width: 100%;
    height: 100%;
    max-width: 100%; /* Astra: Maximizar ancho */
    margin: 0 auto;
    padding: 0 7rem; /* Astra: Espacio aumentado para evitar colisión con flechas */
    display: flex;
    align-items: center;
    justify-content: center; 
  }

  .content-grid-hero {
    display: grid;
    grid-template-columns: 280px 1fr; /* Astra: Texto flexible ocupa todo el espacio */
    gap: 4rem;
    align-items: center;
    justify-content: center;
    width: 100%;
    max-width: 1400px; /* Astra: Límite interno para pantallas ultra-wide */
  }

  .hero-art-box {
    position: relative;
    aspect-ratio: 2/3;
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 30px 60px rgba(0, 0, 0, 0.8);
    border: 1px solid rgba(255, 255, 255, 0.1);
    transform: perspective(1000px) rotateY(10deg);
    transition: all 0.5s ease;
  }

  .slide-main-link:hover .hero-art-box {
    transform: perspective(1000px) rotateY(0deg) scale(1.02);
    border-color: var(--accent-color);
  }

  .hero-poster {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .art-shimmer {
    position: absolute;
    top: 0;
    left: -150%;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      120deg,
      transparent,
      rgba(255, 255, 255, 0.1),
      transparent
    );
    animation: shimmer 4s infinite;
  }

  @keyframes shimmer {
    0% { left: -150%; }
    30% { left: 150%; }
    100% { left: 150%; }
  }

  /* Text Glass Box */
  .hero-text-glass {
    max-width: 100%; /* Astra: Liberado para ocupar todo el ancho disponible */
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    padding-right: 2rem; /* Astra: Pequeño respiro visual contra la flecha derecha */
  }

  .badge-new {
    width: fit-content;
    background: var(--accent-glow);
    color: var(--accent-color);
    padding: 4px 12px;
    border-radius: 100px;
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    border: 1px solid var(--accent-color);
    opacity: 0.9;
  }

  .hero-title {
    font-size: 3.5rem; /* Astra: Reducido ligeramente de 4rem para mayor seguridad */
    font-weight: 900;
    color: #fff;
    margin: 0;
    line-height: 1.1;
    letter-spacing: -0.02em;
    text-shadow: 0 10px 30px rgba(0,0,0,0.5);
    background: linear-gradient(to bottom, #fff, #ccc);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    /* Astra: Control de desbordamiento para títulos largos */
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .hero-description {
    font-size: 1.15rem;
    color: #aaa;
    line-height: 1.6;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    mask-image: linear-gradient(to bottom, #fff 70%, transparent 100%);
  }

  .hero-actions {
    margin-top: 1rem;
  }

  .btn-read-now {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    background: var(--accent-color);
    color: #000;
    padding: 1rem 2.5rem;
    border-radius: 16px;
    font-weight: 800;
    font-size: 1rem;
    box-shadow: 0 10px 25px var(--accent-glow);
    transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }

  .slide-main-link:hover .btn-read-now {
    transform: scale(1.05) translateY(-3px);
    box-shadow: 0 15px 35px var(--accent-glow);
  }

  /* Controls */
  .premium-pagination {
    bottom: 40px !important;
    left: auto !important;
    right: 4rem !important;
    width: auto !important;
    display: flex;
    gap: 10px;
  }

  :global(.premium-pagination .swiper-pagination-bullet) {
    background: rgba(255, 255, 255, 0.2);
    opacity: 1;
    width: 40px;
    height: 4px;
    border-radius: 100px;
    margin: 0 !important;
    transition: all 0.4s ease;
  }

  :global(.premium-pagination .swiper-pagination-bullet-active) {
    background: var(--accent-color);
    width: 80px;
    box-shadow: 0 0 15px var(--accent-glow);
  }

  .premium-nav {
    width: 50px;
    height: 50px;
    background: rgba(0, 0, 0, 0.3);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 50%;
    color: #fff;
    transition: all 0.3s ease;
    top: 50%;
    transform: translateY(-50%);
    z-index: 20;
  }

  .premium-nav:hover {
    background: var(--accent-color);
    color: #000;
    border-color: var(--accent-color);
    transform: translateY(-50%) scale(1.1);
  }

  .premium-nav::after { display: none; }

  .prev { left: 2rem; }
  .next { right: 2rem; }

  /* Mobile Adjustments - Cinematic Style */
  @media (max-width: 900px) {
    .hero-carousel-section {
      z-index: 0;
      position: relative;
      margin-top: 0; /* Astra: Espaciado reducido para pegar el carrusel al Header */
    }

    .carousel-outer-frame { 
      height: 600px; /* Restaurado para impacto vertical en móvil */
      overflow: hidden; 
      border-radius: 0; /* Astra: Bordes rectos para un look cinemático total */
      margin-top: 0;
      /* Super aggressive clipping fix for mobile WebKit */
      -webkit-mask-image: none;
      mask-image: none;
      transform: translate3d(0, 0, 0);
    }
    
    .slide-inner-content { 
      padding: 0 1.5rem; 
      align-items: flex-end; 
      padding-bottom: 4rem; 
      /* padding-top removed, handled by margin */
    }

    .content-grid-hero { 
      grid-template-columns: 1fr; 
      gap: 1.5rem; 
      text-align: center; 
    }

    .hero-art-box { 
      width: 130px; 
      margin: 0 auto; 
      transform: none !important; /* Force disable 3D */
      position: relative; /* Reset position */
      box-shadow: 0 15px 35px rgba(0,0,0,0.8);
    }

    .hero-text-glass { 
      align-items: center; 
      gap: 0.75rem;
      padding-right: 0;
    }

    .slide-bg-art {
        z-index: -1; /* Nuclear option: push to background layer */
        transform: none !important; /* Disable zoom animation on mobile to fix overflow */
        background-position: center center !important; /* Center the art */
    }

    .hero-title { 
      font-size: 2.2rem; 
      line-height: 1.1;
    }

    .hero-description { 
      font-size: 0.9rem; 
      -webkit-line-clamp: 2; 
      opacity: 0.7;
      max-width: 90%;
    }

    .btn-read-now {
      padding: 0.8rem 2rem;
      font-size: 0.9rem;
      border-radius: 12px;
    }

    /* Keep pagination but make it discreet */
    .premium-pagination {
      display: flex !important;
      right: 50% !important;
      transform: translateX(50%);
      bottom: 15px !important;
    }

    :global(.premium-pagination .swiper-pagination-bullet) {
      width: 20px;
      height: 3px;
    }

    :global(.premium-pagination .swiper-pagination-bullet-active) {
      width: 40px;
    }

    .premium-nav { display: none; }
    
    .slide-overlay-master { 
      background: linear-gradient(to top, 
        rgba(0,0,0,1) 0%, 
        rgba(0,0,0,0.8) 40%, 
        rgba(0,0,0,0.2) 100%
      ); 
    }
  }
</style>