---
import type { Series } from '../types';
import Image from './Image.astro';

interface Props {
  mangas: Series[];
}

const { mangas = [] } = Astro.props;
const displayMangas = mangas.slice(0, 6);
---

<section class="featured-premium-section">
  <div class="section-header centered">
    <div class="header-line"></div>
    <h2 class="section-title">
      <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2.5" fill="none"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
      Lo más destacado
    </h2>
    <div class="header-line reversed"></div>
  </div>

  <div class="featured-grid-3x2">
    {
      displayMangas.map((manga) => (
        <div class="featured-card-wrapper">
          <a href={`/series/${manga.slug}`} class="featured-card-premium" data-astro-prefetch="false">
            <div class="card-art-box">
              <Image
                src={manga.coverImageUrl || ''}
                alt={manga.title}
                class="card-image"
                width={300}
                height={450}
                loading="lazy"
                style={`transition-name: cover-${manga.slug}`}
              />
              <div class="card-overlay-gradient"></div>
            </div>

            <div class="card-badge-vistas">
              <div class="glass-tag">
                <svg viewBox="0 0 24 24" width="14" height="14" stroke="currentColor" stroke-width="3" fill="none"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"/></svg>
                <span>{manga.views?.toLocaleString() || 0}</span>
              </div>
            </div>

            <div class="card-action-overlay">
              <div class="action-pill">
                <span>LEER AHORA</span>
                <svg viewBox="0 0 24 24" width="14" height="14" stroke="currentColor" stroke-width="3" fill="none"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
              </div>
            </div>

            <div class="card-info-content">
              <div class="title-row">
                <h3 class="manga-title">{manga.title}</h3>
              </div>
              <p class="manga-description">{manga.description}</p>
            </div>
          </a>
        </div>
      ))
    }
  </div>
</section>

<style is:inline>
  .featured-premium-section {
    width: 100%;
    margin: 0;
  }

  .section-header.centered {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 2rem;
    margin-bottom: 1.5rem;
    width: 100%;
  }

  .header-line {
    height: 1px;
    width: 100%;
    background: linear-gradient(90deg, transparent, var(--accent-color));
    opacity: 0.2;
  }

  .header-line.reversed {
    background: linear-gradient(90deg, var(--accent-color), transparent);
  }

  .section-title {
    font-size: 1.6rem;
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    white-space: nowrap;
  }

  .section-title svg {
    color: var(--accent-color);
  }

  .featured-grid-3x2 {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .featured-card-premium {
    position: relative;
    height: 100%;
    width: 100%;
    border-radius: 24px;
    overflow: hidden;
    background: #1a1a1a;
    border: 1px solid rgba(255, 255, 255, 0.05);
    text-decoration: none;
    transition: all 0.4s cubic-bezier(0.25, 0.8, 0.25, 1);
    display: block;
  }

  .featured-card-wrapper {
    height: 320px;
    padding: 10px 0;
    margin-top: -10px;
  }

  .featured-card-wrapper:hover .featured-card-premium {
    transform: translateY(-10px);
    border-color: var(--accent-color);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.6);
  }

  .card-art-box {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }

  .featured-card-wrapper:hover .card-image {
    transform: scale(1.1);
  }

  .card-overlay-gradient {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.95) 0%,
      rgba(0, 0, 0, 0.6) 50%,
      transparent 100%
    );
  }

  .card-badge-vistas {
    position: absolute;
    top: 1.25rem;
    right: 1.25rem;
    z-index: 5;
  }

  .glass-tag {
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: #fff;
    font-size: 0.75rem;
    padding: 4px 10px;
    border-radius: 100px;
    font-weight: 800;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .card-info-content {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 1.5rem;
    z-index: 5;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .manga-title {
    font-size: 1.3rem;
    font-weight: 800;
    color: #fff;
    margin: 0;
    line-height: 1.2;
    text-shadow: 0 2px 10px rgba(0, 0, 0, 0.5);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .manga-description {
    font-size: 0.85rem;
    color: #aaa;
    line-height: 1.5;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    opacity: 0.8;
  }

  .card-action-overlay {
    position: absolute;
    top: 1.25rem;
    left: 1.25rem;
    z-index: 10;
    opacity: 0;
    transform: translateY(-10px);
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    pointer-events: none;
  }

  .featured-card-wrapper:hover .card-action-overlay {
    opacity: 1;
    transform: translateY(0);
  }

  .action-pill {
    background: var(--accent-color);
    color: #000;
    padding: 6px 14px;
    border-radius: 100px;
    font-size: 0.7rem;
    font-weight: 900;
    letter-spacing: 0.05em;
    display: flex;
    align-items: center;
    gap: 8px;
    box-shadow: 0 10px 20px var(--accent-glow);
  }

  @media (max-width: 1100px) {
    .featured-grid-3x2 {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .featured-grid-3x2 {
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem;
    }
    .featured-card-wrapper {
      height: 240px;
      padding: 0;
      margin: 0;
    }
    .featured-card-premium {
      height: 240px;
      border-radius: 16px;
    }
    .card-info-content {
      padding: 1rem;
      gap: 0.25rem;
    }
    .manga-title {
      font-size: 0.95rem;
    }
    .manga-description {
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
      font-size: 0.75rem;
      opacity: 0.6;
      line-height: 1.3;
    }
    .section-title {
      font-size: 1.2rem;
    }
    .glass-tag {
      padding: 2px 6px;
      font-size: 0.65rem;
    }
  }

  .featured-card-premium:hover .card-image {
    transform: scale(1.1) rotate(-1deg);
  }
  .card-info-content {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    padding: 1.5rem;
    z-index: 2;
    transform: translateY(10px);
    transition: transform 0.4s ease;
  }
  .featured-card-premium:hover .card-info-content {
    transform: translateY(0);
  }
  .card-badge-vistas,
  .card-action-overlay {
    display: contents !important;
    transform: none !important;
    opacity: 1 !important;
  }
  .featured-card-premium .glass-tag,
  .featured-card-premium .action-pill {
    position: absolute !important;
    top: 1rem !important;
    height: 32px !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    padding: 0 0.85rem !important;
    border-radius: 100px !important;
    font-size: 0.72rem !important;
    font-weight: 900 !important;
    text-transform: uppercase !important;
    letter-spacing: 0.05em !important;
    backdrop-filter: blur(12px) !important;
    border: 1px solid rgba(255, 255, 255, 0.15) !important;
    transition:
      transform 0.4s ease-out,
      color 0.3s ease,
      background 0.3s ease,
      box-shadow 0.3s ease !important;
    z-index: 50 !important;
    box-sizing: border-box !important;
    margin: 0 !important;
    transform: translateY(0) scale(1) !important;
  }
  .featured-card-premium .glass-tag {
    right: 1rem !important;
    left: auto !important;
    background: rgba(0, 0, 0, 0.75) !important;
    color: #fff !important;
  }
  .featured-card-premium .action-pill {
    left: 1rem !important;
    right: auto !important;
    background: rgba(0, 0, 0, 0.75) !important;
    color: #fff !important;
  }
  .featured-card-premium:hover .glass-tag {
    color: var(--accent-color) !important;
    border-color: var(--accent-color) !important;
    box-shadow: 0 0 20px var(--accent-glow) !important;
    transform: translateY(0) scale(1.04) !important;
  }
  .featured-card-premium:hover .action-pill {
    background: var(--accent-color) !important;
    color: #000 !important;
    border-color: var(--accent-color) !important;
    box-shadow: 0 0 20px var(--accent-glow) !important;
    transform: translateY(0) scale(1.04) !important;
  }
  @media (max-width: 1024px) {
    .featured-grid-3x2 {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.5rem;
    }
  }
  @media (max-width: 768px) {
    .section-header.centered {
      grid-template-columns: auto 1fr;
      gap: 1rem;
    }
    .header-line {
      display: none;
    }
    .featured-grid-3x2 {
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem;
    }
    .manga-title {
      font-size: 1.1rem;
    }
    .manga-description {
      -webkit-line-clamp: 5;
      font-size: 0.7rem;
      line-height: 1.25;
      color: rgba(255, 255, 255, 0.8);
    }
    .featured-card-premium .glass-tag,
    .featured-card-premium .action-pill {
      height: 24px !important;
      padding: 0 0.5rem !important;
      font-size: 0.58rem !important;
      top: 0.5rem !important;
    }
    .featured-card-premium .glass-tag svg,
    .featured-card-premium .action-pill svg {
      width: 12px !important;
      height: 12px !important;
    }
    .featured-card-premium .glass-tag {
      right: 0.5rem !important;
    }
    .featured-card-premium .action-pill {
      left: 0.5rem !important;
    }
  }
  @media (max-width: 480px) {
    .featured-grid-3x2 {
      gap: 0.75rem;
    }
    .manga-title {
      font-size: 0.95rem;
    }
    .card-info-content {
      padding: 1rem;
    }
  }
</style>


