---
import type { Series } from '../types';
import Image from './Image.astro';

interface Props {
  mangas: Series[];
}

const { mangas = [] } = Astro.props;
const displayMangas = mangas.slice(0, 6);
---

<section class="featured-premium-section">
  <div class="section-header centered">
    <div class="header-line"></div>
    <h2 class="section-title">
      <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2.5" fill="none"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
      Lo más destacado
    </h2>
    <div class="header-line reversed"></div>
  </div>

  <div class="featured-grid-3x2">
    {
      displayMangas.map((manga, index) => (
        <div class="featured-card-wrapper">
          <a href={`/series/${manga.slug}`} class="featured-card-premium" data-astro-prefetch="false">
            <div class="card-art-box">
              <Image
                src={manga.coverImageUrl || ''}
                alt={manga.title}
                class="card-image"
                width={300}
                height={450}
                loading={index < 2 ? "eager" : "lazy"}
                style={`transition-name: cover-${manga.slug}`}
                fetchpriority={index < 2 ? 'high' : 'auto'}
                forceLazy={true}
              />
              <div class="card-overlay-gradient"></div>
            </div>

            <div class="card-badge-vistas">
              <div class="glass-tag">
                <svg viewBox="0 0 24 24" width="14" height="14" stroke="currentColor" stroke-width="3" fill="none"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"/></svg>
                <span>{manga.views?.toLocaleString() || 0}</span>
              </div>
            </div>

            <div class="card-action-overlay">
              <div class="action-pill">
                <span>LEER AHORA</span>
                <svg viewBox="0 0 24 24" width="14" height="14" stroke="currentColor" stroke-width="3" fill="none"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
              </div>
            </div>

            <div class="card-info-content">
              <div class="title-row">
                <h3 class="manga-title">{manga.title}</h3>
              </div>
              <p class="manga-description">{manga.description}</p>
            </div>
          </a>
        </div>
      ))
    }
  </div>
</section>

<style>
  .featured-premium-section {
    width: 100%;
    margin: 0;
  }

  .section-header.centered {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 2rem;
    margin-bottom: 2rem;
    width: 100%;
  }

  .header-line { height: 1px; width: 100%; background: linear-gradient(90deg, transparent, var(--accent-color)); opacity: 0.2; }
  .header-line.reversed { background: linear-gradient(90deg, var(--accent-color), transparent); }

  .section-title {
    font-size: 1.6rem; color: #fff; display: flex; align-items: center; gap: 0.75rem;
    font-weight: 900; text-transform: uppercase; letter-spacing: 0.2em;
  }

  .section-title svg { color: var(--accent-color); }

  .featured-grid-3x2 {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    width: 100%;
  }

  .featured-card-wrapper {
    position: relative;
    width: 100%;
    aspect-ratio: 16/10;
    border-radius: 20px;
    overflow: hidden;
    background: #000;
  }

  .featured-card-premium {
    display: block;
    width: 100%;
    height: 100%;
    text-decoration: none;
    position: relative;
  }

  .card-art-box {
    width: 100%;
    height: 100%;
    position: relative;
    overflow: hidden;
  }

  .card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.165, 0.84, 0.44, 1);
  }

  .featured-card-premium:hover .card-image {
    transform: scale(1.1) rotate(-1deg);
  }

  .card-overlay-gradient {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.9) 0%, rgba(0,0,0,0.4) 50%, transparent 100%);
    z-index: 1;
  }

  .card-info-content {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    padding: 1.5rem;
    z-index: 2;
    transform: translateY(10px);
    transition: transform 0.4s ease;
  }

  .featured-card-premium:hover .card-info-content {
    transform: translateY(0);
  }

  .manga-title {
    color: #fff;
    font-size: 1.4rem;
    font-weight: 900;
    margin-bottom: 0.5rem;
    text-shadow: 0 2px 10px rgba(0,0,0,0.5);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .manga-description {
    color: rgba(255,255,255,0.7);
    font-size: 0.82rem;
    line-height: 1.35;
    display: -webkit-box;
    -webkit-line-clamp: 5;
    -webkit-box-orient: vertical;
    overflow: hidden;
    opacity: 1;
    transition: color 0.4s ease;
  }

  .featured-card-premium:hover .manga-description {
    color: #fff;
  }

  /* Contenedores - Neutralizamos cualquier movimiento heredado */
  .card-badge-vistas, .card-action-overlay {
    display: contents !important;
    transform: none !important; /* Orion: Bloqueamos desplazamientos verticales de global.css */
    opacity: 1 !important;
  }

  /* Elementos Finales (Forzamos posición exacta y estática) */
  .featured-card-premium .glass-tag, 
  .featured-card-premium .action-pill {
    position: absolute !important;
    top: 1rem !important;
    height: 32px !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    padding: 0 0.85rem !important;
    border-radius: 100px !important;
    font-size: 0.72rem !important;
    font-weight: 900 !important;
    text-transform: uppercase !important;
    letter-spacing: 0.05em !important;
    backdrop-filter: blur(12px) !important;
    border: 1px solid rgba(255, 255, 255, 0.15) !important;
    transition: transform 0.4s ease-out, color 0.3s ease, background 0.3s ease, box-shadow 0.3s ease !important;
    z-index: 50 !important;
    box-sizing: border-box !important;
    margin: 0 !important;
    transform: translateY(0) scale(1) !important; /* Orion: Forzamos translateY(0) para evitar elevación */
  }

  .featured-card-premium .glass-tag {
    right: 1rem !important;
    left: auto !important;
    background: rgba(0, 0, 0, 0.75) !important;
    color: #fff !important;
  }

  .featured-card-premium .action-pill {
    left: 1rem !important;
    right: auto !important;
    background: rgba(0, 0, 0, 0.75) !important;
    color: #fff !important;
  }

  /* Efecto Hover Sincronizado (Solo Escala, Cero Desplazamiento) */
  .featured-card-premium:hover .glass-tag {
    color: var(--accent-color) !important;
    border-color: var(--accent-color) !important;
    box-shadow: 0 0 20px var(--accent-glow) !important;
    transform: translateY(0) scale(1.04) !important;
  }

  .featured-card-premium:hover .action-pill {
    background: var(--accent-color) !important;
    color: #000 !important;
    border-color: var(--accent-color) !important;
    box-shadow: 0 0 20px var(--accent-glow) !important;
    transform: translateY(0) scale(1.04) !important;
  }

  @media (max-width: 1024px) {
    .featured-grid-3x2 { grid-template-columns: repeat(2, 1fr); gap: 1.5rem; }
  }

  @media (max-width: 768px) {
    .section-header.centered { grid-template-columns: auto 1fr; gap: 1rem; }
    .header-line { display: none; }
    .featured-grid-3x2 { grid-template-columns: repeat(2, 1fr); gap: 1rem; }
    .manga-title { font-size: 1.1rem; }
    .manga-description { 
      -webkit-line-clamp: 5; 
      font-size: 0.7rem; 
      line-height: 1.25; 
      color: rgba(255, 255, 255, 0.8);
    }
    .featured-card-premium .glass-tag, 
    .featured-card-premium .action-pill {
      height: 24px !important;
      padding: 0 0.5rem !important;
      font-size: 0.58rem !important;
      top: 0.5rem !important;
    }
    .featured-card-premium .glass-tag svg,
    .featured-card-premium .action-pill svg {
      width: 12px !important;
      height: 12px !important;
    }
    .featured-card-premium .glass-tag { right: 0.5rem !important; }
    .featured-card-premium .action-pill { left: 0.5rem !important; }
  }

  @media (max-width: 480px) {
    .featured-grid-3x2 { gap: 0.75rem; }
    .manga-title { font-size: 0.95rem; }
    .card-info-content { padding: 1rem; }
  }
</style>


