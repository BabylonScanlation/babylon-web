---
import { siteConfig } from '../site.config';
import NewsCounter from './NewsCounter.svelte';

const currentYear = new Date().getFullYear();
const { runtime } = Astro.locals;
const r2PublicUrlAssets = runtime.env.R2_PUBLIC_URL_ASSETS || '/api/assets/proxy';
---

<footer class="premium-footer">
  <NewsCounter client:idle />
  <div class="footer-glow"></div>
  
  <div class="footer-container">
    <div class="footer-grid">
      <!-- Sección Marca -->
      <div class="footer-brand">
        <a href="/" class="footer-logo">
          <img
            src={siteConfig.assets.logoHeader.startsWith('/') ? `${r2PublicUrlAssets}${siteConfig.assets.logoHeader}` : siteConfig.assets.logoHeader}
            alt={`${siteConfig.name} Logo`}
            class="logo-img"
          />
        </a>
        <p class="brand-description">
          {siteConfig.description}
        </p>
        <div class="social-pills">
          <a href={siteConfig.links.discord} class="social-pill discord" aria-label="Discord">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor"><path d="M20.317 4.3698a19.7913 19.7913 0 00-4.8851-1.5152.0741.0741 0 00-.0785.0371c-.211.3753-.4447.8648-.6083 1.2495-1.8447-.2762-3.68-.2762-5.4868 0-.1636-.3933-.4058-.8742-.6177-1.2495a.077.077 0 00-.0785-.037 19.7363 19.7363 0 00-4.8852 1.515.0699.0699 0 00-.0321.0277C.5334 9.0458-.319 13.5799.0992 18.0578a.0824.0824 0 00.0312.0561c2.0528 1.5076 4.0413 2.4228 5.9929 3.0294a.0777.0777 0 00.0842-.0276c.4616-.6304.8731-1.2952 1.226-1.9942a.076.076 0 00-.0416-.1057c-.6528-.2476-1.2743-.5495-1.8722-.8923a.077.077 0 01-.0076-.1277c.1258-.0943.2517-.1923.3718-.2914a.0743.0743 0 01.0776-.0105c3.9278 1.7933 8.18 1.7933 12.0614 0a.0739.0739 0 01.0785.0095c.1202.099.246.1981.3728.2924a.077.077 0 01-.0066.1276 12.2986 12.2986 0 01-1.873.8914.0766.0766 0 00-.0407.1067c.3604.698.7719 1.3628 1.225 1.9932a.076.076 0 00.0842.0286c1.961-.6067 3.9495-1.5219 6.0023-3.0294a.077.077 0 00.0313-.0552c.5004-5.177-.8382-9.6739-3.5485-13.6604a.061.061 0 00-.0312-.0286zM8.02 15.3312c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9555-2.4189 2.157-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.9555 2.4189-2.1569 2.4189zm7.9748 0c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9554-2.4189 2.1569-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.946 2.4189-2.1568 2.4189Z"/></svg>
          </a>
          <a href={siteConfig.links.telegram} class="social-pill telegram" aria-label="Telegram">
             <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor"><path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm5.562 8.161c-.18.717-3.956 16.517-3.956 16.517s-.11.458-.55.458c-.33 0-.58-.18-.58-.18l-5.61-4.14-2.82 2.76s-.22.24-.46.24c-.22 0-.42-.18-.42-.18s-.06-.24-.02-.74l.95-6.52L2.04 12.38s-.36-.18-.36-.54c0-.33.36-.51.36-.51l16.14-6.22s.36-.12.57-.12c.24 0 .44.18.44.18s.11.18.06.51z"/></svg>
          </a>
          <a href="#" class="social-pill facebook" aria-label="Facebook">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor"><path d="M22.675 0h-21.35C.585 0 0 .585 0 1.325v21.351C0 23.415.585 24 1.325 24H12.82v-9.294H9.692v-3.622h3.128V8.413c0-3.1 1.893-4.788 4.659-4.788 1.325 0 2.463.099 2.795.143v3.24l-1.918.001c-1.504 0-1.795.715-1.795 1.763v2.313h3.587l-.467 3.622h-3.12V24h6.116c.74 0 1.325-.585 1.325-1.325V1.325C24 .585 23.415 0 22.675 0z"/></svg>
          </a>
        </div>
      </div>

      <!-- Sección Enlaces -->
      <div class="footer-links">
        <h4 class="footer-title">Explorar</h4>
        <ul>
          <li><a href="/search">Biblioteca</a></li>
          <li><a href="/news">Noticias</a></li>
          <li><a href="/profile">Mi Cuenta</a></li>
        </ul>
      </div>

      <!-- Sección Soporte -->
      <div class="footer-links">
        <h4 class="footer-title">Legal</h4>
        <ul>
          <li><a href="/terms">Términos de Uso</a></li>
          <li><a href="/terms#privacy">Privacidad</a></li>
        </ul>
      </div>

      <!-- Sección App -->
      <div class="footer-cta">
        <h4 class="footer-title">{siteConfig.shortName} Mobile</h4>
        <p>Lleva tus series favoritas a todas partes. Descarga nuestra aplicación oficial para Android y disfruta de la mejor experiencia.</p>
        <div class="app-download-container">
          <a href={siteConfig.app.androidUrl} class="download-btn-premium" download>
            <div class="btn-icon">
              <svg viewBox="0 0 24 24" width="24" height="24" fill="currentColor"><path d="M17.523 15.3414C17.523 14.8606 17.1332 14.4709 16.6524 14.4709C16.1716 14.4709 15.7819 14.8606 15.7819 15.3414C15.7819 15.8222 16.1716 16.2119 16.6524 16.2119C17.1332 16.2119 17.523 15.8222 17.523 15.3414ZM8.2181 16.2119C8.69888 16.2119 9.08862 15.8222 9.08862 15.3414C9.08862 14.8606 8.69888 14.4709 8.2181 14.4709C7.73733 14.4709 7.34758 14.8606 7.34758 15.3414C7.34758 15.8222 7.73733 16.2119 8.2181 16.2119ZM17.9835 11.5831L19.7913 8.45198C19.914 8.2394 19.8413 7.96733 19.6287 7.84462C19.4161 7.72191 19.1441 7.79463 19.0214 8.00721L17.1856 11.1861C15.711 10.5126 14.054 10.1245 12.3002 10.1245C10.5465 10.1245 8.88944 10.5126 7.41488 11.1861L5.57902 8.00721C5.45631 7.79463 5.18424 7.72191 4.97166 7.84462C4.75908 7.96733 4.68636 8.2394 4.80907 8.45198L6.61692 11.5831C3.68414 13.1813 1.7041 16.2346 1.64746 19.7755H22.953C22.8964 16.2346 20.9163 13.1813 17.9835 11.5831Z"/></svg>
            </div>
            <div class="btn-text-group">
              <span class="btn-small-text">Descargar para</span>
              <span class="btn-large-text">Android (APK)</span>
            </div>
          </a>
        </div>
      </div>
    </div>

    <div class="footer-bottom">
      <div class="bottom-content">
        <div class="bottom-left">
          <p class="copyright">
            &copy; {currentYear} <span class="accent-text">{siteConfig.shortName}</span>. Hecho por fans, para fans.
          </p>
          <p class="credits">Hecho con ❤️ por <span class="author-name">{siteConfig.author}.</span></p>
        </div>
        
        <div class="bottom-meta">
          <div class="systems-status" id="health-monitor">
            <div class="status-item" title="Cloudflare D1 Database" data-system="d1">
              <span class="dot"></span>
              <span>D1</span>
            </div>
            <div class="status-item" title="Cloudflare R2 Storage" data-system="r2">
              <span class="dot"></span>
              <span>R2 <small class="percent-label"></small></span>
            </div>
            <div class="status-item" title="Firebase Authentication" data-system="auth">
              <span class="dot"></span>
              <span>Auth</span>
            </div>
            <div class="status-item" title="Telegram Bot Sync" data-system="bot">
              <span class="dot"></span>
              <span>Bot</span>
            </div>
          </div>
          <span class="version-pill">v2.1.2</span>
        </div>
      </div>
    </div>
  </div>
</footer>
