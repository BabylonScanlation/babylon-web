---
import type { Comment, User } from '../types';
import CommentsWrapper from './comments/CommentsWrapper.svelte';

interface Props {
  targetType: 'series' | 'chapter' | 'news';
  targetId: number | string;
  comments: Comment[];
  user?: User | null;
}

const { targetType, targetId, comments: initialComments = [], user = null } = Astro.props;

// Orion: Saneamos las fechas para evitar el bug de "Invalid time value" de Astro
const safeComments = initialComments.map((c) => ({
  ...c,
  createdAt:
    c.createdAt &&
    typeof c.createdAt === 'object' &&
    (c.createdAt as any) instanceof Date &&
    !isNaN((c.createdAt as any).getTime())
      ? (c.createdAt as any).toISOString()
      : typeof c.createdAt === 'string' || typeof c.createdAt === 'number'
        ? c.createdAt
        : new Date().toISOString(),
}));
---

<div class="comments-container-glass">
  <CommentsWrapper
    client:load
    targetType={targetType}
    targetId={targetId}
    initialComments={safeComments}
    user={user}
  />
</div>

<style>
  /* --- Comments Shared Styles --- */
  .comments-container-glass {
    background: rgba(255, 255, 255, 0.02);
    border: none; /* Astra: Eliminado borde para limpieza total */
    border-radius: 16px;
    padding: 2rem;
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }

  @media (max-width: 768px) {
    .comments-container-glass {
      padding: 1rem;
    }
  }
</style>
