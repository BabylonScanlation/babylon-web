---
import type { Comment, User } from '../types';
import CommentsWrapper from './comments/CommentsWrapper.svelte';

interface Props {
  targetType: 'series' | 'chapter' | 'news';
  targetId: number | string;
  comments: Comment[];
  user?: User | null;
}

const { targetType, targetId, comments: initialComments = [], user = null } = Astro.props;

// Orion: Saneamos las fechas para evitar el bug de "Invalid time value" de Astro
const safeComments = initialComments.map(c => ({
  ...c,
  createdAt: (c.createdAt instanceof Date && !isNaN(c.createdAt.getTime())) 
    ? c.createdAt.toISOString() 
    : (typeof c.createdAt === 'string' || typeof c.createdAt === 'number') 
      ? c.createdAt 
      : new Date().toISOString()
}));
---

<CommentsWrapper
  client:load
  targetType={targetType}
  targetId={targetId}
  initialComments={safeComments}
  user={user}
/>