---
// src/components/BottomNav.astro
const { pathname } = Astro.url;
const { user } = Astro.locals;

const navItems = [
  {
    id: 'home',
    label: 'Inicio',
    href: '/',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>`
  },
  {
    id: 'search',
    label: 'Buscar',
    href: '/search',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>`
  },
  {
    id: 'news',
    label: 'Noticias',
    href: '/news',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 20H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v1m2 13a2 2 0 0 1-2-2V7m2 13a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2m-4-3H9M7 8h10M7 12h10M7 16h10"></path></svg>`
  },
  {
    id: 'library',
    label: 'Biblioteca',
    href: '/library',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path></svg>`
  },
  {
    id: 'profile',
    label: user ? 'Perfil' : 'Ingresar',
    href: user ? '/profile' : '#',
    action: !user ? 'login' : undefined,
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>`
  }
];
---

<nav class="mobile-bottom-nav" id="mobile-bottom-nav">
  <div class="nav-glass-container">
    {navItems.map((item) => {
      const isActive = item.href !== '#' && (pathname === item.href || (item.href !== '/' && pathname.startsWith(item.href)));
      
      return (
        <a 
          href={item.href} 
          class:list={['nav-item', { active: isActive }]}
          data-open-modal={item.action}
          id={item.id === 'profile' ? 'mobile-profile-link' : undefined}
          onclick={item.action ? "event.preventDefault(); window.dispatchEvent(new CustomEvent('open-auth-modal', { detail: { view: 'login' } }))" : undefined}
        >
          <div class="icon-wrapper">
            <Fragment set:html={item.icon} />
            {item.id === 'news' && <span data-news-badge class="news-badge-dot hidden">0</span>}
          </div>
          <span class="nav-label">{item.label}</span>
          {isActive && <div class="active-indicator" />}
        </a>
      )
    })}
  </div>
</nav>

<script>
  // Logic for Auth Update
  document.addEventListener('auth-success', async () => {
    const profileLink = document.getElementById('mobile-profile-link');
    if (!profileLink) return;

    try {
      const res = await fetch('/api/auth/status?t=' + Date.now());
      if (!res.ok) return;
      const user = await res.json();

      if (user && user.uid) {
        const label = profileLink.querySelector('.nav-label');
        if (label) label.textContent = 'Perfil';
        profileLink.setAttribute('href', '/profile');
        profileLink.removeAttribute('data-open-modal');
        (profileLink as any).onclick = null;
      }
    } catch (e) {
      console.error('Error updating mobile nav:', e);
    }
  });

  // Astra: Smart Hide on Scroll
  let lastScrollY = window.scrollY;
  const bottomNav = document.getElementById('mobile-bottom-nav');

  window.addEventListener('scroll', () => {
    if (!bottomNav) return;
    
    if (document.body.getAttribute('data-reader-modal') === "open") {
      bottomNav.classList.remove('nav-hidden');
      return;
    }

    const currentScrollY = window.scrollY;

    if (currentScrollY > lastScrollY && currentScrollY > 100) {
      bottomNav.classList.add('nav-hidden');
    } else {
      bottomNav.classList.remove('nav-hidden');
    }
    lastScrollY = currentScrollY;
  }, { passive: true });
</script>

<style>
  .mobile-bottom-nav {
    display: none;
    position: fixed;
    bottom: 24px; /* Flotando real sobre el borde */
    left: 0;
    right: 0;
    z-index: 4000;
    padding: 0 1rem;
    pointer-events: none;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.3s ease;
  }

  .mobile-bottom-nav.nav-hidden,
  :global(body[data-search-filter="open"]) .mobile-bottom-nav {
    transform: translateY(100%) scale(0.8);
    opacity: 0;
  }

  .nav-glass-container {
    pointer-events: auto;
    max-width: 500px;
    margin: 0 auto;
    background: var(--glass-bg);
    backdrop-filter: blur(25px);
    -webkit-backdrop-filter: blur(25px);
    border: 1px solid var(--glass-border);
    border-radius: 100px; /* Forma de Cápsula */
    display: flex;
    justify-content: space-around;
    align-items: center;
    padding: 0.4rem;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.4), 0 0 20px rgba(0, 191, 255, 0.05);
  }

  .nav-item {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    text-decoration: none;
    color: rgba(255, 255, 255, 0.4);
    padding: 0.6rem 0.2rem;
    transition: all 0.3s cubic-bezier(0.23, 1, 0.32, 1);
    flex: 1;
  }

  .nav-item.active {
    color: var(--accent-color);
    text-shadow: 0 0 15px var(--accent-glow);
  }

  .nav-label {
    font-size: 0.65rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    opacity: 0.6;
    transition: opacity 0.3s;
  }

  .nav-item.active .nav-label {
    opacity: 1;
  }

  .icon-wrapper {
    width: 24px;
    height: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    position: relative;
  }

  .news-badge-dot {
    position: absolute;
    top: -4px;
    right: -6px;
    background: #ff4444;
    color: white;
    font-size: 0.55rem;
    font-weight: 900;
    min-width: 14px;
    height: 14px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2px;
    box-shadow: 0 0 10px rgba(255, 68, 68, 0.5);
    border: 1.5px solid #050505;
    z-index: 10;
  }

  .news-badge-dot.hidden {
    display: none;
  }

  .nav-item :global(svg) {
    width: 22px;
    height: 22px;
  }

  .active-indicator {
    position: absolute;
    bottom: 2px;
    width: 20px;
    height: 3px;
    background: var(--accent-color);
    border-radius: 100px;
    box-shadow: 0 0 10px var(--accent-color);
  }

  .nav-item:active .icon-wrapper {
    transform: scale(0.8);
  }

  @media (max-width: 1023px) {
    .mobile-bottom-nav {
      display: block;
    }
  }

  @media (min-width: 1024px) {
    .mobile-bottom-nav {
      display: none !important;
    }
  }
</style>