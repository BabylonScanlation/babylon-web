---
// src/components/BottomNav.astro
const { pathname } = Astro.url;
const { user } = Astro.locals;

const navItems = [
  {
    id: 'home',
    label: 'Inicio',
    href: '/',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>`,
  },
  {
    id: 'search',
    label: 'Buscar',
    href: '/search',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>`,
  },
  {
    id: 'news',
    label: 'Noticias',
    href: '/news',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 20H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v1m2 13a2 2 0 0 1-2-2V7m2 13a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2m-4-3H9M7 8h10M7 12h10M7 16h10"></path></svg>`,
  },
  {
    id: 'library',
    label: 'Biblioteca',
    href: '/library',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path></svg>`,
  },
  {
    id: 'profile',
    label: user ? 'Perfil' : 'Ingresar',
    href: user ? '/profile' : '#',
    action: !user ? 'login' : undefined,
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>`,
  },
];
---

<nav class="mobile-bottom-nav" id="mobile-bottom-nav">
  <div class="nav-glass-container">
    {navItems.map((item) => {
      const isActive = item.href !== '#' && (pathname === item.href || (item.href !== '/' && pathname.startsWith(item.href)));
      
      return (
        <a 
          href={item.href} 
          class:list={['nav-item', { active: isActive }]}
          data-open-modal={item.action}
          id={item.id === 'profile' ? 'mobile-profile-link' : undefined}
          onclick={item.action ? "event.preventDefault(); window.dispatchEvent(new CustomEvent('open-auth-modal', { detail: { view: 'login' } }))" : undefined}
        >
          <div class="icon-wrapper">
            <Fragment set:html={item.icon} />
            {item.id === 'news' && <span data-news-badge class="news-badge-dot hidden"></span>}
          </div>
          <span class="nav-label">{item.label}</span>
          {isActive && <div class="active-indicator" />}
        </a>
      )
    })}
  </div>
</nav>
