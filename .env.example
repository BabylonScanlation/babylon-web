# === PUBLIC CONFIG EXAMPLE (.env.example) ===
# Copia este archivo a .env y completa los valores

PUBLIC_FIREBASE_API_KEY="your_api_key_here"
PUBLIC_FIREBASE_PROJECT_ID="your_project_id_here"
PUBLIC_FIREBASE_AUTH_DOMAIN="your_project.firebaseapp.com"
PUBLIC_FIREBASE_STORAGE_BUCKET="your_project.firebasestorage.app"
PUBLIC_FIREBASE_MESSAGING_SENDER_ID="your_sender_id_here"
PUBLIC_FIREBASE_APP_ID="your_app_id_here"

PUBLIC_TURNSTILE_SITE_KEY="0x4AAAAAA..."
PUBLIC_TURNSTILE_DEV_SITE_KEY="1x00000000000000000000AA"

PUBLIC_ADSTERRA_BANNER_ID="your_ad_id_here"
PUBLIC_ADSTERRA_BANNER_LARGE_ID="your_ad_id_here"
PUBLIC_ADSTERRA_BANNER_SMALL_ID="your_ad_id_here"
PUBLIC_ADSTERRA_SQUARE_ID="your_ad_id_here"
