# --- Database (Cloudflare D1) ---
DB=

# --- Auth & Security ---
JWT_SECRET=              # Clave para firmar JWTs (mínimo 32 caracteres)
AUTH_SECRET=             # Clave para firmar manifiestos de capítulos
INTERNAL_CRYPTO_SALT=    # Salt para ofuscación XOR de payloads (NO exponer al cliente)
SHIELD_TOKEN=            # Token secreto para el proxy de R2
SUPER_ADMIN_UID=         # UID del usuario con privilegios totales de Admin

# --- R2 Buckets ---
R2_ASSETS=               # Bucket para portadas y assets permanentes
R2_CACHE=                # Bucket para caché de capítulos y assets temporales
R2_PUBLIC_URL_ASSETS=    # URL pública (o custom domain) para R2_ASSETS

# --- External APIs ---
TELEGRAM_BOT_TOKEN=      # Token del bot de Telegram
TELEGRAM_CHAT_ID=        # ID del canal/grupo de Telegram
